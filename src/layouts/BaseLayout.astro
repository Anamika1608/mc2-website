---
import { Font } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "MC²+ — Multiply · Collaborate · Create. India's flagship energy innovation platform.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-sora" preload />
    <Font cssVariable="--font-faculty" preload />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main"><slot /></main>
    <Footer />
  </body>
</html>

<script>
  // Shared trigger for every `.reveal` element site-wide (Hero H1s + a
  // handful of section headings) — see src/styles/global.css for the full
  // reveal mechanism this drives. `.armed` (added immediately, confirming
  // JS is running) switches each heading to its pre-reveal clipped state;
  // `.in-view` (added once per element, on first intersection) starts the
  // reveal. IntersectionObserver fires ~immediately for an element already
  // on-screen at observe-time, so this ONE mechanism naturally covers both
  // above-the-fold Heroes and below-the-fold headings — no separate
  // load-triggered code path needed. No-JS / reduced-motion: skipped
  // entirely, leaving every heading in its normal, fully-visible state.
  const prefersReducedMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const targets = document.querySelectorAll<HTMLElement>(".reveal");

  if (targets.length && !prefersReducedMotion && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.3 },
    );
    for (const target of targets) {
      target.classList.add("armed");
      observer.observe(target);
    }
  }

  // Site-wide scroll-arrow click-to-scroll: all 8 hero/section down-chevrons
  // (Home/About/Contact/Initiatives/Portfolio/Support/Team Heroes +
  // Initiatives' HowItWorks) share the identical markup shape — a
  // `<button class="scroll">` wrapping a decorative, aria-hidden SVG — so one
  // shared handler covers every instance instead of 8 near-duplicate inline
  // scripts. Every one of these buttons sits as a descendant of its own
  // top-level <section> (the hero/section root), and every page composes its
  // sections as direct children of <main> (this file, above), so walking
  // forward from that <section> to the next actual <section> sibling always
  // resolves to the real next section on the page — verified per-page
  // against each page's own .astro file, not assumed. Scoped to
  // `button.scroll` (not the bare `.scroll` class still used by the SVG-only
  // sizing rules inside each component) so this can never accidentally bind
  // to a future non-interactive `.scroll` element elsewhere.
  const scrollArrows = document.querySelectorAll<HTMLElement>("button.scroll");
  for (const arrow of scrollArrows) {
    arrow.addEventListener("click", () => {
      const ownSection = arrow.closest("section");
      // NOT a plain `.nextElementSibling` read: HowItWorks.astro (Initiatives
      // page) owns a component-local `<script>` for its hover-to-activate
      // cards, and Astro renders that as a literal `<script>` DOM node
      // immediately after `</section>` (confirmed via the rendered page
      // source, not assumed) rather than hoisting it out of the body — so a
      // bare `nextElementSibling` read resolves to that `<script>` tag
      // instead of the real next section (Programs), silently no-op'ing
      // `scrollIntoView` on an element with no layout box. Walking forward
      // until an actual `<section>` is found skips over any such incidental
      // non-section siblings (a script, a style tag, etc.) and is a no-op
      // everywhere else, where the immediate next sibling already is one.
      let target = ownSection?.nextElementSibling ?? null;
      while (target && target.tagName !== "SECTION") {
        target = target.nextElementSibling;
      }
      target?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  }
</script>
