---
// Figma file u4NLOVKuXUTKULhSn0sAJQ: eyebrow 1:13353, underline 1:13352,
// H1 lines 1:13357/1:13358/1:13359, lede group 1:13360, curves+spark group
// 1:13475, scroll chevron 1:13354. See exact derivations in style block below.
// Right-side spark: node 1:13480 (fileKey u4NLOVKuXUTKULhSn0sAJQ) -- verified
// via get_metadata to be a SEPARATE sibling of the curves+spark group
// (1:13475), not baked into hero-curves.svg. Confirmed shape matches
// spark-orange.svg (viewBox 78x85 vs node's own 77.34x84.57) -- that asset
// was already sitting in this folder unused (a prior comment here wrongly
// assumed it wasn't needed).
import HeroCurves from "../../assets/team/hero-curves.svg";
import ScrollArrow from "../../assets/team/scroll-arrow.svg";
import RevealStar from "../../assets/shared/reveal-star.svg";
import SparkOrange from "../../assets/team/spark-orange.svg";
---

<section class="hero">
  <div class="orbit" aria-hidden="true">
    <HeroCurves class="curves" />
    <SparkOrange class="right-spark" />
  </div>

  <div class="hero-inner reveal">
    <p class="eyebrow">TEAM &amp; GOVERNANCE</p>
    <div class="underline" aria-hidden="true"></div>

    <h1>
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">Leadership</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">built for <span class="accent">speed</span></span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">and <span class="accent">accountability</span>.</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </h1>

    <p class="lede reveal-rise reveal-rise--after-3-lines">
      A board that carries national gravitas, an advisory bench deep in
      energy and deep-tech, and an operating team that moves like a startup.
    </p>

    <ScrollArrow class="scroll" aria-hidden="true" />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--color-cream);
    /* Top spacing kept as-is (sits under the sticky header, not derived from
       Figma's absolute canvas), mirroring AboutHero. */
    padding-block: 6rem 0;
  }
  @media (min-width: 1024px) {
    .hero {
      /* Was 63.25rem, matching hero-curves.svg's own raw exported height —
         a placeholder that was never fitted to the actual content (own
         prior comment admitted as much). Real content (eyebrow through the
         scroll chevron) only needs ~38.2rem; the 63.25rem floor left ~401px
         of dead space between the chevron and the next section. Refit to
         42rem — .hero has overflow:hidden, so the decorative curve (100%
         width, height:auto) just crops a bit earlier instead of forcing
         extra section height; verified the crop still reads fine
         (crosses cleanly just before its own intersection point rather than
         mid-stroke). Cuts the dead space to ~61px, matching the same
         fit-to-content pass Initiatives/Portfolio/Home's Heroes already
         went through (per user request 2026-07-06).
         Bumped 42rem -> 46.87rem: adding .right-spark (node 1:13480, see
         above) revealed its bottom edge sits ~78px past .hero's old bottom,
         so overflow:hidden was silently clipping almost the entire spark.
         46.87rem is the exact floor for .right-spark's own bottom edge at
         1920px width (74.19rem hero-top + spark-bottom 749.92px), not an
         arbitrary bump. */
      min-height: 46.87rem;
    }
  }

  /* Curves + spark: 1:13475 (fileKey u4NLOVKuXUTKULhSn0sAJQ) exports as a
     single 1920x1012 SVG (src/assets/team/hero-curves.svg) confirmed (Task 1)
     to already bake in its one orange four-point spark (path "Vector_4",
     matching node 1:13479) alongside the 3 stroked/filled orbit curves
     (Vector/Vector_2/Vector_3, matching nodes 1:13476/1:13477/1:13478) — the
     exported file has exactly 4 <path> elements, verified by inspecting the
     SVG source. Screenshot of 1:13475 shows only the one spark visible.
     CORRECTION: a prior comment here claimed no <SparkOrange> overlay was
     needed at all -- wrong. get_metadata on the hero's full node tree shows
     a SECOND, separate spark (node 1:13480, x=1647.1 y=665.66 w=77.34
     h=84.57 against the 1920x1012 canvas) as a sibling of 1:13475, not part
     of the curves SVG. That's what .right-spark below renders. */
  .orbit {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .curves {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Node 1:13480 -- percentages (not fixed rem) since .orbit/.curves scale
     fluidly with viewport width (width:100%, height:auto), unlike a
     fixed-then-scaled artboard. left/top/width are each this node's own
     Figma position/size as a % of the 1920x1012 canvas, so it scales in
     lockstep with the curves SVG at any viewport width. Aspect ratio (78x85,
     matching this asset's own viewBox almost exactly) is preserved via
     height:auto. */
  .right-spark {
    position: absolute;
    left: 85.786%;
    top: 65.777%;
    width: 4.028%;
    height: auto;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 54rem; /* buffer above the 47.58rem lede group width (1:13360) and 43.44rem widest H1 line (1:13359) */
    margin-inline: auto;
    padding-inline: 1.25rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-hero-eyebrow); /* 27.07px, node 1:13353 — normalized to home hero scale per user directive 2026-07-06 */
    letter-spacing: 0.25em; /* 6.7675px / 27.07px = 0.25em exactly, node 1:13353 */
    /* CORRECTION vs task brief: get_design_context + pixel-sampling of the
       rendered node both give #949494, not --color-orange-bright (#ff7400).
       #949494 is within 1 unit/channel of --color-gray (#959595, same token
       AboutHero's eyebrow uses) — treated as that token, no new one-off gray. */
    color: var(--color-gray);
  }
  .underline {
    width: 11.77rem; /* 188.25px, node 1:13352 (hairline vector, height 0) */
    height: 1px;
    margin: 2.82rem auto 1.72rem; /* 45.11px eyebrow->underline gap / 27.45px underline->H1 gap, nodes 1:13353/1:13352/1:13357 */
    background: #000; /* one-off literal: node 1:13352's own SVG source is `stroke="var(--stroke-0, black)"`, not a token */
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-hero-h1); /* 80px, nodes 1:13357/1:13358/1:13359 — normalized to home hero scale per user directive 2026-07-06 */
    line-height: var(--text-hero-h1-lh); /* baseline delta 87.57px (418.98->506.55->594.11) / 80px = 1.0946 — normalized to home hero scale per user directive 2026-07-06 */
    /* CORRECTION vs task brief note: get_design_context reports #1e1e3e for
       all 3 H1 lines. This is NOT --color-ink-alt (#1e1e3c) nor --color-ink
       (#1e1e3a) -- documented literal per Figma (Figma wins). */
    color: #1e1e3e;
  }
  h1 .line {
    display: block;
  }
  h1 .accent {
    color: var(--color-orange-bright); /* #ff7400 exact match, nodes 1:13358/1:13359 */
  }

  .lede {
    /* Lede (1:13360) is an outlined/vectorized paragraph, not real text, so
       its font-size is reverse-engineered the same way as AboutHero's: the
       "A" cap height (vector 1:13361, 22.63px) against Sora's capHeight/upm
       of 0.73 -> 22.63/0.73 ~= 31.0px; ascenders elsewhere in the group
       (e.g. 21.77px, matching AboutHero's "t" measurement exactly) confirm
       the same ~31px. Line-height is derived from the 3 baked lines' own
       baseline deltas (720.95 -> 761.41 -> 801.87, delta 40.46px both times)
       / 31px ~= 1.305. Max-width 47.58rem = 761.2px, the group's own
       bounding width (1:13360).
       Color: the exported SVG's own path fill is `var(--fill-0, #1E1E3E)`
       -- the SAME literal as the H1 base color, not --color-ink (#1e1e3a)
       used by AboutHero's lede. Documented literal per Figma (Figma wins). */
    max-width: 47.58rem;
    margin: 1.43rem auto 0; /* 22.84px gap, H1 line-3 bottom (698.11) -> lede top (720.95) */
    font-family: var(--font-sans);
    font-size: var(--text-hero-lede); /* 31px, derived — see comment above — normalized to home hero scale per user directive 2026-07-06 */
    line-height: var(--text-hero-lede-lh); /* derived — see comment above — normalized to home hero scale per user directive 2026-07-06 */
    color: #1e1e3e; /* literal, matches lede's own baked SVG fill — see comment above */
  }

  .scroll {
    display: block;
    margin: 8.29rem auto 0; /* 132.63px gap, lede bottom (830.92) -> scroll chevron top (963.55), node 1:13354 */
  }

  @media (max-width: 1023.98px) {
    h1 {
      font-size: var(--text-hero-h1-fluid); /* was clamp(2.4rem, 7vw, 5rem) — normalized to home hero scale per user directive 2026-07-06 */
    }
    .lede {
      max-width: 90%;
    }
  }
</style>
