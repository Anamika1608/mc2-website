---
// Figma file u4NLOVKuXUTKULhSn0sAJQ, node 1:12591 (Board of Directors + Advisory
// Board share one big group; this component only covers the Board of Directors
// half): eyebrow "GOVERNANCE" (1:12888), H2 "Board of Directors" (1:12889),
// 2-line subheading (vectorized paragraph, 1:12890), card grid (1:13078) with
// 5 director cards (1:13079 Neeraj, 1:13131 Vikas, 1:13171 Sanjay, 1:13283
// Akshay, 1:13211 Sandeep). See exact derivations in the style block below.
import { Image } from "astro:assets";
import SparkOrange from "../../assets/team/board-spark.svg";
import neeraj from "../../assets/team/dir-neeraj.png";
import vikas from "../../assets/team/dir-vikas.png";
import sanjay from "../../assets/team/dir-sanjay.png";
import akshay from "../../assets/team/dir-akshay.png";
import sandeep from "../../assets/team/dir-sandeep.png";
import RevealStar from "../../assets/shared/reveal-star.svg";

// Copy verbatim from the task brief. Literal "&" is used here (not the
// "&amp;" entity) to match the house convention already established by
// SponsorStrip.astro's SPONSORS data array ("Oil & Natural Gas") — Astro's
// `{}` text interpolation auto-escapes "&" to "&amp;" in the rendered HTML,
// so storing the literal entity text here would double-escape to "&amp;amp;".
const DIRECTORS = [
  {
    photo: neeraj,
    name: "Dr. Neeraj Mittal",
    role: "CHAIRMAN & DIRECTOR",
    desc: "Secretary, Ministry of Petroleum and Natural Gas",
  },
  {
    photo: vikas,
    name: "Shri Vikas Kaushal",
    role: "DIRECTOR",
    desc: "Chairman & Managing Director, HPCL",
  },
  {
    photo: sanjay,
    name: "Shri Sanjay Khanna",
    role: "DIRECTOR",
    desc: "Chairman & Managing Director, BPCL",
  },
  {
    photo: akshay,
    name: "Shri Akshay Kumar Singh",
    role: "DIRECTOR",
    desc: "Managing Director and Chief Executive Officer, Petronet LNG Ltd.",
  },
  {
    photo: sandeep,
    name: "Shri Sandeep Maheshwari",
    role: "DIRECTOR & CHIEF EXECUTIVE OFFICER",
    desc: "Executive Director, Corporate Strategy & Business Development, HPCL",
  },
];
---

<section class="board">
  <div class="container">
    <p class="eyebrow">GOVERNANCE</p>
    <div class="reveal">
      <h2>
        <span class="reveal-line">
          <span class="reveal-line-box">
            <span class="reveal-line-text">Board of Directors</span>
            <RevealStar class="reveal-star" aria-hidden="true" />
          </span>
        </span>
      </h2>
      <p class="subheading reveal-rise reveal-rise--after-1-line">
        MC&sup2; Plus is governed by leaders drawn from the Ministry of
        Petroleum and Natural Gas and India&rsquo;s energy majors.
      </p>
    </div>

    <div class="grid">
      {DIRECTORS.map((p) => (
        <article class="card">
          <div class="photo-wrap">
            <span class="v-line" aria-hidden="true"></span>
            <SparkOrange class="card-spark" aria-hidden="true" />
            <Image src={p.photo} alt={p.name} widths={[240, 480]} sizes="240px" class="photo" />
          </div>
          <span class="h-line" aria-hidden="true"></span>
          <div class="meta">
            <h3>{p.name}</h3>
            <p class="role">{p.role}</p>
            <p class="desc">{p.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .board {
    background: var(--color-cream);
    /* Figma gap: Board-top 1162 − Hero-bottom 984 ≈ 178px. Single-ownership:
       each section owns only its top gap (bottom 0), mirroring the About page. */
    padding-block: 11.15rem 0;
  }

  /* Eyebrow (node 1:12888): real text, Faculty, 27.07px. Pixel-sampled darkest
     ink = RGB(255,116,0) = #ff7400, an EXACT match for --color-orange-bright
     (the token's own comment cites this exact node as its source) — unlike
     TeamHero's eyebrow (which turned out gray on inspection), this one really
     is the bright-orange token, matching the task brief's expectation. */
  .eyebrow {
    margin: 0 0 1.3rem;
    font-family: var(--font-display);
    font-size: 1.375rem; /* 22px — reduced from the Figma 27.07px per user directive 2026-07-06 (desktop type felt oversized on sub-1920 laptops) */
    letter-spacing: 0.25em; /* same tracking formula as TeamHero's eyebrow, node 1:13353 */
    color: var(--color-orange-bright);
    text-align: center;
  }

  /* H2 (node 1:12889): real text, Faculty 65px. Pixel-sampled darkest ink =
     RGB(30,30,60) = #1e1e3c, an exact match for --color-ink-alt (identical
     treatment to SponsorStrip's H2). */
  h2 {
    margin: 0 0 1.5rem;
    font-family: var(--font-display);
    font-size: 3.25rem; /* 52px — reduced from the Figma 65px per user directive 2026-07-06 (desktop type felt oversized on sub-1920 laptops) */
    color: var(--color-ink-alt);
    text-align: center;
  }

  /* Subheading (node 1:12890) is a vectorized 2-line paragraph, not real text.
     Isolated screenshot + row-by-row ink scan gives a cap-height (steep
     ink-transition edge to baseline-drop edge) of ~14px on both lines ->
     14 / 0.73 (Sora capHeight/upm, same constant used throughout this repo's
     derivations) ~= 19.2px = 1.2rem. Baseline-to-baseline distance between
     the two lines measures ~32px -> line-height 32/19.2 ~= 1.667. Darkest
     ink pixel = RGB(149,149,149) = #959595, an exact match for --color-gray.
     Max-width 44.64rem = line 1's own measured width (714.19px, node 1:12890). */
  .subheading {
    max-width: 44.64rem;
    margin: 0 auto 5.5rem; /* widened from 4.5rem — more breathing room above the card grid per user directive 2026-07-06 */
    font-family: var(--font-sans);
    font-size: 1.0625rem; /* 17px — reduced from the derived 19.2px per user directive 2026-07-06 */
    line-height: 1.667; /* derived — see comment above */
    color: var(--color-gray);
    text-align: center;
  }

  /* Grid: 5 director cards. Was repeat(3, ...) (3-then-2 layout) — switched
     to 2 columns (user directive, dev feedback deck) so every card gets
     roughly double the column width, letting the longest names
     ("Shri Akshay Kumar Singh", "Shri Sandeep Maheshwari") fit on one line
     (see `.meta h3` white-space:nowrap below) at a normal, readable size
     across the whole ≥1024px range — verified live via Playwright, a
     3-column grid only fit those names unwrapped at ~1900px+ without
     shrinking the font to an illegibly small size. 5 items in a 2-col grid
     auto-places as [Neeraj, Vikas] / [Sanjay, Akshay] / [Sandeep alone],
     needing no manual placement rules; unlike the old 3-column layout,
     Sandeep's card is no longer the odd one out needing a span/width
     override (see removed rules this replaced). */
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 3rem; /* widened from 2.5rem per user directive 2026-07-06 */
    row-gap: 3.75rem; /* widened from 3rem — measured ~22% tighter than reference, per user directive 2026-07-06 */
  }

  .card {
    position: relative;
    display: flex;
    /* Was center: with .h-line now positioned via `top:0` relative to .card
       (see below) rather than .photo-wrap, center-alignment let .meta's
       height (which grows when a name wraps to 2 lines) push .photo-wrap
       down away from the card's own top, breaking that assumption and
       causing .h-line to overlap the name instead of sitting at the photo's
       top edge (confirmed live at 1024/1100/1200px, where names still wrap
       to 2 lines). Top-aligning keeps .photo-wrap's top pinned to the
       card's own top always, regardless of .meta's height. */
    align-items: flex-start;
    gap: 1.75rem; /* widened from 1.5rem per user directive 2026-07-06 */
  }

  /* Photo (rounded-rectangle node 1:13126/1:13166/etc). get_design_context on
     the rectangle itself returns a plain `overflow-hidden` container with no
     rounded-* class, so no border-radius is applied; the assets are already
     grayscale on a cream background.
     Size: was a flat 15rem (desktop) / 13.5rem (≤679.98px, mobile-only
     override) — oversized at every width and, combined with .h-line's fixed
     reach (removed below), the direct cause of names wrapping to 3 lines and
     overlapping across the whole 680–1366px range (confirmed live via a
     13-width sweep: real horizontal overflow up to 133px at several widths).
     Replaced with one fluid clamp() (same two-point formula convention as
     PillButton.astro) covering every width with no breakpoint jumps: 8rem
     (128px) at 375px up to 12rem (192px) at 1920px — a real reduction at
     every width, and removes the need for a separate mobile override. */
  .photo-wrap {
    position: relative;
    flex: 0 0 clamp(8rem, 7.03rem + 4.14vw, 12rem);
    width: clamp(8rem, 7.03rem + 4.14vw, 12rem);
    /* Explicit (not content-derived) so .v-line/.card-spark's percentage
       top/height below have an unambiguous reference. */
    height: clamp(8rem, 7.03rem + 4.14vw, 12rem);
  }
  /* Fixed width+height (not width:100%/aspect-ratio:1) is deliberate: Astro's
     <Image> always emits width/height HTML attributes (here 1080x1080), and
     verified live in Chrome — width:100%+aspect-ratio:1 combined with those
     attributes renders the img box hugely tall (a real layout bug, confirmed
     by isolated repro outside Astro too), not a square. Matching the
     photo-wrap's own fluid width instead sidesteps it while still scaling. */
  .photo {
    display: block;
    width: clamp(8rem, 7.03rem + 4.14vw, 12rem);
    height: clamp(8rem, 7.03rem + 4.14vw, 12rem);
    object-fit: cover;
  }

  /* Desktop-only decorative flourish (spark at the photo's top-right corner,
     crossed by a vertical + horizontal hairline — Figma nodes 1:13128/29/30),
     removed sitewide in an earlier pass because its old fixed-rem values
     were calibrated for one specific card width and badly overshot at every
     other width across the fluid grid (real horizontal overflow, up to
     133px, plus text overlap). Re-added here, desktop-only per user
     request, using percentages instead of fixed rem so it scales correctly
     across the whole ≥1024px range rather than just one reference width:
     .v-line/.card-spark are sized relative to .photo-wrap's own (fluid)
     box, since they only need to track the photo's edge; .h-line is placed
     on .card itself (not .photo-wrap) and sized relative to the card's own
     width, since it alone needs to bridge across the gap into .meta, whose
     width doesn't scale at the same rate as the photo alone. Verified via
     Playwright at 1024/1440/1920px: no overflow, no overlap with the name. */
  .card-spark {
    position: absolute;
    top: 0;
    right: 0;
    transform: translate(50%, -50%);
    width: 19%; /* 45.9px / 240px original photo, node 1:13128 */
    height: 19%;
    z-index: 2;
    pointer-events: none;
  }
  .v-line {
    position: absolute;
    right: 0;
    top: -21.9%; /* 52.5px / 240px original photo */
    width: 1px;
    height: 70%; /* 167.9px / 240px original photo */
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(255, 116, 0, 0.1) 0%,
      rgba(255, 116, 0, 0.6) 31%,
      rgba(255, 116, 0, 0.35) 100%
    );
  }
  .h-line {
    position: absolute;
    left: 54%;
    top: 0;
    width: 29%;
    height: 1px;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to right,
      rgba(255, 116, 0, 0.4) 0%,
      rgba(255, 116, 0, 0.55) 17%,
      rgba(255, 116, 0, 0.12) 100%
    );
  }

  .meta {
    min-width: 0;
  }

  /* Name: real text, Faculty ~30px. Pixel-sampled darkest ink = RGB(30,30,62)
     = #1e1e3e (literal, documented in the task brief — not --color-ink-alt). */
  .meta h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.5rem; /* 24px — reduced from 30px per user directive 2026-07-06 */
    line-height: 1.3;
    color: #1e1e3e;
    white-space: nowrap; /* user directive, dev feedback deck — names must not wrap; the 2-col grid above gives every card enough width for this at ≥1024px */
  }

  /* Role: real text, Faculty ~14.88px uppercase, tracked ~1.49px. Pixel-sampled
     darkest ink = RGB(148,148,148), 1 unit/channel from --color-gray (#959595)
     — treated as that token (same as TeamHero's eyebrow correction). Margins:
     6.47px gap above (name->role) / 13.94px gap below (role->desc), node 1:13080. */
  .role {
    margin: 0.4rem 0 0.85rem;
    font-family: var(--font-display);
    font-size: 0.93rem; /* 14.88px */
    letter-spacing: 0.093em; /* 1.49px / 14.88px */
    text-transform: uppercase;
    color: var(--color-gray);
  }

  /* Description (node 1:13082) is a vectorized paragraph, not real text, same
     technique as the subheading: cap-height ~13.5-14px on a no-descender line
     -> /0.73 ~= 19px = 1.2rem, matching the subheading's own derived size
     (kept as one shared body-text scale for the section). Darkest ink pixel
     = RGB(30,30,62) = #1e1e3e — the SAME literal as the name, not
     --color-ink-alt as the brief guessed (Figma wins). */
  .desc {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.0625rem; /* 17px — reduced from the derived 19.2px per user directive 2026-07-06 */
    line-height: 1.3;
    color: #1e1e3e;
  }

  @media (max-width: 1023.98px) {
    h2 {
      font-size: clamp(2.2rem, 6vw, 3.25rem);
    }
    /* .grid is already 2 columns at every width now (see .grid above), so no
       override needed here anymore — this block used to reset the
       desktop-only 3-column grid back to 2 for tablet. */
    /* Below 1024px, a 2-col grid's per-card width is too narrow for the
       photo and an un-wrapped long name to sit side by side (confirmed live:
       "Shri Akshay Kumar Singh"/"Shri Sandeep Maheshwari" overflowed the
       page at 680-900px in row layout). Stacking the card (photo above
       meta) gives the name the full card width instead of card-width minus
       photo minus gap — the same stacked layout already used below 680px,
       just extended up to cover this range too. */
    .card {
      flex-direction: column;
      align-items: flex-start;
    }
    /* Decorative flourish is desktop-only per user request — removed
       completely on tablet and mobile, not just resized/hidden partially. */
    .v-line,
    .h-line,
    .card-spark {
      display: none;
    }
  }

  @media (max-width: 679.98px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
