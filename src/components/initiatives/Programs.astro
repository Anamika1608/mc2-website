<script>
  // Hover-to-expand (this task). Follows Header.astro's existing script pattern (plain
  // DOM addEventListener + classList, no framework) — the only other interactive script
  // in this codebase. Desktop-only: below 1024 the fan collage doesn't exist (cards are
  // full-width/stacked, see the CSS media query), so there's nothing to hover between.
  const row = document.querySelector<HTMLElement>(".programs-row");
  const cardList = document.querySelectorAll<HTMLElement>(".programs-row .card");
  const cards = Array.from(cardList);
  const isDesktop = () => window.matchMedia("(min-width: 1024px)").matches;

  // Decorative spark tracking: the active card's own rendered left edge can't be read via
  // `offsetLeft` right after toggling `.is-active` — TWO cards resize simultaneously (the
  // previously-active one shrinking back to NARROW, the newly-active one growing to WIDE),
  // and both are still mid-transition at the instant the class toggles, so a synchronous
  // geometry read captures a stale, in-between layout rather than the transition's target.
  // Computed analytically instead, from the same WIDE/NARROW/OVERLAP % constants the CSS
  // itself uses (see the `.card`/`.card.is-active` width rules above): every card before
  // the active one is always NARROW (only one card is ever active at a time), so the
  // active card's left edge (as a % of the row's own width) is simply
  // `activeIndex * (NARROW - OVERLAP)`. This needs no DOM measurement of any transitioning
  // element, so it's correct immediately and lets the spark's own `transition: left` run
  // in sync with the cards' width/margin transitions instead of chasing a moving target.
  const NARROW = 28.345;
  const OVERLAP = 7.502;
  // Mobile/tablet counterpart of the --spark-left derivation above (see the mobile
  // scrollspy block below for why a second axis is needed at all): 64.62px is the
  // exact same card-top-to-numeral offset the desktop `top: 4.04rem` CSS rule already
  // uses (see .o1-spark below), reused rather than re-derived since .card-head's own
  // top padding is unchanged below 1024 (only its horizontal padding shrinks further
  // down, at 639.98px) — so the numeral still sits this far below each card's own top
  // at every width this offset is used at.
  const SPARK_NUMERAL_OFFSET = 64.62;

  const activate = (target: HTMLElement) => {
    cards.forEach((card) => card.classList.toggle("is-active", card === target));
    if (row) {
      const activeIndex = cards.indexOf(target);
      const leftPercent = activeIndex * (NARROW - OVERLAP);
      const rowWidth = row.getBoundingClientRect().width;
      row.style.setProperty("--spark-left", `${(leftPercent / 100) * rowWidth}px`);
      // Mobile/tablet: cards stack full-width vertically (see the <1024 media query),
      // so there's no horizontal fan to track — --spark-left above is meaningless at
      // that layout and the mobile-scoped CSS ignores it. What needs to move instead is
      // the VERTICAL position, so the spark stays beside whichever card is active as
      // the user scrolls past each one. Safe to read `target.offsetTop` directly here
      // (unlike the analytic --spark-left math above, which exists specifically
      // because reading geometry mid-transition is unreliable): mobile cards never
      // resize when `.is-active` toggles (width/min-height are pinned to 100%/auto at
      // this breakpoint regardless of state), so there's no simultaneous-transition
      // race to chase, only a plain static offset.
      row.style.setProperty("--spark-top", `${target.offsetTop + SPARK_NUMERAL_OFFSET}px`);
    }
  };

  if (row) {
    cards.forEach((card) => {
      card.addEventListener("mouseenter", () => {
        if (isDesktop()) activate(card);
      });
    });
    // Reset unconditionally (no isDesktop() guard) — unlike activating on hover, resetting
    // to O1 is always the correct state everywhere, including mobile. Guarding this too
    // left a card stuck `.is-active` (wrong border/title, since mobile doesn't override
    // those) if the viewport crossed below 1024 while the mouse was still over a
    // non-O1 card, e.g. narrowing the window mid-hover, since the guard then skipped the
    // reset entirely.
    row.addEventListener("mouseleave", () => {
      activate(document.querySelector(".card--o1")!);
    });
  }

  // Scroll-driven activation (mobile/tablet, <1024px): mirrors HowItWorks.astro's own
  // scrollspy fix (see that file for the general precedent) — there's no hover on touch
  // devices, so per direct feedback, whichever card is currently centered in the
  // viewport while scrolling activates instead, sliding the spark along to follow it
  // (see SPARK_NUMERAL_OFFSET/--spark-top above and the mobile-scoped .o1-spark
  // override in the CSS). The feedback slide offered a "stay constant per folder
  // (parallax)" alternative instead of sliding — sliding was chosen because it's the
  // more direct extension of the already-proven desktop mechanism, and the slide's own
  // "this will change on scroll" wording already implies a continuously-updating
  // interaction, not a static per-card decoration.
  // Kept as a SEPARATE, continuous observer (unlike the site's one-shot `.reveal`
  // observer in BaseLayout.astro, which unobserves after first trigger) so it keeps
  // reacting as the user keeps scrolling, and independent of the hover mechanism above
  // so the two never fight over `.is-active` on desktop.
  const isMobile = () => window.matchMedia("(max-width: 1023.98px)").matches;
  let scrollObserver: IntersectionObserver | null = null;

  const enableScrollActivation = () => {
    if (scrollObserver) return;
    scrollObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) activate(entry.target as HTMLElement);
        }
      },
      { rootMargin: "-45% 0px -45% 0px", threshold: 0 },
    );
    cards.forEach((card) => scrollObserver!.observe(card));
  };

  const disableScrollActivation = () => {
    scrollObserver?.disconnect();
    scrollObserver = null;
    // Unlike HowItWorks (where "no card active" is a valid resting state), Programs
    // always has exactly one active card, even before any interaction (O1, per the
    // markup) — reset to it here (matching the mouseleave handler above) rather than
    // clearing entirely, so that invariant still holds once the viewport crosses back
    // to desktop mid-scroll.
    activate(cards[0]);
  };

  const syncScrollActivation = () => {
    if (isMobile()) enableScrollActivation();
    else disableScrollActivation();
  };

  syncScrollActivation();
  window.addEventListener("resize", syncScrollActivation);
</script>

