---
// Figma file u4NLOVKuXUTKULhSn0sAJQ: eyebrow 1:15970 / H2 1:15971 (consumed via
// SectionHeading, verified against these exact nodes in Task 2), sub-line
// 1:15972 (outlined), step-card row 1:16075 (STEP/O-number text nodes
// 1:16081-1:16265), down-chevron 1:16816 (Task 1: byte-identical to
// src/assets/home/scroll-arrow.svg — reused, no new asset). See derivations
// in the style block below.
import SectionHeading from "../SectionHeading.astro";
import ScrollArrow from "../../assets/home/scroll-arrow.svg";
import RevealStar from "../../assets/shared/reveal-star.svg";

// Folder-tab connector (Figma nodes 1:16080 / 1:16088 / 1:16202 / 1:16262) —
// downloaded all four as raw SVG to compare against Home's Pillars.astro
// precedent (two-path, front-color-swapped-per-card notch). These are
// simpler: a SINGLE path, byte-identical across all four cards, always
// `fill="black"` — even on O2's orange card (verified directly on 1:16088's
// own export, not inferred). So there's no per-card color swap needed; one
// shared shape suffices.
const NOTCH = `<svg class="step-notch" viewBox="0 0 42 73" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
  <path d="M41.6 0V72.13L39.17 48.76C38.41 41.44 32.46 35.7499 25.11 35.3199L0 33.3199L25.67 31.1C32.95 30.63 38.84 25.01 39.64 17.76L41.6 0.0100098V0Z" fill="#000" />
</svg>`;

// Pointed arrow connector (the plan's "pointed arrow connectors between
// cards") — baked into the border-outline paths themselves on O1 (1:16078),
// O2 (1:16086) and O3 (1:16200): each card's right border detours outward to
// a symmetric 45° point beside the STEP label (O1's own path, card-local:
// border line x349.51 detours (349.51,63.81) → apex (368.62,82.92) →
// (349.51,102.03) — a 19.11px-deep, 38.22px-tall V; O2/O3 carry the
// byte-identical shape at slightly different y). ABSENT on O4 (1:16261 is a
// plain rectangle): each card points at its successor, the last card has
// none. (An earlier revision of this file dismissed the shape as an
// Illustrator-import artifact and dropped it — wrong: it's precise,
// symmetric, and consistently present-on-O1/O2/O3 / absent-on-O4.)
// Reproduced as an overlay SVG per V-bearing card, split into two paths — the
// same two-path split precedent as Home's Pillars.astro notch. Fill-only
// path: a wedge closed at x=0, the SVG's local coordinate for the border's
// own INNER edge (not x=1, the border's centerline) — filled with the card's
// own background (orange on O2, whose design path fills the tab orange too)
// — so it replaces the full 2px CSS border thickness across the tab mouth,
// not just its outer half (closing at the centerline left a 1px navy seam
// across the mouth on all three cards — fixed by this wider closing edge).
// Stroke-only path: the two diagonals, centered on the border's own
// centerline (x=1), left open (no closing segment) so no stroke is drawn
// along the border line itself — the same open-detour construction as the
// design's own border path, minus the rectangle.
// Exclusive active card: the tab's fill has to match whichever background color the
// card behind it is currently showing, and that's no longer fixed per card — exactly
// one card (O2 by default, or whichever is hovered) is ever orange at a time — so
// `fill` is always `currentColor`, and the CSS below sets `color` on `.step-vtab` to
// track the same cream/orange switch as the card's own `background` (`.step.is-active`).
const VTAB = `<svg class="step-vtab" viewBox="0 0 21.11 40.22" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 1L20.11 20.11L0 39.22Z" fill="currentColor" />
    <path d="M1 1L20.11 20.11L1 39.22" fill="none" stroke="var(--color-ink-alt)" stroke-width="2" />
  </svg>`;
---

<section class="how-it-works">
  <div class="container heading reveal">
    <SectionHeading eyebrow="HOW IT WORKS">
      <span class="reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">From idea, to deployment.</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </SectionHeading>
    <p class="sub reveal-rise reveal-rise--after-1-line">
      Come in through a Grand Challenge, as a Fellow, or as an existing
      venture. Every builder moves through the same four steps.
    </p>
  </div>

  <div class="container">
    <div class="steps-row">
      <article class="step step--o1">
        <div class="step-head">
          <p class="step-label">STEP</p>
          <p class="step-number">O1</p>
          <div class="step-rule" aria-hidden="true"></div>
          <Fragment set:html={NOTCH} />
          <Fragment set:html={VTAB} />
        </div>
        <div class="step-foot">
          <h3 class="step-title">Apply</h3>
          <!-- Hover-to-reveal (this task): Figma's own O1 frame (node 1:16076) has no
               body text node at all — title + numeral + STEP label only, confirmed via
               get_metadata, genuinely absent, not a truncation. Sourced verbatim from
               the reference build at https://mc2plus.vercel.app/pages/Initiatives.html,
               same source already used for the Programs section. Hidden until hover,
               see .step-body CSS below. -->
          <p class="step-body">
            Tell us what you are building. One application, whichever track
            fits, through a Grand Challenge, the Fellows programme or the
            Accelerator.
          </p>
        </div>
      </article>

      <article class="step step--o2">
        <div class="step-head">
          <p class="step-label">STEP</p>
          <p class="step-number">O2</p>
          <div class="step-rule" aria-hidden="true"></div>
          <Fragment set:html={NOTCH} />
          <Fragment set:html={VTAB} />
        </div>
        <div class="step-foot">
          <h3 class="step-title">Find energy-major champions</h3>
          <p class="step-body">
            We match you to the energy majors who own the problem and the
            assets, your sponsors, mentors and first reference customers.
          </p>
        </div>
      </article>

      <article class="step step--o3">
        <div class="step-head">
          <p class="step-label">STEP</p>
          <p class="step-number">O3</p>
          <div class="step-rule" aria-hidden="true"></div>
          <Fragment set:html={NOTCH} />
          <Fragment set:html={VTAB} />
        </div>
        <div class="step-foot">
          <h3 class="step-title">Build, test, iterate</h3>
          <!-- Design-file error, fixed per the standing "fix with documented
               deviation" policy: node 1:16205 (this body's outlined vector
               group) genuinely stops mid-sentence at "with labs," — verified
               via a direct high-res screenshot of the node (not a crop/clip
               artifact: the group's own bbox sits well inside the card's
               border, with slack below it). There is no further vector data
               to extract; the sentence was never finished in the design file
               itself. Originally completed by hand to match this card's own
               "with X, Y and Z" pattern (see O2's body) — corrected now
               (hover-to-reveal task) to the actual full sentence, recovered
               from the reference build at
               https://mc2plus.vercel.app/pages/Initiatives.html (same
               source used for the Programs section and for O1/O4's copy
               here), replacing that hand-written stand-in. -->
          <p class="step-body">
            Prototype and validate on real infrastructure, with labs, pilot
            sites and hands-on mentorship to reach a field-ready product.
          </p>
        </div>
      </article>

      <article class="step step--o4">
        <div class="step-head">
          <p class="step-label">STEP</p>
          <p class="step-number">O4</p>
          <div class="step-rule" aria-hidden="true"></div>
          <Fragment set:html={NOTCH} />
        </div>
        <div class="step-foot">
          <h3 class="step-title">Scale with capital</h3>
          <!-- Hover-to-reveal (this task): Figma's own O4 frame (node 1:16258) has no
               body text node either (same check as O1 above, confirmed via
               get_metadata) — genuinely absent, not truncated. Sourced verbatim from
               https://mc2plus.vercel.app/pages/Initiatives.html. Hidden until hover. -->
          <p class="step-body">
            Turn a successful pilot into procurement, and raise growth-stage
            capital through the affiliated India Energy Fund to scale.
          </p>
        </div>
      </article>
    </div>
  </div>

  <button type="button" class="scroll" aria-label="Scroll to next section">
    <ScrollArrow aria-hidden="true" />
  </button>
</section>

<script>
  // Exclusive active card, all-closed-by-default (per direct feedback, same
  // change already made to Home's Pillars.astro): exactly one `.step` carries
  // `.is-active` at a time, assigned on hover — none by default (see markup,
  // O2 no longer starts with the class) — and leaving the row deactivates
  // everything instead of falling back to O2.
  const row = document.querySelector<HTMLElement>(".steps-row");
  const steps = document.querySelectorAll<HTMLElement>(".steps-row .step");

  const activate = (target: HTMLElement | null) => {
    steps.forEach((step) => step.classList.toggle("is-active", step === target));
  };

  if (row) {
    steps.forEach((step) => {
      step.addEventListener("mouseenter", () => activate(step));
    });
    // Reset unconditionally (no viewport guard) — the Programs.astro fix-round lesson:
    // gating this on a desktop-only check left a card stuck active if the viewport
    // changed mid-hover.
    row.addEventListener("mouseleave", () => {
      activate(null);
    });
  }

  // Scroll-driven activation (mobile/tablet, <1024px): there's no hover on touch
  // devices, so per direct feedback, whichever card is currently centered in the
  // viewport while scrolling activates instead — a standard "scrollspy" technique.
  // Kept as a SEPARATE, continuous observer (unlike the site's one-shot `.reveal`
  // observer in BaseLayout.astro, which unobserves after first trigger) so it keeps
  // reacting as the user keeps scrolling, and independent of the hover mechanism
  // above so the two never fight over `.is-active` on desktop.
  const isMobile = () => window.matchMedia("(max-width: 1023.98px)").matches;
  let scrollObserver: IntersectionObserver | null = null;

  const enableScrollActivation = () => {
    if (scrollObserver) return;
    scrollObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          entry.target.classList.toggle("is-active", entry.isIntersecting);
        }
      },
      { rootMargin: "-45% 0px -45% 0px", threshold: 0 },
    );
    steps.forEach((step) => scrollObserver!.observe(step));
  };

  const disableScrollActivation = () => {
    scrollObserver?.disconnect();
    scrollObserver = null;
    steps.forEach((step) => step.classList.remove("is-active"));
  };

  const syncScrollActivation = () => {
    if (isMobile()) enableScrollActivation();
    else disableScrollActivation();
  };

  syncScrollActivation();
  window.addEventListener("resize", syncScrollActivation);
</script>

<style>
  .how-it-works {
    background: var(--color-cream);
    /* Gap from Hero's own down-chevron (1:16967, bottom y1044.16 = 1023.55 +
       20.61) to this section's eyebrow top (1:15970, y1205.44) is 161.28px.
       Hero.astro already accounts for 4rem (64px) of that as its own
       padding-bottom, so this section's share is 161.28 - 64 = 97.28px
       (6.08rem). Task 6 whole-page fidelity pass confirmed this renders
       correctly (161.27px measured at 1024/1366/1920 alike, after Hero's own
       dead-space fix — see Hero.astro) — no change needed here.
       padding-bottom (6rem) confirmed too: HowItWorks' own chevron
       (1:16816, bottom y2086.17) to Programs' first card top (y2239.64) is
       153.47px design vs 153.4375px rendered at all three gate widths — a
       coincidental match with Pillars/Home's reused 6rem, not independently
       re-derived, but verified correct as-is. */
    padding-top: 6.08rem;
    padding-bottom: 6rem;
  }

  .heading {
    text-align: center;
    /* 43.82px, gap between the sub-line's own bbox bottom (1:15972, y1397.59)
       and the step row's top (1:16075, y1441.41 — set by O2, the tallest/
       elevated card). */
    margin-bottom: 2.7388rem;
  }

  .sub {
    margin: 0.4613rem auto 0; /* 7.38px, SectionHeading's H2 bottom (1249.85+84) to sub-line top (1341.23) */
    max-width: 50.2056rem; /* 803.29px, node 1:15972's own bbox width */
    font-family: var(--font-sans);
    /* Outlined vectors (no text node — node 1:15972 is ~130 glyph paths, same
       situation as Home's CtaBand .body). Total 2-line bbox height is 56.36px;
       20px/1.4 line-height gives a 28px line box × 2 = 56px, a near-exact
       match (0.36px off) — reusing Pillars' .card-body constant (1.25rem/1.4)
       rather than re-deriving from scratch, since it already fits this
       measurement almost exactly. */
    font-size: 1.0625rem; /* 17px — reduced from 20px per user directive 2026-07-06 */
    line-height: 1.4;
    color: var(--color-gray);
    text-align: justify; /* sitewide paragraph-justify pass */
  }

  .steps-row {
    display: flex;
    align-items: stretch; /* per direct feedback: every card must be the exact same height — flexbox's own default cross-axis behavior already does this natively (every item stretches to the row's tallest), replacing the previous flex-end bottom-alignment that let cards keep their own differing natural heights. Fully responsive with no magic numbers: the row's height is simply whichever card needs the most room at the CURRENT viewport, recalculated by the browser at every width. */
    /* 21.87px avg / 1518.98px total row width (1:16075) — percentage so it
       scales with the row, same technique as Pillars' own row gap. Task 6
       fidelity pass (carried item 2): at 1024 the percentage gap (13.56px)
       compresses below the V-tab's own fixed 21.11px protrusion depth,
       overlapping the next card's border by ~5.5px (measured via
       getBoundingClientRect on all three tabs — 1366 is fine, ~1px, within
       antialiasing noise). Floor added so the gap never falls below the
       tab's own depth plus a small clearance; verified at 1024 the overlap
       drops to 0 (tab tip now lands ~2px clear of the next card). */
    gap: max(1.44%, 1.55rem);
    /* Per direct feedback: reverted to always-open cards (the permanent
       `--step-active-height` reservation, and the min-height/hide-show
       machinery it existed to protect, are gone — see .step and .step-body
       below). That whole apparatus was defending against a real
       reflow-thrashing bug from a card's box growing/shrinking on hover; now
       that every card's body is always visible and never toggles, nothing
       about layout ever changes on hover (only background-color and the
       existing lift transform, neither of which affects layout), so there's
       nothing left to protect against. */
  }

  .step {
    position: relative;
    display: flex; /* per direct feedback (equal card heights): lets .step-foot (below) grow to fill whatever extra height `align-items: stretch` (above) now gives this card. */
    flex-direction: column;
    flex: 1 1 0%;
    min-width: 0;
    box-sizing: border-box;
    border: 0.125rem solid var(--color-ink-alt); /* 2px navy, all four cards (e.g. 1:16078/1:16086/1:16200/1:16261) */
    background: var(--color-cream);
    transition:
      transform 250ms ease,
      background-color 200ms ease;
  }
  /* Per direct feedback: all four cards are always open now (STEP header +
     title + body always visible — see .step-body below), reverting the
     collapsed/expand-on-hover interaction from earlier rounds. `.is-active`
     (assigned by the script below on hover, none by default) now only ever
     toggles `background` + the lift `transform` — nothing about height,
     min-height, or visibility. That's safe specifically because nothing
     about LAYOUT changes on hover anymore (translateY is a compositing
     transform, not a layout one): the reflow-thrashing bug those earlier
     rounds fought (a card's box growing/shrinking on hover, shoving the
     down-chevron around) can't recur when a card's box never changes size
     to begin with. Each card simply keeps its own natural height (STEP
     header + title + body), like the original "staircase" heights (O1
     332.52px / O2 542.52px / O3 402.52px / O4 338.02px), with `align-items:
     flex-end` (on .steps-row) bottom-aligning them. */
  .step.is-active {
    background: var(--color-orange); /* #F37D2C, node 1:16086's own fill */
    transform: translateY(-0.75rem); /* 12px lift — matches Programs.astro's transition timing for consistency on this page */
  }

  /* Figma's own box widths differ slightly per card (368.12px for O1/O2/O3's
     header-bearing box vs 349.01px for O4's, plus O1/O3 additionally split
     their header/foot into two literal stacked boxes of those two widths) —
     an Illustrator-import artifact of the original fixed-width layout, not a
     meaningful ratio to preserve once every card is an equal flex:1 1 0%
     column (Pillars.astro's own precedent for this exact situation). Treated
     as noise and flattened; see init-task-3-report.md for the full geometry
     trace. */
  .step-head {
    position: relative;
    text-align: center;
    padding: 2.8rem 1rem 1.6rem;
  }
  .step-label {
    margin: 0;
    font-family: var(--font-sans); /* Figma reports Faculty Glyphic on this real text node (1:16083 etc.), but a zoomed render shows plain sans strokes (no serifs on S/T/E/P) — same wrapping-group-reports-Faculty correction already applied throughout this page/Home */
    font-size: 1.4rem; /* 22.4px — reduced from 28.53px per user directive 2026-07-06 */
    color: var(--color-ink-alt);
  }
  .step-number {
    margin: 0.2rem 0 0;
    font-family: var(--font-display); /* zoomed render confirms genuine serif/slab strokes here, unlike the label above — Faculty Glyphic rendering truthfully */
    font-size: 5.25rem; /* 84px — reduced from 105.26px per user directive 2026-07-06, the single most oversized element on the page */
    line-height: 1.1;
    color: var(--color-ink-alt);
  }
  /* Divider between header and title/body — reproduces the shared border
     edge where Figma's O1/O3 literally stack two separate boxes, and O2/O4
     draw a zero-height divider vector at the identical relative offset
     (243.63px from card top in all four cases) inside one continuous box. */
  .step-rule {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 0.125rem;
    background: var(--color-ink-alt);
  }
  /* :global — injected via set:html (shared markup built in frontmatter, see
     comment above), so Astro's scoped data-attribute never attaches to it.
     Anchored to .step-head's own bottom (top:100%, the same divider edge as
     .step-rule) rather than a fixed distance from the card's top, so it
     tracks the header's real height regardless of small per-viewport font
     reflow — same technique as Pillars.astro's .card-rule. */
  .step :global(.step-notch) {
    position: absolute;
    top: 100%;
    margin-top: -2.0719rem; /* notch starts 33.15px above the divider (consistent across all four cards' own geometry) */
    right: 0;
    width: 2.6rem; /* 41.6px */
    height: 4.5081rem; /* 72.13px */
    pointer-events: none;
  }

  /* Pointed arrow connector (see frontmatter comment for shape provenance).
     Sizing: the design's V is 19.11px deep x 38.22px tall stroke-center to
     stroke-center; the SVG adds 1px padding on each side for its own 2px
     stroke (viewBox 21.11x40.22). Horizontal: the path's x=1 line must sit on
     the card border's centerline (inner edge + 1px of the 2px border), so the
     SVG's left edge lands exactly on .step-head's right content edge —
     right: -21.11px puts it there while the apex (path x=20.11) ends up
     19.11px beyond the border centerline, matching the design's 349.51 →
     368.62 protrusion exactly. Vertical: in the design the V's top edge sits
     +1.5px (O1) / +8.57px (O2) / +3.99px (O3) below each card's own
     STEP-label top (per-card values from the border-path y's vs. text-node
     y's cited in the frontmatter comment) — a +4.7px mean with ±4px
     hand-placement jitter, treated as one shared value: STEP-label top
     (2.8rem head padding = 44.8px) + 4.7px design offset − 2px SVG padding
     (the fill wedge's own top inset plus the stroke's half-width bleed at
     the vertex) = 47.5px — still inside the jitter band above. */
  .step :global(.step-vtab) {
    position: absolute;
    top: 2.9688rem; /* 47.5px, see above */
    right: -1.3194rem; /* -21.11px, see above */
    width: 1.3194rem; /* 21.11px */
    height: 2.5138rem; /* 40.22px */
    pointer-events: none;
    /* fill="currentColor" in the VTAB markup (see frontmatter) — this tracks the exact
       same cream/orange switch as the card's own background above, so the tab's fill
       never mismatches the card behind it, whichever card is currently active. */
    color: var(--color-cream);
    transition: color 200ms ease;
  }
  .step.is-active :global(.step-vtab) {
    color: var(--color-orange);
  }

  .step-foot {
    flex: 1 1 auto; /* per direct feedback (equal card heights): grows to absorb whatever extra height .step's own stretch gives it, so a shorter card's body just gets blank space below it instead of the whole card being shorter. */
    padding: 1.8rem 1.2rem 1.6rem;
    text-align: center;
  }
  .step-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.4rem; /* 22.4px — reduced from 28.53px per user directive 2026-07-06, kept equal to .step-label */
    font-weight: 400;
    color: var(--color-ink-alt); /* navy on every card, including O2's orange one — matches Pillars' .card-title convention */
  }
  .step-body {
    margin: 0.8rem auto 0;
    font-family: var(--font-sans);
    /* Outlined (no text node). O2's body (node 1:16093, "We match you to the
       energy majors...") wraps to an exact 5 lines at its own 298.06px column
       width (node 1:16090's width, reused below as .step--o2's max-width) —
       verified letter-for-letter against a zoomed screenshot of the node.
       Same empirical technique as Home's CtaBand .body (match the design's
       own line-break points at its own max-width, rather than trust bbox
       height ÷ line count, which is unreliable for an ink bbox): rendered
       this exact sentence at that exact width in real Sora across a range of
       sizes, 18-19px are the only ones that reproduce all 4 of the design's
       break points; 20px+ all break one word earlier per line. 19px chosen
       (upper end of the matching range). Reused for O3's body too — same
       role, same card family, no independent text to re-derive against. */
    font-size: 1rem; /* 16px — reduced from 19px per user directive 2026-07-06 */
    line-height: 1.4;
    color: var(--color-gray);
    /* Always visible now (per direct feedback: all four cards are
       permanently open, hover only changes background/text/notch color and
       the existing lift — see .step's own comment above). */
    text-align: justify; /* sitewide paragraph-justify pass — narrow columns (O2/O3), verified acceptable via screenshot */
  }
  .step.is-active .step-body {
    /* On-orange body copy is navy, not gray (matches Pillars' .card--o3 .card-body) —
       applies uniformly since the active card is always the orange one, whichever card
       that is (none by default — see markup/script above). */
    color: var(--color-ink-alt);
  }
  .step--o2 .step-title,
  .step--o2 .step-body {
    max-width: 18.6288rem; /* 298.06px, node 1:16090/1:16093's own wrap column — reproduces the design's "Find energy-major" / "champions" break */
    margin-inline: auto;
  }
  .step--o3 .step-body {
    max-width: 17.5138rem; /* 280.22px, node 1:16203's own wrap column */
    margin-inline: auto;
  }

  .scroll {
    display: block;
    margin: 5.1019rem auto 0; /* 81.63px, step row bottom (1983.93) to chevron top (1:16816, y2065.56) */
  }

  @media (max-width: 1023.98px) {
    .sub {
      max-width: 90%;
    }

    /* Responsive rule: below 1024, drop the bottom-aligned offset collage for
       a normal 2x2 grid (same pattern as Home's Pillars.astro). `align-items`
       left at its grid default (stretch, per direct feedback on equal card
       heights) rather than the earlier `start` override, so each row of this
       2x2 (O1+O2, then O3+O4) still matches heights within itself. */
    .steps-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
    .step {
      flex: initial;
    }
    /* The pointed arrow connectors express left-to-right succession in the
       desktop 4-across row; in the stacked 2x2/1-col grid that reading no
       longer holds (O2's V would point off the row's right edge into the
       container gutter — 21.11px of protrusion vs. a gutter that clamps down
       to 20px, risking horizontal overflow at narrow widths). Hidden below
       1024 along with the rest of the collage treatment (offsets already
       flattened above), same sanctioned-adaptation reasoning as Hero.astro's
       sparks. */
    .step :global(.step-vtab) {
      display: none;
    }
  }

  @media (max-width: 639.98px) {
    .steps-row {
      grid-template-columns: 1fr;
    }
  }
</style>
