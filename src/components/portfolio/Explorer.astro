---
// Figma file u4NLOVKuXUTKULhSn0sAJQ, node 1:23922. Filter chips + venture list.
// Task 3 built the static markup (all 50 rows, everything visible in the
// default All/All state). Task 4 adds:
//   - Filtering script (single-select per dimension, AND-combined, static chip
//     counts, hidden-attribute show/hide, aria-live results count, empty state).
//   - Hover band (node 1:23932, rounded-rect x96.4 y1731.24 w1675.8 h442.8,
//     image fill): rather than duplicating every text node into a second
//     "white version", the SAME tag/name/sector/desc/link elements are
//     recolored white via `.row:hover`/`:focus-within` descendant selectors
//     and a dark layer (`.row-hover`) fades in behind them — matches the
//     design's own look (identical copy, just restyled) without doubling the
//     DOM. Xyma Analytics alone gets the real photo (hover-photo-xyma.png,
//     Task 1 export) via a CSS custom property set inline on that one row;
//     every other row gets the identical dark gradient band WITHOUT a photo
//     (documented adaptation — the `url` field convention from Task 1 doesn't
//     extend to photos, so there's no per-venture photo to fall back to; the
//     markup/CSS is ready to add one later via the same custom-property hook).
//
// Filter chips (get_metadata on content group 1:23924, y1185-1420; get_design_context
// on 1:23936/1:24017 for chip anatomy): "BACKED BY" 1:24015 (y1185.38, real text)
// and "SECTOR" 1:24198 (y1296.06, real text) each head a row of pill chips
// (Group frames, h=38.51px uniform). Chip labels/counts are OUTLINED (no text
// nodes found by name search) — copy verified via get_screenshot: chip order is
// exactly BACKED BY[All 50, HPCL 6, ONGC 8, IndianOil 8, BPCL 9, GAIL 9 (selected,
// orange fill), Oil India 7, Petronet 3] / SECTOR[All 50 (selected, orange),
// Industrial AI 6, Robotics & Inspection 7, Carbon & Emissions 5, Hydrogen & Fuel
// Cells 5, Sensors & IoT 4, Energy Storage 6, E-Mobility 7, Solar & Power 4,
// Bio-energy 4, Water & Waste 2] — matches BACKERS/SECTORS from Task 1's
// ventures.ts exactly, both order and counts. Unselected fill sampled #e8e6da
// (--color-line, reused as a chip bg — not previously used this way, but an
// exact token match); selected fill #f37d2c (--color-orange), white label.
//
// Venture rows (get_metadata y1451-1950 region on row 1 "H2E Power" + row 2
// "Xyma Analytics"; get_design_context on the tag chip 1:24299 and description
// group 1:24206): each row is BACKED-BY-tag (outlined pill, bordered navy,
// "BACKED BY {BACKER}" — per-row, using that venture's OWN backer, verified via
// the captured GAIL state showing "BACKED BY GAIL" on all 9 visible rows) +
// hairline divider (0.87px, sampled fill #f37d2c — the divider itself is orange,
// distinct from the tag's navy border) + spark (node 1:24203, Task 3 export
// spark-row.svg, 60.78px, positioned straddling the divider's right end) above;
// venture name (real text, e.g. 1:24205 "H2E Power") + sector (dot #959595 +
// label, real text) below-left; description (outlined) + "Visit Page" (real
// text, node 1:24318, orange, arrow via a plain glyph like the site's other
// text-links, e.g. Initiatives Hero's notice-link) on the right. Name font-size
// derived by cap-height ratio against the Hero H1 (known 80px/cap-height 62.06px
// measured ratio 0.776): venture name cap-height measures 50.66px →
// 50.66/0.776 = 65.3px, matching the site's own established 65px Faculty H2
// scale (SectionHeading.astro) almost exactly — reused rather than a new value.
// Row width (name-left-edge 221.87 to divider-right-end 1816.4) = 1594.53px,
// narrower than `.container`'s own 1760px max-width — same "built-in row-width/
// container-width mismatch" already accepted in Programs.astro; name/desc
// column split (767.7/826.83 = 48.14%/51.86% of the row) reproduced as flex-
// basis percentages of `.container` directly, accepting that same mismatch.
//
// Hover band (rounded-rect 1:23932, Task 1's hover-photo-xyma.png export):
// markup placeholder only here — Task 4 adds the script + hover CSS.
import { BACKERS, SECTORS, VENTURES } from "../../data/ventures";
import SparkRow from "../../assets/portfolio/spark-row.svg";
---

<section class="explorer" aria-label="Venture explorer">
  <div class="container">
    <div class="filters">
      <div class="filter-group">
        <p class="filter-label">BACKED BY</p>
        <div class="chip-row" role="group" aria-label="Filter by backer">
          {
            BACKERS.map((b) => (
              <button
                type="button"
                class="chip"
                data-filter="backer"
                data-value={b.label}
                aria-pressed={b.label === "All" ? "true" : "false"}
              >
                {b.label} <span class="count">{b.count}</span>
              </button>
            ))
          }
        </div>
      </div>
      <div class="filter-group filter-group--sector">
        <p class="filter-label">SECTOR</p>
        <div class="chip-row" role="group" aria-label="Filter by sector">
          {
            SECTORS.map((s) => (
              <button
                type="button"
                class="chip"
                data-filter="sector"
                data-value={s.label}
                aria-pressed={s.label === "All" ? "true" : "false"}
              >
                {s.label} <span class="count">{s.count}</span>
              </button>
            ))
          }
        </div>
        {/* Mobile-only alternative to the chip row above, CSS-toggled via
           `.filter-group--sector` in the ≤639.98px media query below. SECTOR
           has 11 options (vs BACKED BY's 8) and measured 8 wrapped rows /
           392px tall at a 390px viewport -- alone it pushed every venture
           card below the fold, so only THIS filter (the one with the actual
           space problem) gets collapsed to a dropdown; BACKED BY keeps its
           chip row everywhere, per user directive not to apply the treatment
           where it isn't needed. The chip buttons stay in the DOM so desktop/
           tablet are unaffected; the filter script keeps this <select> and
           the chips in sync in both directions. */}
        <select
          class="sector-select"
          aria-label="Filter by sector"
          data-filter-select="sector"
        >
          {
            SECTORS.map((s) => (
              <option value={s.label}>
                {s.label} ({s.count})
              </option>
            ))
          }
        </select>
      </div>
    </div>

    <p class="results-count" aria-live="polite">Showing all {VENTURES.length} ventures</p>

    <div class="rows">
      {
        VENTURES.map((v) => (
          <article
            class="row"
            data-backer={v.backer}
            data-sector={v.sector}
          >
            <div class="row-divider" aria-hidden="true">
              <span class="row-tag">Backed by {v.backer}</span>
              <SparkRow class="row-spark" />
            </div>
            <div class="row-body">
              <div class="row-main">
                <h3 class="row-name">{v.name}</h3>
                <p class="row-sector">
                  <span class="dot" aria-hidden="true" />
                  {v.sector}
                </p>
              </div>
              <div class="row-side">
                <p class="row-desc">{v.desc}</p>
                {v.url && (
                  <a href={v.url} class="row-link" target="_blank" rel="noopener">
                    Visit Page <span aria-hidden="true">&rarr;</span>
                  </a>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>
    <p class="empty-state" hidden>No ventures in this combination yet.</p>
  </div>
</section>

<style>
  .explorer {
    background: var(--color-cream);
    padding-block: 2rem 6rem;
  }

  .filters {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 1.1rem; /* eyebrow-to-chip-row gap, node 1:24015/1:24016 (1185.38+24=1209.38 to chip-row top 1221.33 ~ tight; using the site's established eyebrow gap scale) */
  }
  .filter-label {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    letter-spacing: 0.2em;
    color: var(--color-ink-alt);
    font-weight: 600;
  }
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem; /* chip-to-chip gap, approximate from row metadata */
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    height: 2.407rem; /* 38.51px, uniform chip height across both filter rows */
    padding-inline: 1.25rem;
    border: none;
    border-radius: 999px;
    background: var(--color-line); /* #e8e6da sampled exactly, node metadata */
    color: var(--color-ink-alt);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
  }
  .chip .count {
    font-weight: 400;
    color: var(--color-gray);
  }
  .chip[aria-pressed="true"] {
    background: var(--color-orange);
    color: var(--color-white);
  }
  .chip[aria-pressed="true"] .count {
    color: var(--color-white);
    opacity: 0.85;
  }

  .results-count {
    margin: 2.5rem 0 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-gray);
  }

  .rows {
    margin-top: 1rem;
  }

  .row {
    position: relative;
    /* Horizontal padding gives the hover band breathing room; the matching
       negative margin bleeds it back so the resting text still aligns to the
       container edge. 1.25rem == the container's min side padding, so the band
       never causes horizontal scroll even on the narrowest viewport. */
    padding: 2.5rem 1.25rem 2rem;
    margin-inline: -1.25rem;
    border-radius: 0; /* sharp edges on the hover band (per user) */
    transition: background-color 250ms ease;
    cursor: pointer; /* touch devices (notably iOS Safari) only reliably fire
      :active on elements that already look "interactive" -- cursor:pointer is
      the standard trick to opt a non-form block into that; harmless on
      desktop since the row isn't a real control either way. */
    -webkit-tap-highlight-color: transparent; /* suppress the OS's default
      translucent gray/blue tap-flash so it doesn't wash out the orange
      highlight below on the first tap. */
  }
  /* Hover / focus highlight: the whole row turns orange with white text + marks.
     :active is included alongside :hover/:focus-within so the SAME highlight
     fires on touch taps too -- mobile has no real hover, and :hover/
     :focus-within don't reliably activate before a tapped `.row-link` (an
     external, target="_blank" anchor) navigates away, which was reported as
     "Visit Page doesn't highlight orange on tap". :active fires immediately
     on touchstart across mobile browsers, giving the identical existing
     orange treatment (same rules/tokens, nothing new invented) as tap
     feedback. */
  .row:hover,
  .row:focus-within,
  .row:active {
    background-color: var(--color-orange);
  }
  .row-name,
  .row-sector,
  .row-desc,
  .row-link,
  .row-tag,
  .row-divider,
  .row-sector .dot {
    transition: color 200ms ease, background-color 200ms ease,
      border-color 200ms ease;
  }
  .row:hover .row-name,
  .row:focus-within .row-name,
  .row:active .row-name,
  .row:hover .row-sector,
  .row:focus-within .row-sector,
  .row:active .row-sector,
  .row:hover .row-desc,
  .row:focus-within .row-desc,
  .row:active .row-desc,
  .row:hover .row-link,
  .row:focus-within .row-link,
  .row:active .row-link {
    color: var(--color-white);
  }
  .row:hover .row-sector .dot,
  .row:focus-within .row-sector .dot,
  .row:active .row-sector .dot {
    background: var(--color-white);
  }
  .row:hover .row-divider,
  .row:focus-within .row-divider,
  .row:active .row-divider {
    background: var(--color-white);
  }
  .row:hover .row-spark,
  .row:focus-within .row-spark,
  .row:active .row-spark {
    filter: brightness(0) invert(1); /* orange spark → white on the orange band */
  }
  .row-divider {
    position: relative;
    z-index: 2; /* stays above .row-hover's own z-index:0 band, which would otherwise paint over this unpositioned-by-default sibling */
    display: flex;
    align-items: center;
    height: 1px;
    background: var(--color-orange); /* 0.87px hairline, sampled #f37d2c */
    margin-bottom: 2.7rem; /* divider-to-name gap, node measurement (~62.89px) */
  }
  .row-tag {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 2.407rem; /* 38.51px, same uniform pill height as filter chips */
    padding-inline: 1.5rem;
    margin-inline-start: 0;
    border: 0.125rem solid var(--color-ink-alt);
    border-radius: 999px;
    background: var(--color-cream);
    color: var(--color-ink-alt);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .row-spark {
    position: absolute;
    right: 4rem; /* approximate inset from the row's own right edge, node 1:24203 */
    top: 50%;
    transform: translateY(-50%);
    width: 3.8rem; /* 60.78px */
    height: 3.8rem;
    pointer-events: none;
  }

  /* Figma card (1:24199): two-column row — title+sector left (≈48%),
     description+Visit Page right (≈52%). Right column starts at ~48.2% of the
     card (desc node 1:24206 at card-x 768/1595). min-height gives the columns
     a band so the sector (left) and Visit Page (right) pin to the same bottom
     baseline (both at card-y ~225 in Figma). */
  .row-body {
    position: relative;
    display: grid;
    grid-template-columns: 48% 52%;
    align-items: stretch;
    min-height: 7rem;
  }
  .row-main {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
  }
  .row-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.625rem; /* 42px — reduced further from 52px (itself already reduced from Figma's 65px) per user directive 2026-07-06, still read as oversized */
    line-height: 1.1;
    font-weight: 400;
    color: var(--color-ink-alt);
  }
  .row-sector {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    font-family: var(--font-display); /* Faculty, node 1:24315 */
    font-size: 0.93rem; /* 14.88px */
    letter-spacing: 0.1em; /* 1.488px / 14.88px */
    color: var(--color-gray);
  }
  .row-sector .dot {
    width: 0.7rem; /* 11.94px, node 1:24316 */
    height: 0.7rem;
    border-radius: 50%;
    background: var(--color-gray); /* #959595 sampled */
    flex-shrink: 0;
  }

  .row-side {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
  }
  .row-desc {
    margin: 0;
    max-width: 42rem; /* 671.88px, node 1:24206's own bounding width */
    font-family: var(--font-sans);
    font-size: 1.0625rem; /* 17px — reduced from 20px per user directive 2026-07-06, matches the body-copy target used on /team and /contact */
    line-height: 1.4;
    color: var(--color-ink-alt);
    text-align: justify; /* sitewide paragraph-justify pass */
  }
  .row-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0;
    align-self: flex-start;
    font-family: var(--font-display); /* Faculty, node 1:24318 */
    font-size: 0.93rem; /* 14.88px */
    letter-spacing: 0.1em; /* 1.488px / 14.88px */
    font-weight: 400;
    color: var(--color-orange); /* real text node 1:24318, orange fill */
    text-decoration: none;
  }
  .row-link:hover {
    text-decoration: underline;
  }

  .empty-state {
    margin: 3rem 0 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-gray);
    text-align: center;
  }

  @media (max-width: 1023.98px) {
    .row-body {
      grid-template-columns: 1fr; /* was 48% 52% at all widths -- the previous flex:1 1 100% on .row-main/.row-side was dead code since .row-body is a grid, not a flex, container */
      row-gap: 1.25rem;
    }
    .row-name {
      font-size: clamp(1.75rem, 7vw, 2.25rem); /* 28-36px -- reduced from clamp(2.4rem, 6vw, 2.625rem) per user directive 2026-07-07, that floor locked to a flat 38.4px on every real phone width and still read as oversized */
      overflow-wrap: break-word; /* guards single long unbroken words (e.g. "Aerostrovilos") from overflowing past the row on narrow phones */
    }
    .row-spark {
      display: none;
    }
    /* .row-main/.row-side both use `justify-content: space-between` with no
       gap, which only spaces children apart when the flex container is
       TALLER than its content -- true on desktop (`.row-body`'s min-height:
       7rem forces that column to stretch), but on mobile `.row-body` becomes
       a single-column grid where each item's own row-track just shrinks to
       its content height, so space-between had zero effect and the name/
       sector-label lines sat directly against each other with no gap
       (reported: "Industrial AI" touching the name above it). An explicit
       gap fixes that regardless of container height, and doubles as a
       general vertical-rhythm pass across the whole card on mobile. */
    .row-main {
      justify-content: flex-start;
      gap: 0.6rem;
    }
    .row-side {
      justify-content: flex-start;
      gap: 1rem;
    }
  }

  @media (max-width: 639.98px) {
    .row-tag {
      font-size: 0.875rem;
      padding-inline: 1rem;
    }
    .row-desc,
    .row-link {
      font-size: 1.0625rem;
    }

    /* Item 1: filter chips are too large on phones -- SECTOR alone wrapped to
       8 rows / 392px tall at 390px viewport width, pushing every venture
       card below the fold. Two-part fix, phone-only (desktop/tablet chip
       sizing is unchanged, it wasn't flagged as a problem there):
       (a) shrink chip/label font-size + padding so each pill is more
           compact and more fit per row;
       (b) additionally collapse SECTOR specifically (not BACKED BY -- see
           `.filter-group--sector` below) behind a native <select>, since
           compaction alone still leaves an 11-option chip list several rows
           tall. */
    .filters {
      gap: 1.1rem;
    }
    .filter-group {
      gap: 0.7rem;
    }
    .filter-label {
      font-size: 0.8125rem; /* 13px, compact mobile eyebrow */
      letter-spacing: 0.15em;
    }
    .chip-row {
      gap: 0.5rem;
    }
    .chip {
      height: 1.9rem; /* ~30.4px, down from 38.51px */
      padding-inline: 0.75rem;
      gap: 0.3rem;
      font-size: 0.8125rem; /* 13px, down from 16px */
    }

    /* SECTOR only: hide the (still-compacted) chip row and show a native
       select instead. BACKED BY has just 8 options and stays as chips at
       every width -- it wasn't the problem the user's screenshot flagged,
       and collapsing it too would remove a fine desktop-style interaction
       where it isn't actually needed. */
    .filter-group--sector .chip-row {
      display: none;
    }
    .filter-group--sector .sector-select {
      display: block;
    }
  }

  /* Select hidden by default (desktop + tablet keep the chip row); only
     unhidden inside the ≤639.98px `.filter-group--sector` rule above. */
  .sector-select {
    display: none;
    width: 100%;
    height: 2.75rem;
    padding-inline: 1rem;
    border: 0.0625rem solid var(--color-line);
    border-radius: 999px; /* same pill language as the chips it replaces */
    background: var(--color-white);
    color: var(--color-ink-alt);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    /* Custom chevron via a plain SVG data-URI (no new asset file needed) so
       the native control still reads as a dropdown once its default OS
       affordance is reset -- reuses --color-ink-alt already in this file. */
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path d='M1 1l5 5 5-5' fill='none' stroke='%231e1e3c' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 1rem center;
  }
  .sector-select:focus-visible {
    outline: 0.125rem solid var(--color-orange);
    outline-offset: 0.125rem;
  }
</style>

<script>
  // Behavior spec (plan, Task 4): single-select per dimension, All default,
  // AND-combined across dimensions, static chip counts (never recomputed),
  // hidden-attribute show/hide (no re-render), aria-live results count,
  // empty state when a combination matches nothing, fully keyboard-operable
  // via native <button> + aria-pressed (no extra keydown handling needed).
  const explorer = document.querySelector(".explorer")!;
  const chips = Array.from(explorer.querySelectorAll<HTMLButtonElement>(".chip"));
  const rows = Array.from(explorer.querySelectorAll<HTMLElement>(".row"));
  const resultsCount = explorer.querySelector(".results-count")!;
  const emptyState = explorer.querySelector<HTMLElement>(".empty-state")!;
  // Mobile-only SECTOR dropdown (Item 1b) -- same underlying filter state as
  // the chips, kept in sync bidirectionally so switching between viewport
  // widths (or briefly seeing both, e.g. during a resize) never desyncs.
  const sectorSelect = explorer.querySelector<HTMLSelectElement>(".sector-select");

  const selected: Record<"backer" | "sector", string> = {
    backer: "All",
    sector: "All",
  };

  function applyFilters() {
    let visible = 0;
    for (const row of rows) {
      const matches =
        (selected.backer === "All" || row.dataset.backer === selected.backer) &&
        (selected.sector === "All" || row.dataset.sector === selected.sector);
      row.hidden = !matches;
      if (matches) visible++;
    }
    resultsCount.textContent =
      visible === rows.length
        ? `Showing all ${rows.length} ventures`
        : `Showing ${visible} of ${rows.length} ventures`;
    emptyState.hidden = visible !== 0;
  }

  for (const chip of chips) {
    chip.addEventListener("click", () => {
      const filter = chip.dataset.filter as "backer" | "sector";
      const value = chip.dataset.value!;
      selected[filter] = value;
      for (const sibling of chips) {
        if (sibling.dataset.filter === filter) {
          sibling.setAttribute("aria-pressed", String(sibling === chip));
        }
      }
      if (filter === "sector" && sectorSelect) {
        sectorSelect.value = value;
      }
      applyFilters();
    });
  }

  sectorSelect?.addEventListener("change", () => {
    const value = sectorSelect.value;
    selected.sector = value;
    for (const sibling of chips) {
      if (sibling.dataset.filter === "sector") {
        sibling.setAttribute("aria-pressed", String(sibling.dataset.value === value));
      }
    }
    applyFilters();
  });
</script>
