---
// Figma 1:28677 network section: H2 1:28682 (Faculty 65px), hub-and-spoke
// diagram 1:28755 (exported to /public/network-map.svg — text baked as vectors
// for a pixel-exact match), expansion banner 1:28683/1:28684. All spacing/sizes
// derived from get_metadata; banner fill pixel-sampled (#e77628, a source orange
// rendered through mix-blend-multiply over the cream page).
import RevealStar from "../../assets/shared/reveal-star.svg";

const LOCATIONS = [
  {
    kind: "HUB",
    name: "MC²+ Hub",
    city: "ONGC · NEW DELHI",
    address: "Deendayal Urja Bhawan, 5 Nelson Mandela Marg, Vasant Kunj, New Delhi 110070.",
  },
  {
    kind: "SPOKE",
    name: "HPCL Green R&D Centre",
    city: "BENGALURU",
    address: "KIADB Industrial Area, Tarabanahalli, Hosakote, Bengaluru, Karnataka 560067.",
  },
  {
    kind: "SPOKE",
    name: "IndianOil R&D Centre",
    city: "FARIDABAD",
    address: "Sector 13, Faridabad, Haryana 121007.",
  },
  {
    kind: "SPOKE",
    name: "IIT Guwahati node",
    city: "GUWAHATI",
    address: "Technology Incubation Centre, IIT Guwahati, Amingaon, Guwahati, Assam 781039.",
  },
];
---

<section class="network">
  <div class="container reveal">
    <h2>
      <span class="reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">The MC&sup2;+ network</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </h2>

    <img
      class="map"
      src="/network-map.svg"
      alt="MC²+ hub-and-spoke network: the ONGC New Delhi hub connects to spokes at HPCL Green R&D Centre (Bengaluru), IndianOil R&D Centre (Faridabad), and the IIT Guwahati node (Guwahati)."
      width="1284"
      height="533"
    />

    <ul class="locations">
      {
        LOCATIONS.map((l) => (
          <li class:list={["loc", l.kind === "HUB" && "hub"]}>
            <span class="tag">{l.kind}</span>
            <h3>{l.name}</h3>
            <p class="city">{l.city}</p>
            <p class="addr">{l.address}</p>
          </li>
        ))
      }
    </ul>

    <p class="banner">
      Spokes are expanding across GAIL, BPCL, Petronet and Oil India sites
      nationwide.
    </p>
  </div>
</section>

<style>
  .network {
    background: var(--color-cream);
    /* Single-ownership vertical rhythm (like About/Team): this section owns its
       top gap only. Figma: network H2 y1169 − hero content-bottom (chevron) y984
       ≈ 185px = 11.56rem. Bottom owned by the following form section.
       Reduced by 8.3rem here because ContactHero's own min-height grew by
       that same amount (38.7rem -> 47rem) to stop clipping the hero's
       left-side spark — moving the space from this section's padding to the
       hero's own box keeps the total chevron->H2 gap unchanged. */
    padding-block: 3.26rem 0;
    text-align: center;
  }
  h2 {
    font-family: var(--font-display);
    font-size: 3.25rem; /* 52px — reduced from the Figma 65px per user directive 2026-07-06 (desktop type felt oversized on sub-1920 laptops) */
    color: var(--color-ink-alt);
    margin: 0 0 5.06rem; /* H2 bottom 1253 → map top 1334 ≈ 81px */
  }
  .map {
    display: block;
    width: 100%;
    max-width: 80.21rem; /* 1283.3px, diagram 1:28755 */
    height: auto;
    margin-inline: auto;
  }

  /* Mobile fallback (the 1283px diagram's baked text is unreadable when shrunk). */
  .locations {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.5rem;
    text-align: left;
  }
  .loc {
    border: 1px solid var(--color-line);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-white);
  }
  .tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    color: var(--color-gray);
  }
  .loc h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: #1e1e3e;
    margin: 0.35rem 0 0.15rem;
  }
  .loc.hub h3 {
    color: var(--color-orange);
  }
  .loc .city {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: var(--color-gray);
    margin: 0 0 0.5rem;
  }
  .loc .addr {
    font-family: var(--font-sans);
    color: #1e1e3e;
    line-height: 1.5;
    margin: 0;
  }

  .banner {
    margin: 4.69rem auto 0; /* map bottom 1867 → banner top 1942 ≈ 75px */
    max-width: 43.44rem; /* 695.2px, node 1:28683 */
    background: #e77628; /* pixel-sampled render (source orange × mix-blend-multiply) */
    color: var(--color-cream);
    font-family: var(--font-sans);
    font-size: 1.1rem;
    line-height: 1.45;
    padding: 1.25rem 2.5rem; /* 20px / 40px -- reduced from 1.63rem/5.06rem (26px/81px, banner box vs text box 1:28683/1:28685) per user directive 2026-07-07, the Figma padding read as oversized against the pill's own max-width */
    border-radius: 999px; /* pill; banner h106 → radius 53px */
    text-align: center; /* reverted from justify -- uneven word-spacing, per direct user feedback 2026-07-10 */
  }

  @media (max-width: 767.98px) {
    .map {
      display: none;
    }
    .locations {
      display: grid;
    }
    h2 {
      font-size: clamp(2.2rem, 8vw, 3.25rem);
      margin-bottom: 2.5rem;
    }
    .banner {
      border-radius: 1.25rem;
      padding: 1.25rem 1.75rem;
    }
  }
</style>
