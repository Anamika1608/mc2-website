---
// Figma 1:29036 form card + 1:29237/1:29318 enquiry column. All sizes/spacing
// from get_metadata; fonts/fills from get_design_context + pixel-sampling.
// Card 913.3px / info 478.1px, gap 122px. Labels are Faculty 18.53px @0.25em
// (1:29110/29111), NOT Sora. Static form UI (no submission backend wired).
const ROLES = ["FOUNDER", "RESEARCHER", "INSTITUTION", "CORPORATE / INVESTOR", "PRESS"];

const CONTACTS = [
  { label: "GENERAL ENQUIRIES", email: "hello@mcplus.in" },
  { label: "ENERGY MAJOR PARTNERSHIPS", email: "partnerships@mcplus.in" },
  { label: "INVESTOR / LP ENQUIRIES", email: "invest@mcplus.in" },
  { label: "PRESS & MEDIA", email: "press@mcplus.in" },
];
---

<section class="contact-section">
  <div class="container grid">
    <!-- Form card -->
    <form class="card" action="#" novalidate>
      <h2>Send us a message</h2>

      <fieldset class="chips">
        <legend>I AM A</legend>
        {
          ROLES.map((role, i) => (
            <label class="chip">
              <input type="radio" name="role" value={role} checked={i === 0} />
              <span>{role}</span>
            </label>
          ))
        }
      </fieldset>

      <div class="row">
        <div class="field">
          <label for="full-name">FULL NAME</label>
          <input id="full-name" name="full-name" type="text" placeholder="Your name" />
        </div>
        <div class="field">
          <label for="email">EMAIL</label>
          <input id="email" name="email" type="email" placeholder="you@company.com" />
        </div>
      </div>

      <div class="field">
        <label for="org">ORGANISATION</label>
        <input id="org" name="organisation" type="text" placeholder="Company, lab or institution" />
      </div>

      <div class="field">
        <label for="help">HOW CAN WE HELP?</label>
        <textarea id="help" name="message" placeholder="Tell us what you&rsquo;re building or exploring…"></textarea>
      </div>

      <button type="submit" class="submit">
        <span class="submit-label">Send Message</span>
        <span class="arrow" aria-hidden="true">
          <svg viewBox="0 0 20 20" width="20" height="20" fill="none">
            <path d="M3 10h12M10 4.5 15.5 10 10 15.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </span>
      </button>
    </form>

    <!-- Enquiry column -->
    <div class="info">
      {
        CONTACTS.map((c) => (
          <div class="info-block">
            <p class="info-label">{c.label}</p>
            <a class="info-email" href={`mailto:${c.email}`}>{c.email}</a>
          </div>
        ))
      }
      <div class="info-block">
        <p class="info-label">REGISTERED OFFICE</p>
        <p class="info-office">
          MC²+ Foundation<br />
          c/o Ministry of Petroleum &amp; Natural Gas<br />
          Shastri Bhawan, New Delhi, 110001
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-cream);
    /* Last section before footer: owns both gaps. Figma: top = card y2178.6 −
       banner bottom 2048 ≈ 131px = 8.16rem; bottom = footer y3233 − card bottom
       3121 ≈ 112px = 7rem. */
    padding-block: 8.16rem 7rem;
  }
  .grid {
    display: grid;
    /* card 913.3px = 57.06rem, info 478.1px = 29.88rem, gap 122px = 7.625rem */
    grid-template-columns: minmax(0, 57.06rem) minmax(0, 29.88rem);
    gap: 7.625rem;
    justify-content: center;
    align-items: start;
  }

  /* Form card — folded top-right corner. */
  .card {
    background: var(--color-white);
    border: 1px solid var(--color-line);
    padding: 2.25rem 2.5rem 3.75rem; /* 36 / 40 / 60px, from H2/content/submit insets */
    clip-path: polygon(0 0, calc(100% - 1.25rem) 0, 100% 1.25rem, 100% 100%, 0 100%);
  }
  h2 {
    font-family: var(--font-display);
    font-size: 3.125rem; /* 50px, node 1:29037 */
    color: var(--color-ink-alt);
    margin: 0 0 4.24rem; /* H2 bottom 2279 → "I AM A" y2346.8 ≈ 68px */
  }

  /* All form labels: Faculty 18.53px, 0.25em tracking, navy (nodes 1:29110/29111). */
  .chips {
    border: 0;
    margin: 0 0 2.69rem; /* chips row bottom 2473.7 → FULL NAME y2516.7 ≈ 43px */
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.84rem 1.49rem; /* row 13.4px / col 23.9px */
  }
  .chips legend,
  .field label {
    font-family: var(--font-display);
    font-size: 1.158rem; /* 18.53px */
    letter-spacing: 0.25em; /* 4.6325 / 18.53 */
    color: #1e1e3e;
    padding: 0;
  }
  .chips legend {
    margin-bottom: 0.75rem;
    width: 100%;
  }
  .chip input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .chip span {
    display: inline-flex;
    align-items: center;
    height: 2.43rem; /* 38.9px */
    padding: 0 1.6rem;
    border-radius: 999px;
    background: var(--color-cream);
    color: var(--color-ink-alt);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease;
  }
  .chip input:checked + span {
    background: var(--color-orange); /* #f37d2c, sampled */
    color: var(--color-white);
  }
  .chip input:focus-visible + span {
    outline: 2px solid var(--color-ink);
    outline-offset: 2px;
  }

  .row {
    display: grid;
    grid-template-columns: 476fr 334fr; /* FULL NAME 476.3px / EMAIL 334.3px */
    gap: 2.04rem; /* 32.6px */
  }
  .field {
    margin-bottom: 2.2rem;
    display: flex;
    flex-direction: column;
  }
  .field label {
    margin-bottom: 0.63rem; /* ~10px */
  }
  .field input,
  .field textarea {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink);
    background: #e7e5d8; /* pixel-sampled input fill */
    border: 1px solid var(--color-line);
    border-radius: 0.6rem;
    padding: 0 1rem;
    height: 2.61rem; /* 41.8px */
    width: 100%;
  }
  .field textarea {
    height: 9.27rem; /* 148.3px */
    padding: 0.75rem 1rem;
    resize: vertical;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--color-gray);
  }
  .field input:focus,
  .field textarea:focus {
    outline: 2px solid var(--color-orange);
    outline-offset: 1px;
  }

  .submit {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    margin: 3.44rem auto 0; /* textarea bottom 2929 → submit y2984.5 ≈ 55px */
    width: 22.3rem; /* 356.9px */
    height: 4.75rem; /* 76px */
    padding-left: 2.25rem;
    background: var(--color-ink);
    color: var(--color-white);
    font-family: var(--font-sans);
    font-size: 1.4rem;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
  }
  .submit .arrow {
    display: grid;
    place-content: center;
    width: 4.75rem; /* full button height, orange circle 1:29218 (76px) */
    height: 4.75rem;
    border-radius: 999px;
    background: var(--color-orange-bright); /* #ff7400, sampled */
    color: var(--color-white);
    flex: none;
    transition: transform 150ms ease;
  }
  .submit:hover .arrow {
    transform: translateX(2px);
  }

  /* Enquiry column — offset down at desktop so it aligns with the form fields
     (info top y2498 vs card top y2178.6 ≈ 319px = 19.94rem). */
  .info {
    margin-top: 19.94rem;
    display: grid;
    gap: 3rem; /* ~48px between the blocks */
  }
  .info-label {
    font-family: var(--font-display);
    font-size: 1.158rem; /* 18.53px, Faculty, node 1:29239 */
    letter-spacing: 0.1em; /* 1.853 / 18.53 */
    color: var(--color-gray);
    margin: 0 0 0.5rem;
  }
  .info-email {
    font-family: var(--font-sans);
    font-size: 1.6rem; /* ~25px, sampled */
    color: var(--color-orange); /* #f37d2c */
    text-decoration: none;
  }
  .info-email:hover {
    text-decoration: underline;
  }
  .info-office {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--color-ink-alt);
    margin: 0;
  }

  @media (max-width: 1023.98px) {
    .grid {
      grid-template-columns: minmax(0, 57.06rem);
      gap: 3rem;
    }
    .info {
      margin-top: 0;
    }
  }
  @media (max-width: 559.98px) {
    .card {
      padding: 1.75rem 1.5rem 2.5rem;
    }
    .row {
      grid-template-columns: 1fr;
      gap: 0;
    }
    h2 {
      font-size: clamp(2.2rem, 9vw, 3.125rem);
      margin-bottom: 2.5rem;
    }
    .submit {
      width: 100%;
    }
  }
</style>
