---
// Figma 1:29036 form card + 1:29237/1:29318 enquiry column. All sizes/spacing
// from get_metadata; fonts/fills from get_design_context + pixel-sampling.
// Card 913.3px / info 478.1px, gap 122px. Labels are Faculty 18.53px @0.25em
// (1:29110/29111), NOT Sora. Static form UI (no submission backend wired).
// Submit button (1:29215): pill body #1E1E3E, arrow circle #FF7400, navy arrow
// glyph, ~32px label — node-for-node the same pill as PillButton.astro, reused
// here via its type="submit" (button) mode rather than reimplemented.
import PillButton from "../PillButton.astro";

const ROLES = ["FOUNDER", "RESEARCHER", "INSTITUTION", "CORPORATE / INVESTOR", "PRESS"];

const CONTACTS = [
  { label: "GENERAL ENQUIRIES", email: "hello@mcplus.in" },
  { label: "ENERGY MAJOR PARTNERSHIPS", email: "partnerships@mcplus.in" },
  { label: "INVESTOR / LP ENQUIRIES", email: "invest@mcplus.in" },
  { label: "PRESS & MEDIA", email: "press@mcplus.in" },
];
---

<section class="contact-section">
  <div class="container grid">
    <!-- Form card -->
    <form class="card" action="#" novalidate>
      <div class="card-header">
        <h2>Send us a message</h2>
      </div>
      <svg class="fold" viewBox="0 0 49.51 78.62" fill="none" aria-hidden="true">
        <path
          d="M49.51 0.01V78.62L47.72 59.82C46.73 49.39 38.32 41.21 27.86 40.51L0 38.65L28.1 36.48C38.4 35.69 46.66 27.63 47.72 17.35L49.5 0L49.51 0.01Z"
          fill="var(--color-gray)"></path>
      </svg>

      <div class="card-body">
        <fieldset class="chips">
          <legend>I AM A</legend>
          {
            ROLES.map((role, i) => (
              <label class="chip">
                <input type="radio" name="role" value={role} checked={i === 0} />
                <span>{role}</span>
              </label>
            ))
          }
        </fieldset>

        <div class="row">
          <div class="field">
            <label for="full-name">FULL NAME</label>
            <input id="full-name" name="full-name" type="text" placeholder="Your name" />
          </div>
          <div class="field">
            <label for="email">EMAIL</label>
            <input id="email" name="email" type="email" placeholder="you@company.com" />
          </div>
        </div>

        <div class="field">
          <label for="org">ORGANISATION</label>
          <input id="org" name="organisation" type="text" placeholder="Company, lab or institution" />
        </div>

        <div class="field">
          <label for="help">HOW CAN WE HELP?</label>
          <textarea id="help" name="message" placeholder="Tell us what you&rsquo;re building or exploring…"></textarea>
        </div>

        <div class="submit-row">
          <PillButton label="Send Message" type="submit" variant="filled" />
        </div>
      </div>
    </form>

    <!-- Enquiry column -->
    <div class="info">
      {
        CONTACTS.map((c) => (
          <div class="info-block">
            <p class="info-label">{c.label}</p>
            <a class="info-email" href={`mailto:${c.email}`}>{c.email}</a>
          </div>
        ))
      }
      <div class="info-block">
        <p class="info-label">REGISTERED OFFICE</p>
        <p class="info-office">
          MC²+ Foundation<br />
          c/o Ministry of Petroleum &amp; Natural Gas<br />
          Shastri Bhawan, New Delhi, 110001
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-cream);
    /* Last section before footer: owns both gaps. Figma: top = card y2178.6 −
       banner bottom 2048 ≈ 131px = 8.16rem; bottom = footer y3233 − card bottom
       3121 ≈ 112px = 7rem. */
    padding-block: 8.16rem 7rem;
  }
  .grid {
    display: grid;
    /* card 913.3px = 57.06rem, info 478.1px = 29.88rem, gap 122px = 7.625rem */
    grid-template-columns: minmax(0, 57.06rem) minmax(0, 29.88rem);
    gap: 7.625rem;
    justify-content: center;
    align-items: start;
  }

  /* Form card (1:29038): plain rectangle, no fill — the cream page shows
     through — with a gray hairline border. There is no clipped corner; that
     look comes entirely from the .fold flourish below, which sits on the
     header/body divider (1:29040) at the card's top-right corner. */
  .card {
    position: relative;
    background: none;
    border: 1px solid var(--color-gray);
  }
  .card-header {
    padding: 2.23rem 2.5rem 1.85rem; /* H2 top inset 35.75px; H2-bottom→divider gap 29.6px */
    border-bottom: 1px solid var(--color-gray); /* the divider, node 1:29040 */
  }
  h2 {
    font-family: var(--font-display);
    font-size: 2.5rem; /* 40px — reduced from the Figma 50px per user directive 2026-07-06 (desktop type felt oversized on sub-1920 laptops) */
    color: var(--color-ink-alt);
    margin: 0;
  }
  /* Fold flourish (1:29041): flush to the card's right edge, vertically
     centered on the header/body divider line. */
  .fold {
    position: absolute;
    top: 5.73rem; /* 91.65px, card top → flourish top */
    right: 0;
    width: 3.09rem; /* 49.51px */
    height: 4.91rem; /* 78.62px */
  }
  .card-body {
    padding: 2.36rem 2.5rem 3.75rem; /* divider → "I AM A" gap 37.8px; sides/bottom unchanged */
  }

  /* All form labels: Faculty 18.53px, 0.25em tracking, navy (nodes 1:29110/29111). */
  .chips {
    border: 0;
    margin: 0 0 2.69rem; /* chips row bottom 2473.7 → FULL NAME y2516.7 ≈ 43px */
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.84rem 1.49rem; /* row 13.4px / col 23.9px */
  }
  .chips legend,
  .field label {
    font-family: var(--font-display);
    font-size: 0.9375rem; /* 15px — reduced from 18.53px per user directive 2026-07-06 */
    letter-spacing: 0.25em; /* 4.6325 / 18.53 */
    color: #1e1e3e;
    padding: 0;
  }
  .chips legend {
    margin-bottom: 0.75rem;
    width: 100%;
  }
  .chip input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .chip span {
    display: inline-flex;
    align-items: center;
    height: 2.43rem; /* 38.9px */
    padding: 0 1.6rem;
    border-radius: 999px;
    /* Figma fill is --color-cream with mix-blend-multiply over the cream page
       (node 1:29082) — self-multiplied that's ~#e7e6d9, matching the input
       fill literal below almost exactly, so reused here for consistency. Flat
       color now that the card itself has no background for it to blend against. */
    background: #e7e5d8;
    color: var(--color-ink-alt);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease;
  }
  .chip input:checked + span {
    background: var(--color-orange); /* #f37d2c, sampled */
    color: var(--color-white);
  }
  .chip input:focus-visible + span {
    outline: 2px solid var(--color-ink);
    outline-offset: 2px;
  }

  .row {
    display: grid;
    grid-template-columns: 476fr 334fr; /* FULL NAME 476.3px / EMAIL 334.3px */
    gap: 2.04rem; /* 32.6px */
  }
  .field {
    margin-bottom: 2.2rem;
    display: flex;
    flex-direction: column;
  }
  .field label {
    margin-bottom: 0.63rem; /* ~10px */
  }
  .field input,
  .field textarea {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink);
    background: #e7e5d8; /* fill #E7E5D8, node 1:29114 raw SVG */
    border: 1px solid var(--color-gray); /* #949494 stroke, same raw SVG — was wrongly --color-line (#e8e6da), nearly invisible against the fill */
    border-radius: 999px; /* pill — radius = height/2 exactly (21.38px of 42.76px tall), not a subtle rounded-rect */
    padding: 0 1rem;
    height: 2.61rem; /* 41.8px */
    width: 100%;
  }
  .field textarea {
    height: 9.27rem; /* 148.3px */
    padding: 0.75rem 1rem;
    border-radius: 1.1rem; /* 17.66px fixed radius, node 1:29153 raw SVG — not a pill at this height */
    resize: vertical;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--color-gray);
  }
  .field input:focus,
  .field textarea:focus {
    outline: 2px solid var(--color-orange);
    outline-offset: 1px;
  }

  .submit-row {
    margin-top: 3.44rem; /* textarea bottom 2929 → submit y2984.5 ≈ 55px */
    display: flex;
    justify-content: center;
  }

  /* Enquiry column — offset down at desktop so it aligns with the form fields
     (info top y2498 vs card top y2178.6 ≈ 319px = 19.94rem). */
  .info {
    margin-top: 19.94rem;
    display: grid;
    gap: 3rem; /* ~48px between the blocks */
  }
  .info-label {
    font-family: var(--font-display);
    font-size: 0.9375rem; /* 15px — reduced from 18.53px per user directive 2026-07-06 */
    letter-spacing: 0.1em; /* 1.853 / 18.53 */
    color: var(--color-gray);
    margin: 0 0 0.5rem;
  }
  .info-email {
    font-family: var(--font-sans);
    font-size: 1.25rem; /* 20px — reduced from ~25px per user directive 2026-07-06 */
    color: var(--color-orange); /* #f37d2c */
    text-decoration: none;
  }
  .info-email:hover {
    text-decoration: underline;
  }
  .info-office {
    font-family: var(--font-sans);
    font-size: 1.0625rem; /* 17px — reduced from 20px per user directive 2026-07-06 */
    line-height: 1.5;
    color: var(--color-ink-alt);
    margin: 0;
  }

  @media (max-width: 1023.98px) {
    .grid {
      grid-template-columns: minmax(0, 57.06rem);
      gap: 3rem;
    }
    .info {
      margin-top: 0;
    }
  }
  @media (max-width: 559.98px) {
    .card-header {
      padding: 1.75rem 1.5rem 1.5rem;
    }
    .card-body {
      padding: 1.75rem 1.5rem 2.5rem;
    }
    .row {
      grid-template-columns: 1fr;
      gap: 0;
    }
    h2 {
      font-size: clamp(2.2rem, 9vw, 2.5rem);
    }
  }
</style>
