---
// Figma u4NLOVKuXUTKULhSn0sAJQ (frame 1:28676): eyebrow 1:29712, H1 lines
// 1:29716/1:29717/1:29718, lede 1:29719, curves+spark group 1:29819.
// Same hero pattern as TeamHero/AboutHero; style values shared with TeamHero.
import HeroCurves from "../../assets/contact/hero-curves.svg";
import ScrollArrow from "../../assets/contact/scroll-arrow.svg";
---

<section class="hero">
  <div class="orbit" aria-hidden="true">
    <HeroCurves class="curves" />
  </div>

  <div class="hero-inner">
    <p class="eyebrow">CONTACT</p>
    <div class="underline" aria-hidden="true"></div>

    <h1>
      <span class="line">A unique hub-and-spoke</span>
      <span class="line">model to <span class="accent">support you</span></span>
      <span class="line"><span class="accent">where you are</span>.</span>
    </h1>

    <p class="lede">
      Founder, researcher, institution or investor, tell us who you are and
      we&rsquo;ll route you to the right initiative of MC&sup2;+.
    </p>

    <ScrollArrow class="scroll" aria-hidden="true" />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--color-cream);
    padding-block: 6rem 0;
  }
  @media (min-width: 1024px) {
    .hero {
      /* hero-curves.svg's own exported height (1012px = 63.25rem) approximates
         the hero band, mirroring TeamHero. */
      min-height: 63.25rem;
    }
    /* Each h1 span is one authored Figma line (916/798/552px) — the browser's
       Faculty Glyphic metrics render a hair wider than Figma's own, so at the
       container's exact 57.25rem width "A unique hub-and-spoke" wraps to two
       lines without this; nowrap keeps the authored 3-line break exact. */
    h1 .line {
      white-space: nowrap;
    }
  }

  /* Curves + spark: 1:29819 exports as one 1920x1012 SVG that bakes in its
     orange four-point spark alongside the orbit curves (same as TeamHero) —
     no separate spark overlay needed. Background rects stripped for transparency. */
  .orbit {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .curves {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 57.25rem; /* widest H1 line "A unique hub-and-spoke" = 916px (1:29716); re-verified against fresh get_design_context, was wrongly 60rem */
    margin-inline: auto;
    padding-inline: 1.25rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-hero-eyebrow); /* 27.07px, node 1:29712 — normalized to home hero scale per user directive 2026-07-06 */
    letter-spacing: 0.25em; /* 6.7675px / 27.07px, node 1:29712 */
    color: var(--color-gray); /* #949494 per get_design_context 1:29712 ≈ --color-gray */
  }
  .underline {
    width: 11.77rem;
    height: 1px;
    margin: 2.82rem auto 1.72rem;
    background: #000; /* one-off literal, matches the hero underline hairline */
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-hero-h1); /* 80px, nodes 1:29716/1:29717/1:29718 — normalized to home hero scale per user directive 2026-07-06 */
    line-height: var(--text-hero-h1-lh); /* baseline delta 87.5px / 80px — normalized to home hero scale per user directive 2026-07-06 */
    color: #1e1e3e; /* documented literal per Figma (Figma wins), matches H1 fill */
  }
  h1 .line {
    display: block;
  }
  h1 .accent {
    color: var(--color-orange-bright); /* #ff7400, nodes 1:29717/1:29718 */
  }

  .lede {
    max-width: 50.31rem; /* 804.9px, lede group 1:29719 width (was wrongly 47.58) */
    margin: 1.54rem auto 0; /* 24.7px, H1 line-3 bottom 698.1 → lede top 722.8 */
    font-family: var(--font-sans);
    font-size: var(--text-hero-lede); /* 31px, derived from the outlined lede (cap-height 22.6/0.73) — normalized to home hero scale per user directive 2026-07-06 */
    line-height: var(--text-hero-lede-lh); /* baseline delta 40.4px / 31px — normalized to home hero scale per user directive 2026-07-06 */
    color: #1e1e3e; /* literal, matches the lede's baked SVG fill */
  }

  .scroll {
    display: block;
    margin: 8.54rem auto 0; /* 136.7px, lede bottom 826.9 → scroll chevron 963.6 (node 1:29713) */
  }

  @media (max-width: 1023.98px) {
    h1 {
      font-size: var(--text-hero-h1-fluid); /* was clamp(2.4rem, 7vw, 5rem) — normalized to home hero scale per user directive 2026-07-06 */
    }
    .lede {
      max-width: 90%;
    }
  }
</style>
