---
import PillButton from "../PillButton.astro";
---

<section class="cta-band">
  <div class="container heading">
    <h2>
      <span class="line">Building in energy?</span>
      <span class="line">Translate it with MC²+</span>
    </h2>
    <p class="body">
      The first MC²+ cohort launches in August 2026, with applications
      opening soon. Bring a defensible technology and a real problem worth
      an industrial pilot.
    </p>
    <div class="cta">
      <PillButton label="Get in touch" href="/contact" />
    </div>
  </div>
</section>

<style>
  .cta-band {
    background: var(--color-cream);
    /* padding-block retuned in Task 7 against the full-page render.
       Bottom (6rem/96px) already matched the design almost exactly (the
       CtaBand pill (1:1479, ends y3827.06) to Footer top (y3925) gap is
       97.94px in Figma vs 96px rendered — left as-is). Top needed to drop:
       Audiences' own bottom padding (96px, unauthorized/untouched) plus
       this section's old 96px top padding gave a 192px band above this
       section's heading, but the design's actual gap (Audiences group
       bottom 1:377, y3354.08, to this H2's top 1:53, y3461.74) is only
       107.66px total — i.e. Audiences' own padding alone already accounts
       for nearly all of it, so this section's own contribution should be
       small: 107.66 - 96 = 11.66px. 0.73rem = 11.68px. */
    padding-block: 0.73rem 6rem;
  }

  .heading {
    text-align: center;
  }

  h2 {
    font-family: var(--font-display);
    /* 65px, Figma text nodes 1:55/1:56 (real text nodes, not outlined) —
       the design context call reports this size directly, correcting the
       brief's "~42px" bbox-derived guess. Matches the 65px H2 size already
       established for this same Faculty Glyphic H2 role in
       Pillars.astro/Audiences.astro. */
    font-size: 4.0625rem;
    line-height: 1.07; /* consistent with the sibling H2s at this size */
    color: var(--color-ink-alt); /* #1e1e3c, exact fill on 1:55/1:56 */
  }
  h2 .line {
    display: block;
  }

  .body {
    /* 8.88px, gap between the H2 group's own bbox bottom (1:54, ends
       y3615.31) and the paragraph group's bbox top (1:57, starts
       y3624.19) — both real Figma coordinates, not eyeballed. */
    margin: 0.555rem auto 0;
    /* 805.87px, Figma node 1:57 width — also node 1:53's own bbox width,
       since this paragraph's longest wrapped line is the widest element
       in the group (the H2 is narrower and centered within it). */
    max-width: 50.3669rem;
    font-family: var(--font-sans);
    /* Outlined vectors, no text node (see node 1:57's ~130 child paths).
       font-size retuned in Task 7: 20px (matching the site's other
       secondary copy) only wrapped this paragraph to 2 lines at this
       column's 805.87px width, but the design's own wrap (read directly
       off the Figma export) is 3 lines — "...with applications" /
       "opening soon. ...a real problem" / "worth an industrial pilot.".
       Verified empirically in headless Chrome at this exact max-width:
       23px (1.4375rem) is the size that reproduces that exact 3-line
       break (20-22.5px all wrap one word later per line; 23px+ all match,
       so 23px is the smallest/closest fit). */
    font-size: var(--text-body-lg); /* 23px */
    line-height: 1.4;
    color: var(--color-gray);
  }

  .cta {
    display: flex;
    justify-content: center;
    /* 36.12px, gap between the paragraph group's bbox bottom (1:57, ends
       y3714.93) and the pill's own top (1:1479, starts y3751.05). */
    margin-top: 2.2575rem;
  }

  @media (max-width: 1023.98px) {
    h2 {
      font-size: clamp(2.25rem, 6vw, 4.0625rem);
    }
    .body {
      max-width: 90%;
    }
  }
</style>
