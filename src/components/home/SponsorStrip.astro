---
import SparkOrange from "../../assets/home/spark-orange.svg";

// Order, captions and alt text per plan (Task 3 brief). Width/height were
// each logo's Figma-matched design bbox, scaled to 80% per user directive
// 2026-07-07 (a follow-up bump from an earlier 65% pass): at full Figma size
// the 7-logo row's natural width (~1486px incl. gaps) only fit a genuinely
// wide (~1920px+) browser window, wrapping on more modest real desktop
// widths; 65% then fit but read as too small/clustered. 80% + a 3rem gap
// (see .logos below) keeps the row on one line from ~1150px up while
// spreading it out closer to Figma's own look.
//
// Sources swapped 2026-07-07 (user directive) from the old src/assets/home/
// sponsor-*.png imports to new logo exports dropped directly in public/,
// referenced as plain <img src="/...png"> (not astro:assets <Image>) since
// public/ files aren't processed by that pipeline.
const sponsors = [
  {
    src: "/hindustan-petroleum.png",
    width: 99,
    height: 129,
    caption: "Hindustan Petroleum",
    alt: "Hindustan Petroleum Corporation",
  },
  {
    src: "/oil-naural-gas.png",
    width: 101,
    height: 101,
    caption: "Oil & Natural Gas",
    alt: "Oil and Natural Gas Corporation",
  },
  {
    src: "/indian-oil.png",
    width: 112,
    height: 119,
    caption: "Indian Oil Corp",
    alt: "Indian Oil Corporation",
  },
  {
    src: "/bharat-petroleum.png",
    width: 81,
    height: 101,
    caption: "Bharat Petroleum",
    alt: "Bharat Petroleum Corporation",
  },
  {
    src: "/gas-authority.png",
    width: 141,
    height: 106,
    caption: "Gas Authority",
    alt: "GAIL (India) Limited",
  },
  {
    src: "/oil-india.png",
    width: 83,
    height: 122,
    caption: "Oil India Ltd",
    alt: "Oil India Limited",
  },
  {
    src: "/petronet-lng.png",
    width: 78,
    height: 103,
    caption: "Petronet LNG",
    alt: "Petronet LNG Limited",
  },
] as const;
---

<section class="sponsor-strip">
  <div class="container">
    <h2>Built together by India's energy backbone:</h2>

    <div class="logos-viewport">
      <ul class="logos">
        {
          [...sponsors, ...sponsors].map((sponsor, i) => (
            <li aria-hidden={i >= sponsors.length ? "true" : undefined}>
              <figure class="logo">
                <span class="logo-frame">
                  <img
                    src={sponsor.src}
                    alt={sponsor.alt}
                    width={sponsor.width}
                    height={sponsor.height}
                  />
                </span>
                <figcaption>{sponsor.caption}</figcaption>
              </figure>
            </li>
          ))
        }
      </ul>
    </div>

    <SparkOrange class="divider" aria-hidden="true" />
  </div>
</section>

<style>
  .sponsor-strip {
    background: var(--color-cream);
    padding-block: 4rem;
  }

  h2 {
    margin: 0 0 2.5rem;
    text-align: center;
    /* Design (node 1:195) sets this heading in Sora, not the site's serif
       display face global.css defaults h2 to — text is outlined vectors in
       Figma, so size (~20px from bbox) and color are approximated per the
       brief rather than read off a text node. */
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: var(--text-body); /* ~20px, Figma 1:195 bbox height 29.4px */
    color: var(--color-ink);
  }

  .logos-viewport {
    overflow: hidden;
    width: 100%;
  }

  .logos {
    list-style: none;
    margin: 0;
    padding: 0;
    /* Marquee: the array above is rendered twice back-to-back, and the track
       is animated left by exactly 50% of its own width (one full set) --
       the instant the first set scrolls off, the second is sitting exactly
       where the first started, so the loop is seamless. Requires nowrap
       (a single continuous row, not centered -- centering an animated track
       doesn't mean anything) instead of the old wrap/justify-center. */
    display: flex;
    flex-wrap: nowrap;
    align-items: start;
    gap: 2.5rem 3rem; /* column-gap bumped from 2rem to 3rem (48px) per user directive 2026-07-07 -- spreads the row out closer to Figma's own ~103px gap while still fitting one row at realistic desktop widths (see sponsors array comment above) */
    width: max-content;
    animation: sponsor-scroll 32s linear infinite;
  }

  @keyframes sponsor-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logos {
      animation-play-state: paused;
    }
  }

  .logo {
    flex-shrink: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .logo-frame {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    /* 8.0625rem = 129px, 80% of the tallest sponsor asset (Hindustan
       Petroleum, scaled per user directive 2026-07-07 -- see the sponsors
       array comment above). Bottom-aligning each image inside a box this
       tall keeps the row visually level without stretching or cropping any
       logo, same technique as before, just scaled with the images. */
    height: 8.0625rem;
  }

  figcaption {
    margin-top: 0.75rem;
    font-family: var(--font-sans);
    font-size: var(--text-caption); /* ~12px, estimated from caption bbox heights (Figma 1:253 etc.) relative to the heading — captions are outlined vectors too */
    color: var(--color-gray);
    text-align: center;
  }

  .divider {
    display: block;
    /* margin-top tuned in Task 7: was 3rem/48px (an eyeball guess); the
       actual gap between the caption row's bottom (1:234, ends y1381.66)
       and the spark's own top (1:1026, y1454.25) measures 72.59px in Figma —
       verified against the full-page render, which showed the spark sitting
       visibly tighter under the logos than the design. 4.54rem = 72.64px. */
    margin: 4.54rem auto 0;
    width: 3.0963rem; /* 49.54px, Figma 1:1026 */
    height: 3.0963rem;
  }
</style>
