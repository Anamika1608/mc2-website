---
import SparkOrange from "../../assets/home/spark-orange.svg";

// Order, captions and alt text per plan (Task 3 brief). Width/height were
// each logo's Figma-matched design bbox, scaled to 65% per user directive
// 2026-07-07: at full size the 7-logo row's natural width (~1486px incl.
// gaps) only fit a genuinely wide (~1920px+) browser window, wrapping to a
// second row on any more modest real desktop width (confirmed via a live
// screenshot at the user's own browser window). Scaling down keeps the row
// on one line from 1024px up (this codebase's own desktop/tablet boundary).
//
// Sources swapped 2026-07-07 (user directive) from the old src/assets/home/
// sponsor-*.png imports to new logo exports dropped directly in public/,
// referenced as plain <img src="/...png"> (not astro:assets <Image>) since
// public/ files aren't processed by that pipeline.
const sponsors = [
  {
    src: "/hindustan-petroleum.png",
    width: 81,
    height: 105,
    caption: "Hindustan Petroleum",
    alt: "Hindustan Petroleum Corporation",
  },
  {
    src: "/oil-naural-gas.png",
    width: 82,
    height: 82,
    caption: "Oil & Natural Gas",
    alt: "Oil and Natural Gas Corporation",
  },
  {
    src: "/indian-oil.png",
    width: 91,
    height: 97,
    caption: "Indian Oil Corp",
    alt: "Indian Oil Corporation",
  },
  {
    src: "/bharat-petroleum.png",
    width: 66,
    height: 82,
    caption: "Bharat Petroleum",
    alt: "Bharat Petroleum Corporation",
  },
  {
    src: "/gas-authority.png",
    width: 114,
    height: 86,
    caption: "Gas Authority",
    alt: "GAIL (India) Limited",
  },
  {
    src: "/oil-india.png",
    width: 68,
    height: 99,
    caption: "Oil India Ltd",
    alt: "Oil India Limited",
  },
  {
    src: "/petronet-lng.png",
    width: 63,
    height: 84,
    caption: "Petronet LNG",
    alt: "Petronet LNG Limited",
  },
] as const;
---

<section class="sponsor-strip">
  <div class="container">
    <h2>Built together by India's energy backbone:</h2>

    <ul class="logos">
      {
        sponsors.map((sponsor) => (
          <li>
            <figure class="logo">
              <span class="logo-frame">
                <img
                  src={sponsor.src}
                  alt={sponsor.alt}
                  width={sponsor.width}
                  height={sponsor.height}
                />
              </span>
              <figcaption>{sponsor.caption}</figcaption>
            </figure>
          </li>
        ))
      }
    </ul>

    <SparkOrange class="divider" aria-hidden="true" />
  </div>
</section>

<style>
  .sponsor-strip {
    background: var(--color-cream);
    padding-block: 4rem;
  }

  h2 {
    margin: 0 0 2.5rem;
    text-align: center;
    /* Design (node 1:195) sets this heading in Sora, not the site's serif
       display face global.css defaults h2 to — text is outlined vectors in
       Figma, so size (~20px from bbox) and color are approximated per the
       brief rather than read off a text node. */
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: var(--text-body); /* ~20px, Figma 1:195 bbox height 29.4px */
    color: var(--color-ink);
  }

  .logos {
    list-style: none;
    margin: 0;
    padding: 0;
    /* Was display:grid + grid-template-columns:repeat(7,1fr) -- that stretched
       the row across the full .container width, inflating the gaps between
       logos well past Figma's own layout (confirmed via get_screenshot on
       node 1:194: the 7-logo group has a fixed natural width and sits
       centered with consistent ~103px gaps, not spread edge-to-edge).
       flex + a fixed gap keeps every logo at its own natural size and centers
       the whole group instead of stretching it. */
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: start;
    gap: 2.5rem 2rem; /* column-gap reduced from 6.44rem (103px, Figma-measured) to 2rem (32px) per user directive 2026-07-07 -- the Figma-derived gap only kept one row at a genuinely wide (~1920px+) browser window; combined with the smaller logo sizes below, this keeps all 7 on one row from 1024px up */
  }

  .logo {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .logo-frame {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    /* 6.54rem = 104.65px, 65% of the tallest sponsor asset (Hindustan
       Petroleum, scaled per user directive 2026-07-07 -- see the sponsors
       array comment above). Bottom-aligning each image inside a box this
       tall keeps the row visually level without stretching or cropping any
       logo, same technique as before, just scaled down with the images. */
    height: 6.54rem;
  }

  figcaption {
    margin-top: 0.75rem;
    font-family: var(--font-sans);
    font-size: var(--text-caption); /* ~12px, estimated from caption bbox heights (Figma 1:253 etc.) relative to the heading — captions are outlined vectors too */
    color: var(--color-gray);
    text-align: center;
  }

  .divider {
    display: block;
    /* margin-top tuned in Task 7: was 3rem/48px (an eyeball guess); the
       actual gap between the caption row's bottom (1:234, ends y1381.66)
       and the spark's own top (1:1026, y1454.25) measures 72.59px in Figma —
       verified against the full-page render, which showed the spark sitting
       visibly tighter under the logos than the design. 4.54rem = 72.64px. */
    margin: 4.54rem auto 0;
    width: 3.0963rem; /* 49.54px, Figma 1:1026 */
    height: 3.0963rem;
  }

  @media (max-width: 1023.98px) {
    .logos {
      /* Restores the pre-existing grid layout at this breakpoint -- untouched
         by the desktop-only flex change above. */
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 559.98px) {
    .logos {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
