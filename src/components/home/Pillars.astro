---
import PillButton from "../PillButton.astro";
import IllusCapital from "../../assets/home/illus-capital.svg";
import IllusMentorship from "../../assets/home/illus-mentorship.svg";
import IllusMarket from "../../assets/home/illus-market.svg";

// Folder-tab notch (Figma nodes 1:1073 / 1:1191 / 1:1339 / 1:1476) — a single
// flattened two-path vector reused identically on all four cards. The back
// path is always navy; only the front path's fill changes (literal black on
// the three cream cards, navy on O3's orange card so it doesn't read as a
// harsh cutout). Inlined here (rather than a separate asset) since it's one
// shape shared by every card with a one-color swap.
function notch(front: string) {
  return `<svg class="pillar-notch" viewBox="0 0 51.11 72.18" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <path d="M50.68 0.01V72.14L48.25 48.77C47.49 41.45 41.54 35.76 34.19 35.33L0.02 33.33L34.74 31.11C42.02 30.64 47.91 25.02 48.71 17.77L50.67 0.02L50.68 0.01Z" fill="${front}" />
    <path d="M50.68 0.01C50.67 23.96 51.1 48.1 51.11 72.14L50.24 72.18C49.81 68.4 48.09 51.1 47.61 47.71C46.52 41.37 40.85 36.24 34.43 35.84C31.29 35.64 22.92 35.13 19.68 34.94L0 33.75V32.88C8.54 32.37 23.77 31.42 32.15 30.95C40.02 31.24 47.26 26.35 48.47 18.27C49.24 12.13 50.01 6.02 50.67 0L50.68 0.01ZM50.68 0.01C49.98 6.18 49.47 12.28 48.79 18.33C48.03 24.56 42.98 29.95 36.8 31.11C34.12 31.59 30.32 31.66 27.6 31.9L18.42 32.53L0.05 33.76V32.89L19.74 34.01L29.58 34.57L34.51 34.86C39.61 35.18 44.39 38.31 46.84 42.78C48.57 45.67 48.8 49.21 49.1 52.48L51.11 72.1L50.24 72.14C50.26 48.09 50.69 24.14 50.67 0.01H50.68Z" fill="var(--color-ink-alt)" />
  </svg>`;
}
const NOTCH_BLACK = notch("#000");
const NOTCH_NAVY = notch("var(--color-ink-alt)");
---

<section class="pillars">
  <div class="container heading">
    <p class="eyebrow">WHAT WE PROVIDE</p>
    <h2>
      <span class="line">Four pillars. One mission: from idea </span>
      <span class="line">to industrial deployment.</span>
    </h2>
  </div>

  <div class="container">
    <div class="pillars-row">
      <article class="card card--o1">
        <h3 class="card-title">O1 Infrastructure</h3>
        <div class="card-rule" aria-hidden="true"></div>
        <Fragment set:html={NOTCH_BLACK} />
      </article>

      <article class="card card--o2">
        <h3 class="card-title">O2 Capital</h3>
        <div class="card-rule" aria-hidden="true"></div>
        <div class="card-content">
          <p class="card-body">
            Structured access to seed funding for early validation and
            scale-up capital for ventures demonstrating commercial traction.
          </p>
          <IllusCapital class="card-illus" aria-hidden="true" />
        </div>
        <Fragment set:html={NOTCH_BLACK} />
      </article>

      <article class="card card--o3">
        <h3 class="card-title">O3 Mentorship</h3>
        <div class="card-rule" aria-hidden="true"></div>
        <div class="card-content">
          <p class="card-body">
            Deep mentorship and research partnerships with premier
            institutions and enterprises, shortening the path from lab to
            deployment.
          </p>
          <IllusMentorship class="card-illus" aria-hidden="true" />
        </div>
        <Fragment set:html={NOTCH_NAVY} />
      </article>

      <article class="card card--o4">
        <h3 class="card-title">O4 Market Access</h3>
        <div class="card-rule" aria-hidden="true"></div>
        <div class="card-content">
          <!-- O4 body: design file duplicated O2's text; replacement approved by user 2026-07-05 -->
          <p class="card-body">
            Structured pathways to field pilots, procurement and first
            reference customers across the energy majors' operating sites.
          </p>
          <IllusMarket class="card-illus" aria-hidden="true" />
        </div>
        <Fragment set:html={NOTCH_BLACK} />
      </article>
    </div>

    <div class="cta">
      <PillButton label="See the full support stack" href="/support" />
    </div>
  </div>
</section>

<style>
  .pillars {
    background: var(--color-cream);
    /* padding-top/bottom split in Task 7 gap-fix pass (whole-page cross-
       section rhythm): the old symmetric `padding-block: 6rem` (96px both
       sides) was a placeholder rhythm guess, not page math. Measured via
       Figma metadata: SponsorStrip's divider (1:1026, bottom y1503.79) to
       this section's own eyebrow top (1:1029, y1580.31) = 76.52px design
       gap; this section's CTA pill (1:1033, bottom y2361.07) to Audiences'
       eyebrow top (1:379, y2548.26) = 187.19px design gap. Rendered (before
       fix, 1920px headless Chrome): 160px and 192px respectively — both
       larger than design. SponsorStrip's own padding-bottom (64px) and
       Audiences' own padding-top (96px) already read correctly elsewhere
       (Hero→SponsorStrip, Audiences→CtaBand) and are out of scope, so both
       deltas are absorbed here: padding-top = 76.52 − 64 = 12.52px
       (0.7825rem); padding-bottom = 187.19 − 96 = 91.19px (5.6994rem).
       Re-rendered after the fix: 76.52px and 187.19px — both match design
       to within 0.01px. */
    padding-top: 0.7825rem;
    padding-bottom: 5.6994rem;
    overflow-x: hidden;
  }

  .heading {
    text-align: center;
    margin-bottom: 3.8575rem; /* 61.72px, gap between H2 (1:1032) and card collage (1:1068) */
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-sans);
    /* Figma reports Faculty Glyphic on the wrapping group (1:1028), but the
       rendered glyphs are unmistakably sans (verified against the 1:1 scale
       screenshot) — same eyebrow-is-sans correction already made in
       Hero.astro/SponsorStrip.astro. */
    font-size: 1.6919rem; /* 27.07px, Figma 1:1029 */
    letter-spacing: 0.25em; /* 6.7675px tracking / 27.07px size = 0.25em exactly */
    color: var(--color-gray);
  }

  h2 {
    margin: 0.5875rem 0 0; /* 9.4px, eyebrow-bottom to H2-top gap */
    font-family: var(--font-display);
    /* 65px + 1.07 line-height verified directly against the 1:1 scale
       screenshot: the "F" of "Four" measures ~49px cap-height (49/65=0.75,
       a normal serif ratio) and the two line-tops sit 69.57px apart
       (69.57/65=1.07). This corrects the plan's "~44px" eyeball estimate —
       Figma's own reported size (1:1031/1:1032) turns out to be right. */
    font-size: 4.0625rem;
    line-height: 1.07;
    color: var(--color-ink-alt);
  }
  h2 .line {
    display: block;
  }

  .pillars-row {
    display: flex;
    align-items: flex-end; /* shared bottom baseline (all four cards' boxes end at Figma y2218.1) — this alone produces O3's "sits higher" and O1's short tab */
    gap: 3.47%; /* 61.45px / 1772.2px total row width (1:1068) — percentage so the gap scales with the row instead of the fixed-width cards overflowing narrower desktop viewports */
  }

  .card {
    position: relative;
    flex: 1 1 0%;
    min-width: 0;
    box-sizing: border-box;
    border: 0.125rem solid var(--color-ink-alt); /* 2px, all four cards (1:1070 etc.) */
    background: var(--color-cream);
    padding: 0.8rem 1.47rem 1.5rem; /* top/sides inset ≈ title's own inset (12.78px / 23.53px, consistent across all four cards) */
  }
  /* O1 bleeds off the container's left edge (Figma: the 4-card row starts at
     x=-33.82 on the 1920px canvas — one card-width+gap left of O2, i.e.
     this is where a uniform grid naturally lands the first cell, not a
     special extra offset).
     Retuned in Task 7 review round 2: a row-relative percentage (the
     original -1.91%, then a since-superseded -11.7% eyeballed at 1920px
     only) can't reproduce this — the required offset is the sum of two
     independent quantities that don't scale together: (a) the .container
     utility's own left gutter, which must be fully cancelled so the row's
     left edge reaches the true viewport edge, and (b) a further constant
     33.82px (the design's own bleed magnitude, x=-33.82 on the 1920 frame)
     to pass that edge. (a) is fixed per viewport width but not proportional
     to the row's own width, so no single percentage-of-row-width holds
     across breakpoints (verified: -11.7% under-bled at 1440px, cropping the
     card's own title text, and over-bled at 2560px into a much larger gap
     than the design shows).
     `.container`'s left gutter (src/styles/global.css) is
     `clamp(1.25rem, 4vw, 5rem)` padding-inline plus, once the viewport
     exceeds the 1760px max-width, `(100vw - 1760px) / 2` of centering
     margin — reproduced identically here so the two stay coupled if
     `.container` ever changes. `.pillars-row` sits directly inside
     `.container` with no padding/border of its own, so a flex-item
     margin-left on `.card--o1` resolves against that same content-box
     width/offset — i.e. this calc's first term exactly cancels the gutter
     regardless of viewport.
     `100vw` includes the scrollbar gutter on platforms with an
     always-visible scrollbar (~15px on Windows/Linux; 0 on macOS's
     overlay scrollbars) — an acceptable small error here since the design
     intent is "visibly bleeds past the edge," not a pixel-exact clip line.
     Verified via headless-Chrome renders (getBoundingClientRect on
     `.card--o1`) at all three tiers: 1440px → left edge -91.4px (title
     fully clear of the viewport, no cropping); 1920px → -190.6px (matches
     the design's -33.82px-past-container-edge almost exactly: gutter
     156.8px + 33.82px = 190.62px); 2560px → -513.8px (gutter 480px +
     33.82px = 513.82px) — bleed magnitude grows with the gutter at wide
     viewports, same as the design's own fixed-canvas math would imply if
     extrapolated. */
  .card--o1 {
    margin-left: calc(
      -1 * (clamp(1.25rem, 4vw, 5rem) + max((100vw - 1760px) / 2, 0px)) -
        2.11rem
    );
    min-height: 6.5663rem; /* 105.06px, Figma 1:1069 */
  }
  .card--o2 {
    min-height: 20.5063rem; /* 328.10px, Figma 1:1076 */
  }
  .card--o3 {
    background: var(--color-orange); /* #F37D2C, Figma 1:1201 */
    min-height: 23.6313rem; /* 378.10px, Figma 1:1200 — tallest, so bottom-alignment reads as "sits higher" */
  }
  .card--o4 {
    min-height: 20.1313rem; /* 322.10px, Figma 1:1342 */
  }

  .card-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.7831rem; /* 28.53px, Figma 1:1071/1:1078/1:1203/1:1344 — same navy on every card, including O3's orange one */
    line-height: 1.3; /* 37px bbox / 28.53px */
    font-weight: 400;
    color: var(--color-ink-alt);
  }

  .card-rule {
    position: absolute;
    left: 3.9rem; /* 62.4px inset from card edge, all four cards */
    right: 0; /* flush to the border, matching Figma's ~0.44px gap */
    top: 3.92rem; /* 62.73px */
    height: 0.125rem;
    background: var(--color-ink-alt);
  }

  /* Notebook-margin rule + body copy, present on every card except O1 (which
     has no body). Figma draws this as one compound path merging a vertical
     divider into the card's own border outline (e.g. O2's border vector:
     "M37.82 72.79V329.1H397.54V1H1V329.1H88.05") — reproduced here as a
     border-left on the content wrapper instead of chasing the compound path. */
  .card-content {
    margin-top: 0.6rem;
    margin-left: 0.89rem; /* divider inset (37.82px) minus the card's own left padding (23.53px) */
    padding-left: 2.3rem; /* body-text inset (74.62px) minus the divider's own inset (37.82px) */
    padding-bottom: 1rem;
    border-left: 0.125rem solid var(--color-ink-alt);
  }

  .card-body {
    margin: 0 0 1rem;
    max-width: 15.5rem; /* approximates the design's line breaks (outlined vectors, no text node — sized off the screenshot's 5-line wrap) */
    font-family: var(--font-sans);
    /* Body copy is outlined vectors in Figma (no text-node metrics). Size
       measured directly off the 1:1 screenshot: the "S" of "Structured"
       has an ~15px cap-height, consistent with a ~20px font at a typical
       ~0.73 cap-height ratio — matches the site's other secondary-text size
       (Hero .lede, also 20px). */
    font-size: 1.25rem;
    line-height: 1.4;
    color: var(--color-gray);
  }
  .card--o3 .card-body {
    color: var(--color-ink-alt); /* on-orange body copy is navy, not gray */
  }

  .card-illus {
    display: block;
    height: auto;
    max-width: 100%;
    margin-left: 2.1rem; /* illustrations sit right of the body-text column (Figma insets vary ~34px beyond the body text's own inset, per card) */
  }

  /* :global — this SVG is injected via set:html (it's shared, colour-swapped
     markup built in frontmatter), so Astro's scoped data-attribute never
     attaches to it and an un-prefixed rule here would silently no-op. The
     class is section-prefixed ("pillar-") and the rule anchored under the
     scoped .card so it can't collide with other components' globals. */
  .card :global(.pillar-notch) {
    position: absolute;
    top: 1.9rem; /* ≈30px from card top, consistent across all four cards regardless of card height */
    right: 0;
    width: 3.1944rem; /* 51.11px */
    height: 4.5113rem; /* 72.18px */
    pointer-events: none;
  }

  .cta {
    display: flex;
    justify-content: center;
    margin-top: 4.1856rem; /* 66.97px, gap between the card collage (1:1068) and the CTA pill (1:1033) */
  }

  @media (max-width: 1023.98px) {
    h2 {
      font-size: clamp(2.25rem, 6vw, 4.0625rem);
    }

    /* Responsive rule (brief step 2): below 1024, drop the bleed/offset
       collage for a normal 2x2 grid — O1 stays title-only (no body is ever
       rendered for it) but is no longer pushed off-canvas, and no card is
       forced taller/shorter than its own content. */
    .pillars-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      align-items: start;
      gap: 2rem;
    }
    .card {
      flex: initial;
    }
    .card--o1,
    .card--o2,
    .card--o3,
    .card--o4 {
      margin-left: 0;
      min-height: auto;
    }
  }

  @media (max-width: 639.98px) {
    .pillars-row {
      grid-template-columns: 1fr;
    }
  }
</style>
