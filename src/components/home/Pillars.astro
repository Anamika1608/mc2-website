---
import PillButton from "../PillButton.astro";
import RevealStar from "../../assets/shared/reveal-star.svg";

// Folder-tab notch (Figma nodes 1:1073 / 1:1191 / 1:1339 / 1:1476) — a single
// flattened two-path vector reused identically on all four cards. The back
// path is always navy; only the front path's fill changes (literal black on
// a cream card, navy on whichever card is currently orange, so it doesn't
// read as a harsh cutout). Inlined here (rather than a separate asset) since
// it's one shape shared by every card with a one-color swap.
// Hover-to-expand (this task): the front path is always `fill="currentColor"`
// now instead of being baked in per call site — at most one card is ever
// orange at a time (whichever carries `.is-active`, none by default — see the
// script below), not permanently any one card, so the notch color has to
// track that dynamically. `color` is set via CSS on `.pillar-notch` (base
// black, orange-card override), same pattern as HowItWorks.astro's step-vtab
// and Programs.astro's card-flag.
const NOTCH = `<svg class="pillar-notch" viewBox="0 0 51.11 72.18" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <path d="M50.68 0.01V72.14L48.25 48.77C47.49 41.45 41.54 35.76 34.19 35.33L0.02 33.33L34.74 31.11C42.02 30.64 47.91 25.02 48.71 17.77L50.67 0.02L50.68 0.01Z" fill="currentColor" />
    <path d="M50.68 0.01C50.67 23.96 51.1 48.1 51.11 72.14L50.24 72.18C49.81 68.4 48.09 51.1 47.61 47.71C46.52 41.37 40.85 36.24 34.43 35.84C31.29 35.64 22.92 35.13 19.68 34.94L0 33.75V32.88C8.54 32.37 23.77 31.42 32.15 30.95C40.02 31.24 47.26 26.35 48.47 18.27C49.24 12.13 50.01 6.02 50.67 0L50.68 0.01ZM50.68 0.01C49.98 6.18 49.47 12.28 48.79 18.33C48.03 24.56 42.98 29.95 36.8 31.11C34.12 31.59 30.32 31.66 27.6 31.9L18.42 32.53L0.05 33.76V32.89L19.74 34.01L29.58 34.57L34.51 34.86C39.61 35.18 44.39 38.31 46.84 42.78C48.57 45.67 48.8 49.21 49.1 52.48L51.11 72.1L50.24 72.14C50.26 48.09 50.69 24.14 50.67 0.01H50.68Z" fill="var(--color-ink-alt)" />
  </svg>`;
---

<section class="pillars">
  <div class="container heading reveal">
    <p class="eyebrow">WHAT WE PROVIDE</p>
    <h2>
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">Four pillars. One mission: from idea </span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">to industrial deployment.</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </h2>
  </div>

  <div class="container">
    <div class="pillars-row">
      <article class="card card--o1">
        <div class="card-head">
          <h3 class="card-title">O1 Infrastructure</h3>
          <div class="card-rule" aria-hidden="true"></div>
          <Fragment set:html={NOTCH} />
        </div>
        <!-- Hover-to-expand (this task): O1 never had a body/icon at all — confirmed
             genuinely absent from Figma (node 1:1069 has only a border, title and
             notch, no body text or illustration node). Body sourced verbatim from
             the reference screenshot provided for this task. Hidden until this
             card is active — see .card-content CSS below.
             Icon (round 11): public/icon01.png — a raster PNG replacing the
             old Globe-Gray.png, plain <img> like every other card's icon now
             (round 11 swapped O3/O4 off inline-SVG components onto matching
             raster PNGs too, so all four share one sizing rule below). -->
        <div class="card-content">
          <p class="card-body">
            Shared access to world-class R&D labs, testing rigs, fabrication
            workshops and technical facilities across India's energy majors
            and research institutions.
          </p>
          <img src="/icon01.png" alt="" class="card-illus" />
        </div>
      </article>

      <article class="card card--o2">
        <div class="card-head">
          <h3 class="card-title">O2 Capital</h3>
          <div class="card-rule" aria-hidden="true"></div>
          <Fragment set:html={NOTCH} />
        </div>
        <div class="card-content">
          <p class="card-body">
            Structured access to seed funding for early validation and
            scale-up capital for ventures demonstrating commercial traction.
          </p>
          <img src="/icon02.png" alt="" class="card-illus" />
        </div>
      </article>

      <article class="card card--o3">
        <div class="card-head">
          <h3 class="card-title">O3 Mentorship</h3>
          <div class="card-rule" aria-hidden="true"></div>
          <Fragment set:html={NOTCH} />
        </div>
        <div class="card-content">
          <p class="card-body">
            Deep mentorship and research partnerships with premier
            institutions and enterprises, shortening the path from lab to
            deployment.
          </p>
          <img src="/icon03.png" alt="" class="card-illus" />
        </div>
      </article>

      <article class="card card--o4">
        <div class="card-head">
          <h3 class="card-title">O4 Market Access</h3>
          <div class="card-rule" aria-hidden="true"></div>
          <Fragment set:html={NOTCH} />
        </div>
        <div class="card-content">
          <!-- O4 body: design file duplicated O2's text; replacement approved by user 2026-07-05 -->
          <p class="card-body">
            Structured pathways to field pilots, procurement and first
            reference customers across the energy majors' operating sites.
          </p>
          <img src="/icon04.png" alt="" class="card-illus" />
        </div>
      </article>
    </div>

    <div class="cta">
      <PillButton label="See the full support stack" href="/support" />
    </div>
  </div>
</section>

<script>
  // Exclusive active card, at most one at a time — same pattern as
  // HowItWorks.astro's script (plain DOM addEventListener + classList, no
  // framework). No card is active by default (round 6, per direct feedback +
  // reference screenshots: all four start collapsed, nothing orange, until the
  // user actually hovers one) — O3 used to be the default/fallback here, no
  // longer is.
  const row = document.querySelector<HTMLElement>(".pillars-row");
  const cards = document.querySelectorAll<HTMLElement>(".pillars-row .card");

  const activate = (target: HTMLElement | null) => {
    cards.forEach((card) => card.classList.toggle("is-active", card === target));
  };

  if (row) {
    cards.forEach((card) => {
      card.addEventListener("mouseenter", () => activate(card));
    });
    // Reset to "nothing active" (not a fallback card) — moving the mouse off the
    // row returns to the same fully-collapsed look as page load. Unconditional
    // (no viewport guard), same lesson as the Programs.astro fix-round: gating
    // this on a desktop-only check left a card stuck active if the viewport
    // changed mid-hover.
    row.addEventListener("mouseleave", () => {
      activate(null);
    });
  }
</script>

<style>
  .pillars {
    background: var(--color-cream);
    /* padding-top/bottom split in Task 7 gap-fix pass (whole-page cross-
       section rhythm): the old symmetric `padding-block: 6rem` (96px both
       sides) was a placeholder rhythm guess, not page math. Measured via
       Figma metadata: SponsorStrip's divider (1:1026, bottom y1503.79) to
       this section's own eyebrow top (1:1029, y1580.31) = 76.52px design
       gap; this section's CTA pill (1:1033, bottom y2361.07) to Audiences'
       eyebrow top (1:379, y2548.26) = 187.19px design gap. Rendered (before
       fix, 1920px headless Chrome): 160px and 192px respectively — both
       larger than design. SponsorStrip's own padding-bottom (64px) and
       Audiences' own padding-top (96px) already read correctly elsewhere
       (Hero→SponsorStrip, Audiences→CtaBand) and are out of scope, so both
       deltas are absorbed here: padding-top = 76.52 − 64 = 12.52px
       (0.7825rem); padding-bottom = 187.19 − 96 = 91.19px (5.6994rem).
       Re-rendered after the fix: 76.52px and 187.19px — both match design
       to within 0.01px. */
    padding-top: 0.7825rem;
    padding-bottom: 5.6994rem;
    overflow-x: hidden;
  }

  .heading {
    text-align: center;
    margin-bottom: 3.8575rem; /* 61.72px, gap between H2 (1:1032) and card collage (1:1068) */
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-sans);
    /* Figma reports Faculty Glyphic on the wrapping group (1:1028), but the
       rendered glyphs are unmistakably sans (verified against the 1:1 scale
       screenshot) — same eyebrow-is-sans correction already made in
       Hero.astro/SponsorStrip.astro. */
    font-size: 1.375rem; /* 22px — reduced from 27.07px per user directive 2026-07-06 (desktop type felt oversized on sub-1920 laptops) */
    letter-spacing: 0.25em; /* 6.7675px tracking / 27.07px size = 0.25em exactly */
    color: var(--color-gray);
  }

  h2 {
    margin: 0.5875rem 0 0; /* 9.4px, eyebrow-bottom to H2-top gap */
    font-family: var(--font-display);
    /* Was 65px (4.0625rem) + 1.07 line-height verified directly against the
       1:1 scale screenshot: the "F" of "Four" measures ~49px cap-height
       (49/65=0.75, a normal serif ratio) and the two line-tops sit 69.57px
       apart (69.57/65=1.07). Reduced to 52px per user directive 2026-07-06
       (desktop type felt oversized on sub-1920 laptops) — line-height ratio
       unchanged. */
    font-size: 3.25rem;
    line-height: 1.07;
    color: var(--color-ink-alt);
  }
  h2 .line {
    display: block;
  }

  .pillars-row {
    display: flex;
    align-items: stretch; /* per direct feedback: every card must be the exact same height — flexbox's own default cross-axis behavior already does this natively (every item stretches to the row's tallest), replacing the previous flex-end bottom-alignment that let cards keep their own differing natural heights. Fully responsive with no magic numbers: the row's height is simply whichever card needs the most room at the CURRENT viewport, recalculated by the browser at every width, same as the rest of this flex layout already works. */
    gap: 3.47%; /* 61.45px / 1772.2px total row width (1:1068) — percentage so the gap scales with the row instead of the fixed-width cards overflowing narrower desktop viewports */
    /* Per direct feedback: reverted to always-open cards (round 7's permanent
       `--pillar-active-height` reservation, and the min-height/hide-show
       machinery it existed to protect, are gone — see .card and .card-content
       below). That whole apparatus was defending against a real
       reflow-thrashing bug from a card's box growing/shrinking on hover; now
       that every card's content is always visible and never toggles, nothing
       about layout ever changes on hover (only background-color, a paint
       property), so there's nothing left to protect against. */
  }

  .card {
    position: relative;
    display: flex; /* per direct feedback (equal card heights): lets .card-content (below) grow to fill whatever extra height `align-items: stretch` (above) now gives this card, so the icon can be pushed to the card's own bottom instead of leaving a random gap wherever the content happens to end. */
    flex-direction: column;
    flex: 1 1 0%;
    min-width: 0;
    box-sizing: border-box;
    border: 0.125rem solid var(--color-ink-alt); /* 2px, all four cards (1:1070 etc.) */
    background: var(--color-cream);
    padding: 0.8rem 1.47rem 1rem; /* top/sides inset ≈ title's own inset (12.78px / 23.53px, consistent across all four cards) */
    transition: background-color 200ms ease;
  }
  /* Per direct feedback: all four cards are always open now (title + body +
     icon always visible — see .card-content below), reverting the
     collapsed/expand-on-hover interaction from earlier rounds. `.is-active`
     (assigned by the script below on hover, none by default) now only ever
     toggles `background` — nothing about height, min-height, or visibility.
     That's safe specifically because nothing about LAYOUT changes on hover
     anymore: the reflow-thrashing bug those earlier rounds fought (a card's
     box growing/shrinking on hover, shoving the CTA button around) can't
     recur when a card's box never changes size to begin with. Each card
     simply keeps its own natural height (title + body + icon), same as the
     reference screenshot's differing heights, with `align-items: flex-end`
     (on .pillars-row) bottom-aligning them. */
  .card.is-active {
    background: var(--color-orange); /* #F37D2C, Figma 1:1201 */
  }
  /* O1 previously bled off the container's left edge by a Figma-matched constant
     (~33.8px past the viewport edge) — removed per direct user feedback: it read
     as a broken/cut-off card regardless of its design provenance. Always a
     normal, fully on-screen flex item now, same as O2/O3/O4 — kept exactly as-is
     through this round too, per instruction. */
  .card--o1 {
    margin-left: 0;
  }

  .card-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.4rem; /* 22.4px — reduced from 28.53px per user directive 2026-07-06 */
    line-height: 1.3; /* 37px bbox / 28.53px */
    font-weight: 400;
    color: var(--color-ink-alt);
  }

  /* Wraps just the title + its rule. Position:relative here (rather than on
     .card) makes this box hug the title's own rendered height exactly — 1
     line at ≥1440px, 2 lines at 1024–1366px for O1/O3/O4 — since .card-rule
     is absolutely positioned inside it and so doesn't add to its height.
     .card-content's own margin-top (below) is therefore untouched by any of
     this: it still measures from the title's bottom edge, same as before. */
  .card-head {
    position: relative;
  }

  /* Final-review fix (whole-branch review): this used to be `top: 3.92rem`
     fixed from the card's own top, calibrated for a one-line title. At
     1024–1366px O1/O3/O4's titles wrap to 2 lines and the fixed offset then
     landed mid-text, striking through the wrapped second line. Anchoring to
     `top: 100%` of `.card-head` (which hugs the title's real height, see
     above) instead makes the rule track the title's actual bottom edge at
     any wrap count. `margin-top` reproduces the exact one-line gap so
     ≥1440px (where every title is still 1 line) renders pixel-identically
     to the old fixed-offset rule: 3.92rem (old top) − [0.8rem card
     padding-top + 1.7831rem × 1.3 title line-box] = 0.80197rem ≈ 0.802rem. */
  .card-rule {
    position: absolute;
    left: 2.43rem; /* 3.9rem original card-relative inset minus the card's own 1.47rem left padding, which .card-head (unlike .card) sits inside of already — reproduces the same 62.4px inset from the card's border */
    right: -1.47rem; /* extends back out through the card's own right padding to stay flush with the border, same as the original `right: 0` measured from the card's padding edge */
    top: 100%;
    margin-top: 0.802rem;
    height: 0.125rem;
    background: var(--color-ink-alt);
  }

  /* Notebook-margin rule + body copy + icon. Figma draws the divider as one
     compound path merging a vertical divider into the card's own border outline
     (e.g. O2's border vector: "M37.82 72.79V329.1H397.54V1H1V329.1H88.05") —
     reproduced here as a border-left on the content wrapper instead of chasing
     the compound path. Always visible now (per direct feedback: all four
     cards are permanently open, hover only changes background color — see
     .card's own comment above). */
  .card-content {
    display: flex; /* per direct feedback (equal card heights): grows to fill whatever extra height .card's own stretch now gives it (flex: 1 below), then stacks its own children in a column so .card-illus (below) can be pushed to the bottom via margin-top: auto instead of leaving a random gap whichever card happens to have less body text. */
    flex-direction: column;
    flex: 1 1 auto;
    margin-top: 0.6rem;
    margin-left: 0.89rem; /* divider inset (37.82px) minus the card's own left padding (23.53px) */
    padding-left: 1.5rem; /* per direct feedback + Figma node 1:1200: text must start flush with the horizontal rule's own left edge, not indented further right — measured live, rule sits 64.4px from the card border while this padding used to put the body text at 78.5px, a visible extra gap the rule itself doesn't have. 1.5rem puts text at ~63.8px, matching the rule to within a pixel. */
    /* Direct feedback: give the text below the horizontal rule some top
       breathing room — this used to be 0, so the body text's own line-height
       started flush against the divider/rule with no gap at all. */
    padding-top: 0.75rem;
    padding-bottom: 0.5rem;
    border-left: 0.125rem solid var(--color-ink-alt);
  }

  .card-body {
    margin: 0 0 0.6rem; /* bottom trimmed from 1rem (round 8) — see .card's own comment */
    max-width: 15.5rem; /* approximates the design's line breaks (outlined vectors, no text node — sized off the screenshot's 5-line wrap) */
    font-family: var(--font-sans);
    /* Body copy is outlined vectors in Figma (no text-node metrics). Size
       measured directly off the 1:1 screenshot: the "S" of "Structured"
       has an ~15px cap-height, consistent with a ~20px font at a typical
       ~0.73 cap-height ratio — matches the site's other secondary-text size
       (Hero .lede, also 20px). */
    font-size: 1.0625rem; /* 17px — reduced from 20px per user directive 2026-07-06 */
    line-height: 1.4;
    color: var(--color-gray);
    text-align: justify; /* sitewide paragraph-justify pass */
  }
  .card.is-active .card-body {
    color: var(--color-ink-alt); /* on-orange body copy is navy, not gray — applies to whichever card is currently active, not just O3 */
  }

  /* Round 11: all four cards' icons are now plain <img> raster PNGs
     (public/icon01-04.png) sharing the same 2:1 aspect ratio and properly
     cropped to their own content (unlike the old Globe-Gray.png/Icons.png,
     which had huge built-in transparent padding and needed per-card size
     hacks — O2's 9rem override, O4's separate SVG height cap — to
     compensate). One shared rule now covers every card. Height matches the
     long-standing convention already used for the SVG-era icons
     (illus-mentorship's native 178x89, also 2:1). */
  .card-illus {
    display: block;
    /* Fix (mobile icon squish, O1-O3): was `height: 5.5625rem; width: auto;
       max-width: 100%` — a fixed height with width deriving from it ONLY
       until max-width:100% actually clamps the rendered width below that
       natural value (which happens at the single-column 639.98px breakpoint,
       where the card column is narrower than the icon's natural width at
       89px-tall/2:1) — past that point the browser renders at the clamped
       width while height stays pinned, distorting the 2:1 aspect (same
       mechanism already diagnosed and fixed for O4 alone, below). Switching
       to height:auto + max-width means it always follows the rendered width
       1:1 with the image's real aspect ratio (confirmed 5906x2953 = exactly
       2:1 via `sips`), so it can never distort at any card width. 11.125rem
       (178px) reproduces the exact on-screen size the old rule rendered at
       everywhere it didn't clip (5.5625rem height x 2:1 aspect = 178px
       wide), so ≥640px is visually unchanged. Deliberately NOT also setting
       `width: 100%` (unlike O4's own override below) — this is an <img>
       (replaced element with intrinsic ratio) inside a flex column
       (.card-content), and per spec `align-items:stretch` doesn't stretch
       replaced elements with an intrinsic ratio, so it already sizes to
       min(intrinsic width, max-width) with no explicit width needed —
       avoids a latent risk in O4's own width:100%-plus-inherited-margin-left
       combination (width:100% is computed against the content-box while
       margin sits outside it, which can in principle push the box past the
       container's right edge) without needing to touch O4's own shipped
       rule below. */
    height: auto;
    max-width: 11.125rem; /* 178px, see derivation above */
    margin-left: 2.1rem; /* illustrations sit right of the body-text column (Figma insets vary ~34px beyond the body text's own inset, per card) */
    margin-top: auto; /* per direct feedback (equal card heights): pushes the icon to .card-content's own bottom edge, so the extra height every card now gets (to match the tallest) shows up as breathing room above the icon, not a gap after it. */
  }

  /* O4-only override (2026-07-08, user directive): Figma's own O4 illustration
     node (1:1457, "Clip path group") is 239.67x132.38 -- notably bigger than
     O2's (211.66x64.56) or O3's (176.26x87.66) -- and is actually a larger
     graphic deliberately cropped by the card edge so only its top half peeks
     through (confirmed via get_design_context + get_screenshot). Per user
     direction, keeping O4 as a complete/uncropped icon like O1/O2/O3 rather
     than replicating that crop, but sizing it up to better match Figma's
     larger intent for this specific card. Also switches away from the
     shared rule's height:fixed + width:auto + max-width:100% pattern (which
     breaks aspect ratio once max-width actually clamps the width, since
     height never follows) to width:100% + max-width + height:auto, which
     can never distort at any card width. Scoped to .card--o4 only --
     O1/O2/O3 keep the shared rule above, completely unchanged. */
  .card--o4 .card-illus {
    height: auto;
    width: 100%;
    max-width: 14rem; /* 224px, ~26% larger than the shared rule's effective 178px (89px height x icon04.png's 2:1 aspect) */
  }

  /* :global — this SVG is injected via set:html (it's shared, colour-swapped
     markup built in frontmatter), so Astro's scoped data-attribute never
     attaches to it and an un-prefixed rule here would silently no-op. The
     class is section-prefixed ("pillar-") and the rule anchored under the
     scoped .card so it can't collide with other components' globals.

     Per direct feedback (the notch's own pinch point should cross .card-rule,
     matching Figma node 1:1073 etc. almost exactly — confirmed directly
     against Figma's own coordinates, off by 0.32px): this used to be `top:
     1.9rem` measured from the card's own top — a fixed guess that only holds
     when the title is a single line. Confirmed via a full-width sweep
     (1024-1920px) that O1/O3/O4's titles genuinely wrap to 2 lines at
     1024-1366px (O4 up to 1440px) — pushing .card-rule down a full line
     without moving this fixed offset, opening a real ~36px gap exactly at
     those widths (O2's shorter title never wraps, so it stayed aligned
     throughout, which is why this only showed up on 3 of the 4 cards at
     narrower widths). Moved the notch inside `.card-head` (alongside
     .card-rule, right after it in the markup) and anchored it the same way
     `.card-rule` already is — `top: 100%` off .card-head's own bottom edge —
     so it always tracks the title's real rendered height at any wrap count.
     `margin-top` reproduces the pinch-to-rule offset: the notch's visual
     pinch sits partway down its own SVG, not at its own top edge (viewBox
     y=33.33 of 72.18, i.e. 46.18% down), so margin-top pulls it up by that
     fraction of its own height, landing the pinch on .card-rule's own line:
     0.802rem (.card-rule's own margin-top) − (33.33 / 72.18 × 4.5113rem) ≈
     -1.2813rem. `right` is offset by `-1.595rem` (the card's own right
     padding, 1.47rem, plus its 0.125rem border) to compensate for .card-head
     sitting inset from the card's actual outer border edge by that combined
     amount — without it, the notch would land short of the card's border
     instead of flush with it, same as Figma's own 0px inset (confirmed
     against 1:1073's coordinates: right edge exactly at the card's border,
     no gap). */
  .card :global(.pillar-notch) {
    position: absolute;
    top: 100%;
    margin-top: -1.2813rem;
    right: -1.595rem;
    width: 3.1944rem; /* 51.11px */
    height: 4.5113rem; /* 72.18px */
    pointer-events: none;
    /* fill="currentColor" in the NOTCH markup (see frontmatter) — tracks the same
       cream/orange switch as the card's own background, so the notch's front path
       never mismatches whichever card is currently active. */
    color: #000;
    transition: color 200ms ease;
  }
  .card.is-active :global(.pillar-notch) {
    color: var(--color-ink-alt);
  }

  .cta {
    display: flex;
    justify-content: center;
    margin-top: 4.1856rem; /* 66.97px, gap between the card collage (1:1068) and the CTA pill (1:1033) */
  }

  @media (min-width: 1024px) and (max-width: 1439.98px) {
    /* Final-review fix (whole-branch review): O1's bleed calc (`.card--o1`
       margin-left, above) is correct and shared with O3/O4's wrap — left
       untouched. But at this range O1's title itself wraps to 2 lines
       ("O1" / "Infrastructure"), and its box's left edge sits ~8.25px past
       the viewport edge at any width in this range (the bleed math is
       viewport-independent, verified via getBoundingClientRect). A
       one-line "O1 Infrastructure" survives that crop (the rounded "O"'s
       own left bearing absorbs it — verified readable ≥1440px, left as-is
       there), but the wrapped second line's leading "I" has ~zero left
       bearing and was visibly clipped to "nfrastructure". Nudging the
       title inward by more than the 8.25px overhang (with a little extra
