---
import PillButton from "../PillButton.astro";
import SparkOrange from "../../assets/home/spark-orange.svg";
import RevealStar from "../../assets/shared/reveal-star.svg";
---

<section class="audiences">
  <div class="container heading reveal">
    <p class="eyebrow">WHO IT’S FOR</p>
    <h2>
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">Built for every builder</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>{" "}
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">in India’s energy&nbsp;story.</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </h2>
    <p class="intro">
      Whether you are an early-stage aspiring entrepreneur, a researcher with
      a lab&#8209;stage IP, or an institution ready to co-build the next decade of
      energy technology – MC²+ is for you.
    </p>
    <div class="cta">
      <PillButton label="Explore the initiatives" href="/initiatives" />
    </div>
  </div>

  <div class="container">
    <div class="columns">
      <!-- Desktop-only decorative framework (node group 1:945 + 1:534,
           pixel-mapped off the 1:377 screenshot): a top rule at the pill's
           vertical center emerging from behind the pill and bleeding off the
           right viewport edge; a bottom rule bleeding off the left viewport
           edge and tapering out just past the grid's center; bookend
           verticals outside columns 1 and 4; and sparks at the line
           intersections/endpoints (sizes vary per the design — see the
           per-spark rules below). Hidden <1024 along with the pill-anchored
           divider extensions. -->
      <div class="decor" aria-hidden="true">
        <span class="rule rule--top"></span>
        <span class="rule rule--bottom"></span>
        <span class="vline vline--left"></span>
        <span class="vline vline--right"></span>
        <SparkOrange class="dspark dspark--sm dspark--top-d1" />
        <SparkOrange class="dspark dspark--lg dspark--top-d3" />
        <SparkOrange class="dspark dspark--lg dspark--top-right" />
        <SparkOrange class="dspark dspark--lg dspark--bot-left" />
        <SparkOrange class="dspark dspark--lg dspark--bot-d1" />
        <SparkOrange class="dspark dspark--lg dspark--bot-d2" />
        <SparkOrange class="dspark dspark--xs dspark--bot-d3" />
      </div>

      <div class="column">
        <p class="number">01</p>
        <h3 class="title">Startups & <br class="title-break" />Founders</h3>
        <p class="body">
          Validate, pilot and scale your energy technology with India’s
          largest energy majors behind you.
        </p>
      </div>

      <div class="column">
        <SparkOrange class="divider-spark divider-spark--top" aria-hidden="true" />
        <SparkOrange class="divider-spark divider-spark--bottom" aria-hidden="true" />
        <p class="number">02</p>
        <h3 class="title">Researchers & Scientists</h3>
        <p class="body">
          Turn lab&#8209;stage IP into venture-ready technology through the MC²
          Fellows Entrepreneur-in-Residence track.
        </p>
      </div>

      <div class="column">
        <SparkOrange class="divider-spark divider-spark--top" aria-hidden="true" />
        <SparkOrange class="divider-spark divider-spark--bottom" aria-hidden="true" />
        <p class="number">03</p>
        <h3 class="title">Academic & <br class="title-break" />R&D Institutions</h3>
        <p class="body">
          Bring your labs, faculty and pipeline of innovators into a national
          energy-innovation platform.
        </p>
      </div>

      <div class="column">
        <SparkOrange class="divider-spark divider-spark--top" aria-hidden="true" />
        <SparkOrange class="divider-spark divider-spark--bottom" aria-hidden="true" />
        <p class="number">04</p>
        <h3 class="title">Corporates & Investors</h3>
        <!-- trailing ".t" in design file removed; approved by user 2026-07-05 -->
        <p class="body">
          Co-invest, co-pilot, or plug into a sourcing pipeline built on real
          industrial validation.
        </p>
      </div>

      <!-- Mobile-only (<=639.98px) left rail: replaces the desktop decor
           overlay and per-column dividers with a single continuous vertical
           line running the full height of the stacked 1-col layout, paired
           with the top sparks kept below (dev-feedback: don't hide the
           divider/spark treatment outright on mobile, give it a rail
           instead). display:none outside that breakpoint. Deliberately
           placed LAST (not as the first sibling of .decor, as the reviewed
           plan specified) — DEVIATION: `.columns`'s existing children are
           .decor + 4x .column, and the pre-existing tablet-width cascade
           (`.column:nth-child(3)...`) already numerically counts .decor as
           child 1 (nth-child counts elements regardless of display:none),
           so inserting a new sibling any earlier than the end shifts every
           .column's :nth-child() index by one and silently breaks that
           cascade (verified live). Placing it last leaves every existing
           index untouched; its own absolute positioning in the CSS below
           doesn't depend on DOM order. -->
      <span class="columns-rail" aria-hidden="true"></span>
    </div>
  </div>
</section>

<style>
  .audiences {
    /* Sampled from the screenshot background (244,243,237) — matches
       --color-cream-alt exactly, not --color-cream used by Hero/Pillars/
       SponsorStrip. A deliberate alternating-band choice, node group 1:377. */
    background: var(--color-cream-alt);
    padding-block: 6rem;
    /* Contain the decor rules' 50vw viewport bleeds (Pillars precedent). */
    overflow-x: hidden;
  }

  .heading {
    text-align: center;
    /* Paint the pill above the decor's top rule — the design's rule emerges
       from behind the pill (screenshot: no rule visible left of the pill,
       line starts at its right edge). */
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-sans);
    /* Figma reports Faculty Glyphic on the wrapping group, but the rendered
       glyphs are sans — same eyebrow-is-sans correction already made in
       Hero.astro/SponsorStrip.astro/Pillars.astro. Size/tracking identical
       to Pillars' eyebrow (node 1:379): 27.07px / 6.7675px tracking = 0.25em. */
    font-size: 1.375rem; /* 22px — reduced from 27.07px per user directive 2026-07-06 (desktop type felt oversized on sub-1920 laptops) */
    letter-spacing: 0.25em;
    color: var(--color-gray);
  }

  h2 {
    margin: 0.6rem 0 0;
    font-family: var(--font-display);
    /* Was 65px (4.0625rem), node 1:381/1:382. Line-height verified directly
       against the screenshot (same method as Pillars.astro): line-tops sit
       ~70px apart (70/65 = 1.077), matching Pillars' 1.07 for the same
       font-size. Reduced to 52px per user directive 2026-07-06 (desktop
       type felt oversized on sub-1920 laptops) — line-height ratio unchanged. */
    font-size: 3.25rem;
    line-height: 1.07;
    color: var(--color-ink-alt);
  }
  h2 .line {
    display: block;
  }

  .intro {
    /* Not a text node (no node id) — Figma's design-context call returned no
       text node for this paragraph, so its outlined-vector metrics were
       measured directly off the 1:1 screenshot: a capital "W" of "Whether"
       has an 18px cap-height vs. the column body copy's 15px "V" (both
       outlined too) — 18/15 * 20px = ~24px, a size step up from the site's
       usual 20px secondary text. */
    max-width: 51.875rem; /* 830px, screenshot's longest wrapped line */
    margin: 1.5rem auto 0;
    font-family: var(--font-sans);
    font-size: 1.25rem; /* 20px — reduced from 24px per user directive 2026-07-06 */
    line-height: 1.3;
    color: var(--color-gray);
    text-align: center; /* reverted from justify -- uneven word-spacing, per direct user feedback 2026-07-10 */
  }

  .cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .columns {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    /* Column gap is a whole-page layout concern per the Pillars.astro
       precedent — reasonable equal-width grid here, checked in Task 7.
       Left as the plain 3rem: the design's own gap (avg 102px across the
       three measured column gaps, node 1:536/1:626/1:727/1:840) is wider,
       but the .dspark/.vline/.divider-spark rules below hardcode this
       gap's half/quarter (1.5rem/0.75rem) into their offsets — changing
       gap alone would desync the decor overlay from the actual gap band,
       and retuning every dependent offset is out of this task's scope. */
    gap: 3rem;
    /* Outer inset tuned in Task 7: the design's own column group (node
       1:535) is only 1429.98px wide at the 1920px canvas (243.06px inset
       each side) — narrower than the shared .container's 1606.4px content
       box (156.8px inset) this row was inheriting, so the columns bled
       closer to the viewport edges than the design. Constraining this row
       to the design's own measured width restores its wider outer gutter
       without touching the shared .container utility (heading above is
       unaffected). 89.3738rem = 1429.98px. */
    max-width: 89.3738rem;
    margin-inline: auto;
    /* 58px: measured off the 1:377 screenshot — pill bottom y408 to the
       "01" number tops y466. The decor geometry below anchors to the pill's
       center through this value, so it is design-sourced (not eyeballed). */
    margin-top: 3.625rem;
    /* Decor anchors, both measured off the 1:377 screenshot:
       --decor-rise: columns-top to pill-center = 96px (58px margin above
         + half the 76px pill) — the top rule and divider tops sit here.
       --decor-drop: columns-bottom to the bottom spark row = 40px
         (deepest column text bottoms at y716, bottom rule at y756). */
    --decor-rise: 6rem;
    --decor-drop: 2.5rem;
  }

  .column {
    position: relative;
    text-align: left;
  }

  /* Mobile-only rail (<=639.98px), see media block below for the visible
     rule — no-op at tablet/desktop. */
  .columns-rail {
    display: none;
  }

  /* ==== Column dividers (node group 1:945) ====
     Thin vertical hairlines between the four columns — sampled color
     (243,184,140), an antialiased tint of --color-orange at 1px width; the
     token is used directly rather than a new literal. On desktop each
     divider rises past the columns to the top rule at the pill's center
     (screenshot: lines at x580/x962/x1342 all start at rule level y372 —
     x962's top is hidden behind the pill, exactly what happens here too
     since that divider sits at the grid's center under the centered pill)
     and drops to the bottom spark row. */
  .column:not(:first-child)::before {
    content: "";
    position: absolute;
    top: calc(-1 * var(--decor-rise));
    bottom: calc(-1 * var(--decor-drop));
    left: -1.5rem; /* half of the 3rem column gap */
    width: 1px;
    background: var(--color-orange);
  }
  /* col3/4 divider tapers out above its tiny bottom spark (screenshot:
     solid to y707, fading to y756) — approximated with a gradient fade. */
  .column:nth-child(4)::before {
    background: linear-gradient(
      to bottom,
      var(--color-orange) calc(100% - 3rem),
      transparent
    );
  }

  /* Per-column sparks are the <1024 fallback only — on desktop all sparks
     are drawn by the .decor overlay (sizes/positions differ per spark in
     the design, which the uniform per-column pair can't express). Only
     rendered for columns 2-4 (see markup), so no first-child guard needed. */
  .divider-spark {
    display: none;
    position: absolute;
    left: -1.5rem;
    width: 1.1rem;
    height: 1.1rem;
    transform: translate(-50%, -50%);
  }
  .divider-spark--top {
    top: 0;
  }
  .divider-spark--bottom {
    top: 100%;
  }

  /* ==== Desktop decor overlay (node groups 1:945 + 1:534) ====
     All geometry below is pixel-mapped off the 1920px-wide 1:377 screenshot.
     Divider x-positions in grid coords: divider n sits mid-gap, i.e. at
     calc(n*25% ± 0.75rem) — for a 4-col grid with gap g, divider 1 =
     25% - g/4, divider 2 = 50%, divider 3 = 75% + g/4 (g = 3rem). Bookends
     sit half a gap outside the grid edges (design: grid lines at
     x198/580/962/1342/1723, uniformly 381-382px apart). */
  .decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .rule {
    position: absolute;
    height: 1px;
  }
  /* Top rule (y372 = pill center): emerges from behind the pill — nothing
     is drawn left of it (screenshot: cream gap between the col1/2 spark and
     the pill's left edge) — and bleeds off the right viewport edge, fading
     near the end (solid to x1847 of 1920). Starting it at the grid's 50%
     center hides the left half behind the centered pill, matching the
     design's visible extent exactly. */
  .rule--top {
    top: calc(-1 * var(--decor-rise));
    left: 50%;
    right: calc(50% - 50vw); /* full-bleed right */
    background: linear-gradient(
      to right,
      var(--color-orange) 92%,
      transparent
    );
  }
  /* Bottom rule (y756): bleeds off the left viewport edge (tapering in over
     the first ~75px) and runs through the left-bookend, col1/2 and col2/3
     bottom sparks, tapering out 96px past the grid center (x1058). */
  .rule--bottom {
    top: calc(100% + var(--decor-drop));
    left: calc(50% - 50vw); /* full-bleed left */
    right: calc(50% - 6rem); /* right edge 96px past grid center */
    background: linear-gradient(
      to right,
      transparent,
      var(--color-orange) 6%,
      var(--color-orange) 90%,
      transparent
    );
  }

  .vline {
    position: absolute;
    width: 1px;
    background: var(--color-orange);
  }
  /* Left bookend (x198): tapers in ~21px above the columns' content top
     (y445 vs y466) — never reaching the top rule — and runs down to the
     bottom spark row. */
  .vline--left {
    left: -1.5rem;
    top: -1.3125rem;
    bottom: calc(-1 * var(--decor-drop));
    background: linear-gradient(
      to bottom,
      transparent,
      var(--color-orange) 2rem
    );
  }
  /* Right bookend (x1723): from its spark on the top rule down 275px
     (y372 to y647), tapering out well above the bottom row — the only
     vertical with no bottom spark. */
  .vline--right {
    left: calc(100% + 1.5rem);
    top: calc(-1 * var(--decor-rise));
    height: 17.1875rem;
    background: linear-gradient(
      to bottom,
      var(--color-orange) calc(100% - 3rem),
      transparent
    );
  }

  /* Spark sizes from the screenshot: large ~43px (the Hero's 2.7rem spark
     size), the lone small one at the col1/2 divider top ~20px, and the tiny
     one ending the col3/4 divider ~7px. */
  .dspark {
    position: absolute;
    transform: translate(-50%, -50%);
  }
  .dspark--lg {
    width: 2.7rem;
    height: 2.7rem;
  }
  .dspark--sm {
    width: 1.25rem;
    height: 1.25rem;
  }
  .dspark--xs {
    width: 0.5rem;
    height: 0.5rem;
  }
  .dspark--top-d1 {
    left: calc(25% - 0.75rem);
    top: calc(-1 * var(--decor-rise));
  }
  .dspark--top-d3 {
    left: calc(75% + 0.75rem);
    top: calc(-1 * var(--decor-rise));
  }
  .dspark--top-right {
    left: calc(100% + 1.5rem);
    top: calc(-1 * var(--decor-rise));
  }
  .dspark--bot-left {
    left: -1.5rem;
    top: calc(100% + var(--decor-drop));
  }
  .dspark--bot-d1 {
    left: calc(25% - 0.75rem);
    top: calc(100% + var(--decor-drop));
  }
  .dspark--bot-d2 {
    left: 50%;
    top: calc(100% + var(--decor-drop));
  }
  .dspark--bot-d3 {
    left: calc(75% + 0.75rem);
    top: calc(100% + var(--decor-drop));
  }

  .number {
    margin: 0 0 0.5rem;
    font-family: var(--font-sans);
    /* No text node (outlined, like the body copy) — screenshot cap-height
       (16px) is a near-match for the body copy's 15px "V" at 20px, so sized
       the same as .body rather than stepping down further. */
    font-size: 1.0625rem; /* 17px — reduced from 20px per user directive 2026-07-06 */
    /* Navy, not the site's usual gray eyebrow — sampled (30,30,60) off the
       screenshot, an exact match for --color-ink-alt. */
    color: var(--color-ink-alt);
  }

  .title {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    /* Was 35.23px (2.2019rem), node 1:538/1:539 (col 1) and 1:628/1:629
       (col 2) — real text nodes, and (unlike the eyebrow) genuinely serif
       on inspection of the screenshot. Line-height measured off the
       two-line title's line-top gap (42px / 35.23px = 1.19). Reduced to
       28px per user directive 2026-07-06 (desktop type felt oversized on
       sub-1920 laptops) — line-height ratio unchanged. */
    font-size: 1.75rem;
    line-height: 1.2;
    font-weight: 400;
    color: var(--color-ink-alt);
  }

  .body {
    margin: 0;
    font-family: var(--font-sans);
    /* Outlined vectors, no text node. Screenshot cap-height ("V" of
       "Validate" ~15px) matches the site's other 20px secondary text
       (Hero .lede, Pillars .card-body) exactly, including the 1.4
       line-height (measured line-top gap ~29px / 20px = 1.45). Reduced to
       17px per user directive 2026-07-06. */
    font-size: 1.0625rem;
    line-height: 1.4;
    color: var(--color-gray);
  }

  @media (max-width: 1023.98px) {
    h2 {
      font-size: clamp(2.25rem, 6vw, 3.25rem);
    }
    .intro {
      max-width: 90%;
    }

    /* .title-break forces "Startups &"/"Founders" and "Academic &"/"R&D
       Institutions" onto 2 lines to match Figma's desktop 4-column layout
       (node 1:377 — confirmed via separate text nodes 1:538/1:539 at
       different y-offsets, a real 2-line title, not a coincidental wrap).
       Below 1024px the columns get much wider (2-col, then 1-col), so the
       forced break reads as unnecessary/inconsistent next to the other 2
       titles' natural single-line fit at those widths (confirmed visually)
       — drop it here and let all 4 titles wrap naturally like they did
       before this fix. */
    .title-break {
      display: none;
    }

    /* Responsive rule (brief step 2): 2x2 grid below 1024. The desktop decor
       overlay (rules, bookends, pill-anchored geometry) assumes the pill
       sits directly above a single 4-column row, so it is hidden here;
       dividers revert to spanning just their own column's height with the
       uniform per-column spark pair. Column 2/3 are no longer horizontally
       adjacent (col 2 top-right, col 3 bottom-left), so that divider is
       dropped; the col1/col2 and col3/col4 dividers stay, each still
       separating two columns sharing a row. */
    .decor {
      display: none;
    }
    .columns {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 3rem;
    }
    .column:not(:first-child)::before {
      top: 0;
      bottom: 0;
      background: var(--color-orange);
    }
    .divider-spark {
      display: block;
    }
    .column:nth-child(3)::before,
    .column:nth-child(3) .divider-spark {
      display: none;
    }
  }

  /* Dev feedback ("text formatting", arrow at the H2): at narrow phone
     widths "story." was orphaning alone below "in India's energy" (and
     "builder" similarly below "Built for every"), since this heading's 2
     `.line.reveal-line` spans are unconditionally forced one-per-row
     (h2 .line above). Same fix and same reasoning as Scale.astro's
     analogous override (see that file's comment for the full derivation);
     summary of the 3 deviations from the reviewed plan, all verified live:
       1. `.line` alone becoming inline doesn't reflow the nested
          `.reveal-line-box`/`.reveal-line-text` (shared global.css,
          `display: inline-block`) — an inline-block's shrink-to-fit width
          claims the full available row once its content is wider than
          that space, leaving no real room for a sibling even on the
          wrapped box's otherwise-mostly-empty last line. All 3 nesting
          levels are flattened to plain `inline` here, scoped locally to
          this component (Astro's per-component style scoping keeps this
          off Hero.astro/Pillars.astro's own instances of the same shared
          classes).
       2. This is its OWN dedicated breakpoint, NOT the shared
          "below 1024px" one Scale.astro also uses, and NOT this file's own
          639.98px columns breakpoint: this heading's per-line wrap
          boundary was measured live at exactly 400px-wraps/405px-doesn't
          (font-size is at its clamped floor across this whole span, so the
          boundary is driven by container width, not font scaling) — well
          short of both of this file's other breakpoints. Reusing either
          would apply the join logic into a range where each line already
          renders cleanly on its own single row, which (as found in
          Scale.astro) creates a NEW single-word orphan instead of fixing
          the original one.
       3. `text-wrap: balance` on the h2 is still required, same as
          Scale.astro, to avoid the reflow itself producing a new orphan
          ("builder" landing alone) at some width within the fixed range.
          DEVIATION from Scale.astro's own fix, though: Scale's line 2
          ("every venture.", 2 words) was short enough to keep together
          with `white-space: nowrap` on the whole span without ever
          overflowing its container. Verified live that this file's line 2
          ("in India’s energy story.", 5 words) is NOT — even alone, it
          wraps to 2 rows within these same viewports (320-400px), so
          forcing the whole phrase to `nowrap` just pushed it past the
          container edge instead of wrapping (visibly clipped/cut off in
          the screenshot). Used the standard editorial fix instead: an
          `&nbsp;` between just the last two words ("energy" / "story.",
          see the markup above) so only THAT pair can't be split across a
          line break — "in India's" is still free to wrap normally, and
          there's no full-phrase overflow risk.
     Safe re: the star: `.reveal-star` is already `display: none` below
     1024px sitewide, so there's no star-positioning concern either way.
     Selector is this file's own `.line` class (NOT `.reveal-line` as in
     Scale.astro — different local layout-class name, same shared
     `.reveal-line` the star-stagger keys off). */
  @media (max-width: 404.98px) {
    h2 .line,
    h2 .reveal-line-box,
    h2 .reveal-line-text {
      display: inline;
    }
    h2 {
      text-wrap: balance;
    }
  }

  @media (max-width: 639.98px) {
    /* Single column: no two columns are adjacent, so the per-column
       hairline drops out entirely (replaced below by one continuous rail)
       — but the sparks are kept, repurposed as boundary markers along that
       rail rather than hidden outright (dev-feedback: rail + sparkle
       instead of hiding). */
    .columns {
      grid-template-columns: 1fr;
    }
    .column::before {
      display: none;
    }
    .column {
      /* Clears the rail + spark, which sit at left: -0.75rem (see below). */
      padding-left: 1.25rem;
    }
    .columns-rail {
      display: block;
      position: absolute;
      top: 0;
      bottom: 0;
      left: -0.75rem;
      width: 1px;
      background: var(--color-orange);
    }
    /* Keep only the top spark per column as the 3 boundary markers (one
       per column transition) — hiding the bottom twin avoids a doubled
       icon at each boundary and a dangling 4th spark below the last
       column. */
    .divider-spark--bottom {
      display: none;
    }
    /* Reposition the kept top spark from the base rule's left: -1.5rem
       (matched to the desktop 3rem column gap) to left: -0.75rem here —
       DEVIATION from the reviewed plan, which said to keep it at -1.5rem.
       Verified live: `.divider-spark` uses `transform: translate(-50%,
       -50%)` (center-anchored, unlike Scale.astro's edge-anchored
       .stat-spark), and at these widths --container-gutter (clamped to a
       1.25rem/20px floor) is narrower than 1.5rem/24px — so at -1.5rem the
       spark's bounding box measured ~73% clipped off-screen (left: -12.8px
       of a 17.6px-wide box) and the rail itself measured 4px off-screen.
       -0.75rem keeps both fully on-screen at the narrowest supported width
       (320px) with a small margin, and doubles as the .column padding
       reference above so the rail/spark still align with each other. */
    .divider-spark--top {
      left: -0.75rem;
    }
    /* Required override, selector matches the reviewed plan, but its
       target column-label is CORRECTED here: the plan's prose said this
