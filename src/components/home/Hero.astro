---
import HeroCurves from "../../assets/home/hero-curves.svg";
import SparkOrange from "../../assets/home/spark-orange.svg";
import ScrollArrow from "../../assets/home/scroll-arrow.svg";
import LineRevealStar from "../../assets/home/line-reveal-star.svg";
---

<section class="hero">
  <div class="orbit" aria-hidden="true">
    <HeroCurves class="curves" />
    <SparkOrange class="spark spark-a" />
    <SparkOrange class="spark spark-b" />
    <SparkOrange class="spark spark-c" />
  </div>

  <div class="hero-inner">
    <p class="eyebrow">Multiply · Collaborate · Create</p>
    <div class="underline" aria-hidden="true"></div>

    <h1>
      <span class="line line-1">
        <span class="line-box">
          <span class="line-text">Where ideas <span class="accent">multiply</span>,</span>
          <LineRevealStar class="line-star" aria-hidden="true" />
        </span>
      </span>
      <span class="line line-2">
        <span class="line-box">
          <span class="line-text">industries <span class="accent">collaborate</span> and</span>
          <LineRevealStar class="line-star" aria-hidden="true" />
        </span>
      </span>
      <span class="line line-3">
        <span class="line-box">
          <span class="line-text"
            >visionaries <span class="accent">create</span> energy ventures.</span
          >
          <LineRevealStar class="line-star" aria-hidden="true" />
        </span>
      </span>
    </h1>

    <p class="lede">
      India's flagship energy innovation platform, uniting seven of the
      country's largest energy majors to carry ventures from the lab bench to
      industrial scale.
    </p>

    <ScrollArrow class="scroll" aria-hidden="true" />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--color-cream);
    padding-block: 6rem 4rem;
  }
  @media (min-width: 1024px) {
    .hero {
      /* Approximates the design's hero band (page y110.65 header end to
         y1143.56 sponsor-strip start ~= 1033px = 64.5rem at the 1920px
         reference canvas: 1033/1920 = 53.75vw).
         Final-review fix (whole-branch review): a flat 64.5rem for every
         ≥1024px width left a large dead cream band between the chevron and
         the sponsor strip at 1024–1366px, because `.curves` scales its
         *height* down with viewport width (100% width, height:auto) while
         this fixed min-height did not. Using `53.75vw` as the fluid branch
         reproduces 64.5rem exactly at 1920px (53.75vw × 1920 = 1032.6px,
         which the 64.5rem cap then rounds to) and scales it down
         proportionately below that, closing the gap at 1024–1366px; the
         64.5rem cap keeps ≥1920px identical to before (unauthorized to
         change here). 40rem floor is a sanity backstop, not expected to
         bind at any ≥1024px width. */
      min-height: clamp(40rem, 53.75vw, 64.5rem);
    }
  }

  /* Curves + sparks: decorative, absolutely positioned behind copy.
     Positions are percentages of the curves SVG's own 1920x1153 box (Figma
     node 1:188), so sparks stay locked to the curve intersections at any
     viewport width — this also satisfies the "curves scale with section
     (allow crop)" responsive rule without extra breakpoints. */
  .orbit {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .curves {
    display: block;
    width: 100%;
    height: auto;
  }
  .spark {
    position: absolute;
    transform: translate(-50%, -50%);
  }
  .spark-a {
    left: 5.17%;
    top: 66.88%;
    width: 1.9rem;
    height: 1.9rem;
  }
  .spark-b {
    left: 13.66%;
    top: 74.73%;
    width: 1.9rem;
    height: 1.9rem;
  }
  .spark-c {
    left: 80.63%;
    top: 26.98%;
    width: 2.7rem;
    height: 2.7rem;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 55.4375rem; /* 887px, Figma 1:23 HEADLINE column */
    margin-inline: auto;
    /* Deliberately NOT the sitewide .container utility (the brief's "Consumes: .container"):
       its clamp(1.25rem, 4vw, 5rem) gutters eat into the fixed 887px column at desktop widths
       and wrap the H1 onto a 4th line. Fixed 1.25rem is narrow-viewport safety only. */
    padding-inline: 1.25rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.25rem; /* 20px */
    /* Real page eyebrow is navy, verified against the page export (1:995/1:997) —
       corrects the plan/trial-frame value #676767 (trial node 1:26). */
    color: var(--color-ink-alt);
  }
  .underline {
    width: 8.15625rem; /* 130.5px, Figma 1:25 */
    height: 1px;
    margin: 1rem auto 3rem;
    background: #000; /* one-off literal, sampled from the real page (1:996) — not a token */
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 3.25rem; /* 52px */
    line-height: 1.173; /* 61/52 */
    color: var(--color-ink-alt);
  }
  h1 .line {
    display: block;
  }
  h1 .accent {
    /* Real page accent fill is #f37d2c per node 1:1876 — corrects the trial frame's #e58341. */
    color: var(--color-orange);
  }

  /* Entrance animation: star-led line reveal, reference video (Canva) +
     star asset from Figma node 8:29 (navy 4-point sparkle, fill #1e1e3c,
     exported to src/assets/home/line-reveal-star.svg). Three constants
     drive the whole sequence — LINE_STAGGER (0.35s, gap between each line's
     own start), LINE_DURATION (1.2s, each line's own timeline), and the
     75%-keyframe split within LINE_DURATION (text/star finish moving at 90%
     of 1.2s = ~1.08s in, then hold/linger for the remaining ~10% before the
     star fades) — chosen to reproduce the reference's "lines overlap,
     staggered, not strictly sequential" cascade and the star's brief pause
     before fading once its line completes.
     `.line-box` (inline-block) exists so `.line-text`'s clip-path and
     `.line-star`'s left-position percentages are relative to the ACTUAL
     rendered text width, not `.line`'s full-width block box (`.line` stays
     block only to force each line onto its own row + inherit the section's
     centered text-align). `.line-star` is a SIBLING of `.line-text`, not a
     child — a descendant would be clipped by the same clip-path and never
     show at all. */
  .line-box {
    position: relative;
    display: inline-block;
  }
  .line-text {
    display: inline-block;
    clip-path: inset(0 100% 0 0);
    animation: line-reveal 1.2s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }
  .line-1 .line-text {
    animation-delay: 0s;
  }
  .line-2 .line-text {
    animation-delay: 0.35s;
  }
  .line-3 .line-text {
    animation-delay: 0.7s;
  }
  @keyframes line-reveal {
    0% {
      clip-path: inset(0 100% 0 0);
    }
    90% {
      clip-path: inset(0 0% 0 0);
    }
    100% {
      clip-path: inset(0 0% 0 0);
    }
  }

  .line-star {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-50%, -50%);
    opacity: 0;
    pointer-events: none;
    animation: star-travel 1.2s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }
  /* Sizes decrease line-to-line, matching the reference video (line 1's
     star reads noticeably larger than line 3's) — approximated by eye from
     the captured frames, not a measured Figma value. */
  .line-1 .line-star {
    width: 2.6rem;
    height: 2.6rem;
    animation-delay: 0s;
  }
  .line-2 .line-star {
    width: 2.1rem;
    height: 2.1rem;
    animation-delay: 0.35s;
  }
  .line-3 .line-star {
    width: 1.7rem;
    height: 1.7rem;
    animation-delay: 0.7s;
  }
  @keyframes star-travel {
    0% {
      left: 0%;
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    90% {
      left: 100%;
      opacity: 1;
    }
    100% {
      left: 100%;
      opacity: 0;
    }
  }

  /* Accent word settles into its final orange slightly AFTER the clip
     boundary passes it (visible in the reference as "multiply" still pale
     just after being revealed) — a longer-than-reveal duration on the same
     delay does this without needing to know the accent word's exact
     position within its line. */
  .accent {
    animation: accent-settle 1.4s ease forwards;
  }
  .line-1 .accent {
    animation-delay: 0s;
  }
  .line-2 .accent {
    animation-delay: 0.35s;
  }
  .line-3 .accent {
    animation-delay: 0.7s;
  }
  @keyframes accent-settle {
    0% {
      color: #f0c9a3; /* one-off literal: an approximated pale/washed-out tint of --color-orange for the reveal effect, not a design token */
    }
    100% {
      color: var(--color-orange);
    }
  }

  .lede {
    max-width: 38.8125rem; /* 621px */
    margin: 1.5rem auto 0;
    font-family: var(--font-sans);
    font-size: 1.25rem; /* 20px */
    line-height: 1.4; /* 28/20 */
    /* Final-review fix: the plan's own transcription of the trial-frame
       paragraph node (1:27, native text — the real page's own paragraph is
       an outlined vector with no fill data to read) is `#1e1e3a`, i.e.
       --color-ink, not --color-ink-alt (#1e1e3c). The two are visually
       near-identical (one value off in the blue channel); this corrects an
       undocumented token slip to match that node exactly. */
    color: var(--color-ink);
    /* Rises + fades in once line 3 finishes revealing (delay 0.7s + 90% of
       its own 1.2s duration = 1.78s) — the reference shows the paragraph
       starting only after the H1 completes, not concurrently. */
    opacity: 0;
    transform: translateY(1.25rem);
    animation: lede-rise 0.8s ease forwards;
    animation-delay: 1.78s;
  }
  @keyframes lede-rise {
    0% {
      opacity: 0;
      transform: translateY(1.25rem);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .scroll {
    display: block;
    margin: 3rem auto 0;
  }

  /* First animation on the site — no existing prefers-reduced-motion
     convention to follow, so this establishes the baseline: show the final
     state immediately, no motion. */
  @media (prefers-reduced-motion: reduce) {
    .line-text,
    .line-star,
    .accent,
    .lede {
      animation: none !important;
    }
    .line-text {
      clip-path: none;
    }
    .line-star {
      display: none;
    }
    .accent {
      color: var(--color-orange);
    }
    .lede {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 1023.98px) {
    h1 {
      font-size: clamp(2.1rem, 5vw, 3.25rem);
    }
    .lede {
      max-width: 90%;
    }

    /* Sanctioned adaptation: below the H1's own fixed-52px breakpoint, a
       line can wrap onto multiple visual rows (clamp() font-size + a
       narrower viewport), and a single clip-path on `.line-text` would clip
       against its whole (multi-row) box, not per visual row — same category
       of "desktop-only composition, drop for narrow viewports" adaptation
       already used elsewhere (e.g. Portfolio Hero hides its sparks below
       1024px). Falls back to a plain staggered fade + rise, no star. */
    .line-text {
      clip-path: none;
      opacity: 0;
      transform: translateY(0.75rem);
      animation: line-fade 0.7s ease forwards;
    }
    .line-1 .line-text {
      animation-delay: 0s;
    }
    .line-2 .line-text {
      animation-delay: 0.2s;
    }
    .line-3 .line-text {
      animation-delay: 0.4s;
    }
    .line-star {
      display: none;
    }
    .accent {
      animation: none;
      color: var(--color-orange);
    }
    .lede {
      animation-delay: 1.1s; /* line 3 delay (0.4s) + its fade duration (0.7s) */
    }

    @keyframes line-fade {
      0% {
        opacity: 0;
        transform: translateY(0.75rem);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>
