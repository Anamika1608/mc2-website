---
import HeroCurves from "../../assets/home/hero-curves.svg";
import SparkOrange from "../../assets/home/spark-orange.svg";
import ScrollArrow from "../../assets/home/scroll-arrow.svg";
import RevealStar from "../../assets/shared/reveal-star.svg";
---

<section class="hero">
  <div class="orbit" aria-hidden="true">
    <HeroCurves class="curves" />
    <SparkOrange class="spark spark-a" />
    <SparkOrange class="spark spark-b" />
    <SparkOrange class="spark spark-c" />
  </div>

  <div class="hero-inner reveal">
    <p class="eyebrow">Multiply · Collaborate · Create</p>
    <div class="underline" aria-hidden="true"></div>

    <h1>
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">Where ideas <span class="accent">multiply</span>,</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">institutes <span class="accent">collaborate</span> and</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
      <span class="line reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text"
            >visionaries <span class="accent">create</span> energy ventures.</span
          >
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </h1>

    <p class="lede reveal-rise reveal-rise--after-3-lines">
      India's flagship energy innovation platform, uniting seven of the
      country's largest energy majors to carry ventures from the lab bench to
      industrial scale.
    </p>

    <button type="button" class="scroll" aria-label="Scroll to next section">
      <ScrollArrow aria-hidden="true" />
    </button>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--color-cream);
    padding-block: 6rem 4rem;
  }
  @media (min-width: 1024px) {
    .hero {
      /* Approximates the design's hero band (page y110.65 header end to
         y1143.56 sponsor-strip start ~= 1033px = 64.5rem at the 1920px
         reference canvas: 1033/1920 = 53.75vw).
         Final-review fix (whole-branch review): a flat 64.5rem for every
         ≥1024px width left a large dead cream band between the chevron and
         the sponsor strip at 1024–1366px, because `.curves` scales its
         *height* down with viewport width (100% width, height:auto) while
         this fixed min-height did not. Using `53.75vw` as the fluid branch
         reproduces 64.5rem exactly at 1920px (53.75vw × 1920 = 1032.6px,
         which the 64.5rem cap then rounds to) and scales it down
         proportionately below that, closing the gap at 1024–1366px; the
         64.5rem cap keeps ≥1920px identical to before (unauthorized to
         change here). 40rem floor is a sanity backstop, not expected to
         bind at any ≥1024px width. */
      min-height: clamp(40rem, 53.75vw, 64.5rem);
    }
  }

  /* Curves + sparks: decorative, absolutely positioned behind copy.
     Positions are percentages of the curves SVG's own 1920x1153 box (Figma
     node 1:188), so sparks stay locked to the curve intersections at any
     viewport width — this also satisfies the "curves scale with section
     (allow crop)" responsive rule without extra breakpoints. */
  .orbit {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .curves {
    display: block;
    width: 100%;
    height: auto;
  }
  .spark {
    position: absolute;
    transform: translate(-50%, -50%);
  }
  /* Fix (mobile decor bug, 2026-07-09 review): sizes were fixed rem
     (1.9rem/1.9rem, 2.7rem/2.7rem) — unlike .curves (width:100%,
     height:auto) and TeamHero's own .right-spark precedent, these did NOT
     shrink with .orbit at narrower viewports, so as the curve linework
     shrank toward mobile widths the sparks stayed pinned at full desktop
     pixel size: curves fade to near-invisible hairlines while the sparks
     read as oversized dots floating with nothing under them. Converted to
     percentages of .orbit's own width (spark-orange.svg is a 50x50 square
     viewBox, confirmed via its own <svg> tag, so width:X%/height:auto
     reproduces the exact square at any scale) — this keeps the sparks
     locked to the curve's own scale at any viewport, matching TeamHero's
     convention, with no separate mobile-only override needed. */
  .spark-a {
    left: 5.17%;
    top: 66.88%;
    width: 1.583%; /* was 1.9rem — (1.9rem×16px) / (120rem×16px, the 1920px reference width) × 100 */
    height: auto;
  }
  .spark-b {
    left: 13.66%;
    top: 74.73%;
    width: 1.583%; /* same derivation as spark-a — both were 1.9rem */
    height: auto;
  }
  .spark-c {
    left: 80.63%;
    top: 26.98%;
    width: 2.25%; /* was 2.7rem — (2.7rem×16px) / (120rem×16px) × 100 */
    height: auto;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 55.4375rem; /* 887px, Figma 1:23 HEADLINE column */
    margin-inline: auto;
    /* Deliberately NOT the sitewide .container utility (the brief's "Consumes: .container"):
       its clamp(1.25rem, 4vw, 5rem) gutters eat into the fixed 887px column at desktop widths
       and wrap the H1 onto a 4th line. Fixed 1.25rem is narrow-viewport safety only. */
    padding-inline: 1.25rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-hero-eyebrow); /* 20px */
    /* Real page eyebrow is navy, verified against the page export (1:995/1:997) —
       corrects the plan/trial-frame value #676767 (trial node 1:26). */
    color: var(--color-ink-alt);
  }
  .underline {
    width: 8.15625rem; /* 130.5px, Figma 1:25 */
    height: 1px;
    margin: 1rem auto 3rem;
    background: #000; /* one-off literal, sampled from the real page (1:996) — not a token */
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-hero-h1); /* 52px */
    line-height: var(--text-hero-h1-lh); /* 61/52 */
    color: var(--color-ink-alt);
  }
  h1 .line {
    display: block;
  }
  h1 .accent {
    /* Real page accent fill is #f37d2c per node 1:1876 — corrects the trial frame's #e58341. */
    color: var(--color-orange);
  }

  .lede {
    max-width: 38.8125rem; /* 621px */
    margin: 1.5rem auto 0;
    font-family: var(--font-sans);
    font-size: var(--text-hero-lede); /* 20px */
    line-height: var(--text-hero-lede-lh); /* 28/20 */
    /* Final-review fix: the plan's own transcription of the trial-frame
       paragraph node (1:27, native text — the real page's own paragraph is
       an outlined vector with no fill data to read) is `#1e1e3a`, i.e.
       --color-ink, not --color-ink-alt (#1e1e3c). The two are visually
       near-identical (one value off in the blue channel); this corrects an
       undocumented token slip to match that node exactly. */
    color: var(--color-ink);
    text-align: justify; /* block stays centered via margin auto, only the text's own wrap edges even out */
    text-align-last: center; /* justify's own last line defaults to left even inside this centered block -- explicit center keeps it reading centered like the rest of the paragraph, per direct user feedback 2026-07-09 */
  }

  .scroll {
    display: block;
    margin: 3rem auto 0;
  }

  @media (max-width: 1023.98px) {
    h1 {
      font-size: var(--text-hero-h1-fluid); /* clamp(2.1rem, 5vw, 3.25rem) */
    }
    .lede {
      max-width: 90%;
    }
    /* Fix ("and" stranding, 2026-07-09 review): each of the 3 H1 lines is
       its own hard <span class="line"> block (`h1 .line { display: block }`
       above, needed at desktop so the 3 authored Figma line-breaks hold
       exactly). At mobile widths line 2's own text ("institutes collaborate
       and") is on its own long enough to wrap internally — but its hard
       block boundary means the wrapped remainder can't share a row with
       line 1 or line 3's text, so "and" ends up alone on its own row.
       Switching to `inline` here lets all 3 lines' text reflow together as
       one continuous run, so the browser's own line-breaking naturally
       avoids stranding a single word — this is the same "sanctioned
       adaptation below 1024px" the shared reveal-star system already
       documents for exactly this case (global.css: a line can wrap onto
       multiple visual rows at narrow widths, hence the animation itself
       switches from the desktop clip-path reveal to a plain fade below this
       breakpoint) — compatible, not a new mechanism. A trailing space is
       needed between lines since the hard block boundaries used to supply
       that gap for free; added as a single explicit space in each
       `reveal-line-text` span's own markup would require touching 3 lines
       of JSX-like markup for a purely-visual concern, so it's added here via
       each line's own ::after instead, scoped to this breakpoint only. */
    h1 .line {
      display: inline;
    }
    h1 .line:not(:last-child)::after {
      content: " ";
    }
    /* Considered (2026-07-09 review) and deliberately NOT adding a
       SupportHero-style `.orbit { min-width: Xrem }` "zoom crop" here: tried
       it directly (min-width: 50rem) in a real render at 500/600px and it
       trades away more than it gains — spark-c (the top-right spark) is
       pushed fully off-screen by the wider, left-anchored canvas, which
       contradicts the user's own mobile screenshot (both spark clusters —
       the single top-right one AND the two-spark lower-left cluster —
       visible together, just smaller), and the curve strokes don't read any
       more clearly at that crop factor to justify the loss (an SVG's
       stroke width scales down with its own viewBox regardless of how much
       of the canvas overflow:hidden happens to crop away — only rendering
       .orbit near its full ~120rem desktop physical scale would meaningfully
       thicken the strokes, which stops being a "mobile" treatment at all).
       The .spark-a/b/c percentage-sizing fix above already resolves the
       actual reported bug (sparks were rendering ~3.2x oversized relative
       to the curves — fixed 1.9rem against a curve scaled to ~31% of its
       natural size at a 600px viewport) while keeping both spark clusters
       on-screen, matching the user's own screenshot composition. */
  }

  @media (max-width: 767.98px) {
    /* sitewide paragraph-justify pass: this lede's font-size doesn't shrink below
       1024px (no fluid clamp, unlike the h1), so once the column narrows to ~90%
       of a phone viewport it only fits 2-3 words per justified line — verified via
       Playwright screenshot at 390px, several lines stretched to ugly, oversized
       word-gaps. Reverting to the pre-existing center alignment below this
       breakpoint (matches every other hero's own fallback); justify is kept
       ≥768px, where it renders cleanly (verified at 900/1920px). */
    .lede {
      text-align: center;
    }
  }
</style>
