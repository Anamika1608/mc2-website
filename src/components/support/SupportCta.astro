---
// Figma file u4NLOVKuXUTKULhSn0sAJQ, group 1:20863: H2 1:20865,
// vectorized paragraph inside 1:20864, pills group 1:20981.
import PillButton from "../PillButton.astro";
import RevealStar from "../../assets/shared/reveal-star.svg";
---

<section class="support-cta">
  <div class="container reveal">
    <h2>
      <span class="reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">Build with all of this behind you.</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </h2>
    <p class="lede reveal-rise reveal-rise--after-1-line">
      The first MC<sup>2</sup>+ cohort launches in August 2026, with
      applications opening soon. Bring the technology, and put this support
      stack to work.
    </p>

    <div class="ctas">
      <PillButton label="Get in touch" href="/contact" variant="filled" />
      <PillButton label="Explore initiatives" href="/initiatives" variant="filled" />
    </div>
  </div>
</section>

<style>
  .support-cta {
    background: var(--color-cream);
    padding-block: 0 7.82rem;
    text-align: center;
  }

  h2 {
    margin: 0 0 0.7rem;
    font-family: var(--font-display);
    font-size: 4.0625rem; /* 65px, node 1:20865 */
    font-weight: 400;
    line-height: 1.3;
    color: #1e1e3e;
  }

  .lede {
    max-width: 53rem;
    margin: 0 auto 2.65rem;
    font-family: var(--font-sans);
    font-size: 1.23rem;
    line-height: 1.25;
    color: #949494;
  }

  .lede sup {
    font-size: 0.58em;
    line-height: 0;
  }

  .ctas {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.6rem;
  }

  @media (max-width: 1023.98px) {
    h2 {
      font-size: clamp(2.2rem, 6vw, 4.0625rem);
    }
  }

  @media (max-width: 559.98px) {
    .ctas {
      flex-direction: column;
      gap: 1.25rem;
    }
  }
</style>
