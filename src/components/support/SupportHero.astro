---
// Figma file u4NLOVKuXUTKULhSn0sAJQ, frame 1:19224. Hero source nodes:
// orbit art 1:21030, eyebrow 1:21041, H1 1:21045/1:21046/1:21047,
// vectorized lede 1:21048, scroll cue inside 1:21039.
import { Image } from "astro:assets";
import HeroOrbit from "../../assets/support/hero-orbit.png";
import ScrollArrow from "../../assets/about/scroll-arrow.svg";
import RevealStar from "../../assets/shared/reveal-star.svg";
---

<section class="support-hero">
  <Image
    src={HeroOrbit}
    alt=""
    class="orbit"
    loading="eager"
    widths={[960, 1440, 1920]}
    sizes="100vw"
  />

  <div class="hero-inner reveal">
    <p class="eyebrow">SUPPORT</p>
    <div class="rule" aria-hidden="true"></div>

    <h1>
      <span class="reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">Everything an</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
      <span class="reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">energy venture needs,</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
      <span class="reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text"
            ><span class="accent">under one roof</span><span class="period">.</span></span
          >
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </h1>

    <p class="lede reveal-rise reveal-rise--after-3-lines">
      Capital is rarely the whole problem. MC<sup>2</sup>+ pairs funding with
      the expertise, infrastructure and market access that energy hardware
      actually needs to reach industrial scale.
    </p>

    <ScrollArrow class="scroll" aria-hidden="true" />
  </div>
</section>

<style>
  .support-hero {
    position: relative;
    overflow: hidden;
    background: var(--color-cream);
    padding-block: 6rem 0;
  }

  @media (min-width: 1024px) {
    .support-hero {
      /* Was 62rem (992px), then briefly 61.5rem (984px, the minimum that
         kept .orbit's full ~984px-tall PNG uncropped) — but that only
         closed 8px of the ~390px gap below the scroll arrow, essentially
         invisible. Per user directive, accepting orbit cropping to actually
         close the gap: content (chevron) bottom sits at 601px from hero's
         own top, so 38.8rem (620.8px) gives a small buffer past that,
         matching the convention used for the About/Contact hero fixes. The
         orbit's own bottom portion (its circle+spark) is now clipped by
         .hero's overflow:hidden. */
      min-height: 38.8rem;
    }
  }

  .orbit {
    position: absolute;
    top: 0;
    left: 50%;
    z-index: 0;
    width: 100%;
    min-width: 120rem;
    height: auto;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 58rem;
    margin-inline: auto;
    padding-inline: 1.25rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-hero-eyebrow); /* 27.07px, node 1:21041 — normalized to home hero scale per user directive 2026-07-06 */
    letter-spacing: 0.25em;
    color: #949494;
  }

  .rule {
    width: 11.7656rem; /* 188.25px, node 1:21040 */
    height: 1px;
    margin: 2.81rem auto 1.73rem;
    background: #000;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-hero-h1); /* 80px, nodes 1:21045-1:21047 — normalized to home hero scale per user directive 2026-07-06 */
    font-weight: 400;
    line-height: var(--text-hero-h1-lh); /* was 1.095 — normalized to home hero scale per user directive 2026-07-06 */
    color: #1e1e3e;
  }

  /* Scoped to .reveal-line specifically, not a bare `h1 span` tag selector:
     the latter would also match the new .reveal-line-box/.reveal-line-text
     spans nested inside (Astro's scoping attribute makes component-local
     rules beat the shared global.css rules at equal specificity), clobbering
     their required inline-block display. */
  h1 .reveal-line {
    display: block;
    white-space: nowrap;
  }

  h1 .accent,
  h1 .period {
    display: inline;
  }

  h1 .accent {
    color: var(--color-orange-bright);
  }

  h1 .period {
    color: #1e1e3e;
  }

  .lede {
    max-width: 49.03rem; /* 784.52px, node 1:21048 */
    margin: 1.23rem auto 0;
    font-family: var(--font-sans);
    font-size: var(--text-hero-lede); /* vectorized Sora paragraph, same derived scale as About/Team hero — normalized to home hero scale per user directive 2026-07-06 */
    line-height: var(--text-hero-lede-lh); /* was 1.31 — normalized to home hero scale per user directive 2026-07-06 */
    color: #1e1e3e;
  }

  .lede sup {
    /* Relative to the lede's own font-size (em, not a hero token): at the
       normalized 20px lede this renders 11.6px (0.58 × 20px), down from
       ~17.98px (0.58 × 31px) pre-normalization — verified legible (the "2"
       superscript in "MC2+") in the after-render at all 4 widths. */
    font-size: 0.58em;
    line-height: 0;
  }

  .scroll {
    display: block;
    /* Bottom margin added so the next section (support-stack) doesn't sit
       right on top of the chevron — was 0, giving only ~19.6px of gap after
       the hero's min-height was floored to close the earlier dead-space
       bug. .support-hero uses min-height (a floor, not a cap), so this
       margin grows the hero's own rendered height to fit, rather than
       getting clipped. Doubled from 2rem per user directive. */
    margin: 6.12rem auto 4rem;
  }

  @media (max-width: 1023.98px) {
    .support-hero {
      min-height: 48rem;
    }

    .orbit {
      min-width: 90rem;
    }

    h1 {
      font-size: var(--text-hero-h1-fluid); /* was clamp(2.65rem, 7vw, 5rem) — normalized to home hero scale per user directive 2026-07-06 */
    }

    h1 .reveal-line {
      white-space: normal;
    }

    .lede {
      max-width: 90%;
      /* was clamp(1.2rem, 3vw, 1.9375rem) — fixed to the hero lede token,
         matching Home's <1024 lede behavior (keeps the token size, only
         constrains width) — normalized to home hero scale per user
         directive 2026-07-06 */
      font-size: var(--text-hero-lede);
    }
  }
</style>
