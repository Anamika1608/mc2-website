  .line-one {
    /* Capital-closing. Was 41.8rem. */
    left: 0;
    right: 0;
    top: 53.29rem;
  }

  .line-two {
    /* Expertise-closing. Was 87.9rem. */
    left: 3.5rem;
    right: 1.5rem;
    top: 89.24rem;
  }

  .line-four {
    /* Infrastructure-closing — newly added, this card had no closing line
       before. Reuses .line-one's full-width style since Infrastructure
       shares Capital's card-left/art-right layout.
       left was 0, then 9.95rem (trimmed to align with .line-left's
       crossing) — now matched exactly to .line-two's own left (3.5rem) per
       user request, so the two closing lines above/below this card share
       the same left edge. Still comfortably left of .line-left's x
       (9.95rem) so that crossing/spark-m is unaffected. */
    left: 3.5rem;
    right: 0;
    top: 125.18rem;
  }

  .line-three {
    /* Piloting-closing (this is the line the user originally flagged).
