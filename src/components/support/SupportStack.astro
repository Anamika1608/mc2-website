---
// Figma file u4NLOVKuXUTKULhSn0sAJQ, frame 1:19224. Support-stack source:
// paired card groups 1:19227 and 1:19947, illustrations 1:20698 / 1:20756 /
// 1:20788 / 1:20844. Body copy is vectorized in Figma, transcribed from the
// native 1920x4790 screenshot saved during context gathering.
import { Image } from "astro:assets";
import SparkOrange from "../../assets/about/spark-orange.svg";
import CapitalArt from "../../assets/support/capital-art.png";
import ExpertiseArt from "../../assets/support/expertise-art.png";
import InfrastructureArt from "../../assets/support/infrastructure-art.png";
import PilotingArt from "../../assets/support/piloting-art.png";

// Each card's own decorative group (2 vertical lines, 3 horizontal lines, 4
// sparks) re-derived directly from Figma's actual node tree (fileKey
// u4NLOVKuXUTKULhSn0sAJQ, node 1:19224) via get_metadata, walked as real
// parent/child XML (not bbox-matched -- the 4 card containers overlap in
// absolute space, which gives false matches). Each card is an INDEPENDENT
// decorative group built from the same reusable template, not a shared
// page-spanning line system -- they only look continuous because the
// template's relative offsets happen to align between adjacent cards.
// `deco.x/y` = this card's own container origin (matches its
// `.support-card-*` position exactly). `deco.h` = container height (63.281rem
// for all except Piloting's 60.156rem, since it's the last card). `deco.vbTop`
// / `deco.vbH` = the shorter, left-hand vertical line's own top/height (a
// per-card exception besides h-b/container-height/small-c-x below).
// `deco.hbX` / `deco.hbW` = the short line above the eyebrow, whose x/width
// vary by card. `deco.smallCX` = the small spark paired with that short line
// -- for 3 of the 4 cards it sits on the RIGHT (at the tall vertical), but
// Infrastructure's actual Figma data has it on the LEFT (at the short
// vertical, matching its own h-b, which is also mirrored to the left) --
// confirmed by re-checking each card's own Figma screenshot individually
// after an initial pass wrongly assumed this position was uniform. All other
// template values (the tall vertical, the closing line, the
// subtitle-underline line, the other 3 spark sizes/positions) are identical
// across all 4 cards and live directly in the shared CSS below, not
// duplicated here.
const CARDS = [
  {
    key: "capital",
    eyebrow: "01 | WHAT WE FUND",
    title: "Capital",
    subtitle: "Grants, seed and scale-up",
    intro:
      "Structured access to seed funding for early validation and scale-up capital for ventures demonstrating commercial traction in the energy and industrial sector.",
    bullets: [
      "Seed grants for proof-of-concept and prototype stages",
      "Scale-up equity for ventures with demonstrated traction",
      "Warm introductions to co-investors and strategic partners",
      "Non-dilutive grants for specific technology challenges",
    ],
    deco: { x: 0, y: 0, h: 63.281, vbTop: 9.583, vbH: 48.584, hbX: 29.83, hbW: 30.616, smallCX: 55.257 },
  },
  {
    key: "expertise",
    eyebrow: "02 | WHO YOU WORK WITH",
    title: "Expertise",
    subtitle: "Mentorship and research partnerships",
    intro:
      "Deep mentorship and research partnerships with premier Indian and global institutions, bringing domain knowledge that shortens the path from lab to commercial deployment.",
    bullets: [
      "Partnerships with IITs, IIMs, CSIR labs and global universities",
      "Mentors from senior technical and commercial teams",
      "Access to global energy-transition research networks",
      "Regulatory guidance and policy navigation support",
    ],
    deco: { x: 46.006, y: 35.951, h: 63.281, vbTop: 9.583, vbH: 48.584, hbX: 26.08, hbW: 34.366, smallCX: 55.257 },
  },
  {
    key: "infrastructure",
    eyebrow: "03 | WHERE YOU BUILD",
    title: "Infrastructure",
    subtitle: "Labs, rigs and workspace",
    intro:
      "Shared access to world-class R&D laboratories, testing rigs, fabrication workshops and technical facilities across energy-major sites spanning multiple cities nationwide.",
    bullets: [
      "Lab and testing facility access at energy-major R&D centres",
      "Shared incubation workspace across multiple cities",
      "Technical equipment and safety-certified environments",
      "Storage, fabrication and prototyping infrastructure",
    ],
    deco: { x: 0, y: 71.894, h: 63.281, vbTop: 0.324, vbH: 57.842, hbX: 4.065, hbW: 30.616, smallCX: 9.261 },
  },
  {
    key: "piloting",
    eyebrow: "04 | HOW YOU PILOT",
    title: "Piloting Opportunities",
    subtitle: "Field pilots and procurement",
    intro:
      "Real-world deployment access at operating energy-major sites including refineries, pipelines and terminals to test, iterate and validate technology at industrial scale.",
    bullets: [
      "First-of-a-kind field pilots at refineries, terminals and gas grids",
      "Structured problem statements from energy-major technology teams",
      "Fast-tracked procurement pathways for successful pilots",
      "Access to operating assets across multiple geographies",
    ],
    deco: { x: 46.006, y: 107.845, h: 60.156, vbTop: 9.583, vbH: 49.834, hbX: 26.08, hbW: 34.366, smallCX: 55.257 },
  },
];
---

<section class="support-stack" aria-labelledby="support-stack-title">
  <h2 id="support-stack-title" class="sr-only">The MC²+ support stack</h2>

  <div class="stage" data-support-stage>
    <div class="stage-artboard" data-support-artboard>
      {CARDS.map((card) => (
        <div
          class="card-deco"
          style={`--deco-x:${card.deco.x}rem;--deco-y:${card.deco.y}rem;--deco-h:${card.deco.h}rem;--vb-top:${card.deco.vbTop}rem;--vb-h:${card.deco.vbH}rem;--hb-x:${card.deco.hbX}rem;--hb-w:${card.deco.hbW}rem;--small-c-x:${card.deco.smallCX}rem;`}
          aria-hidden="true"
        >
          <div class="deco-line deco-v-a"></div>
          <div class="deco-line deco-v-b"></div>
          <div class="deco-line deco-h-a"></div>
          <div class="deco-line deco-h-b"></div>
          <div class="deco-line deco-h-c"></div>
          <SparkOrange class="deco-spark deco-spark-big-a" />
          <SparkOrange class="deco-spark deco-spark-big-b" />
          <SparkOrange class="deco-spark deco-spark-small-c" />
          <SparkOrange class="deco-spark deco-spark-tiny-d" />
        </div>
      ))}

      <Image
        src={CapitalArt}
        alt=""
        class="art art-capital"
        widths={[469, 938]}
        sizes="469px"
      />
      <Image
        src={ExpertiseArt}
        alt=""
        class="art art-expertise"
        widths={[253, 506]}
        sizes="253px"
      />
      <Image
        src={InfrastructureArt}
        alt=""
        class="art art-infrastructure"
        widths={[247, 494]}
        sizes="247px"
      />
      <Image
        src={PilotingArt}
        alt=""
        class="art art-piloting"
        widths={[443, 886]}
        sizes="443px"
      />

      {CARDS.map((card) => (
        <article class={`support-card support-card-${card.key}`}>
          <p class="card-eyebrow">{card.eyebrow}</p>
          <h3>{card.title}</h3>
          <p class="subtitle">{card.subtitle}</p>
          <p class="intro">{card.intro}</p>
          <ul>
            {card.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const stage = document.querySelector("[data-support-stage]");
    if (!stage) return;

    const baseWidth = 1757.92;
    const baseHeight = 2688;
    const desktopQuery = window.matchMedia("(min-width: 1200px)");

    const syncStage = () => {
      window.requestAnimationFrame(() => {
        if (!desktopQuery.matches) {
          stage.style.removeProperty("--support-stage-scale");
          stage.style.removeProperty("--support-stage-height");
          return;
        }

        const scale = Math.min(1, stage.getBoundingClientRect().width / baseWidth);
        stage.style.setProperty("--support-stage-scale", String(scale));
        stage.style.setProperty("--support-stage-height", `${baseHeight * scale}px`);
      });
    };

    syncStage();
    window.addEventListener("resize", syncStage, { passive: true });
  })();
</script>

<style>
  .support-stack {
    background: var(--color-cream);
    padding-block: 0 4.75rem;
    overflow-x: clip;
  }

  .stage {
    position: relative;
    width: min(calc(100% - 2.5rem), 109.87rem); /* 1757.92px, node 1:19227/1:19947 combined width */
    height: var(--support-stage-height, 168rem); /* 2688px, support stack top to bottom */
    margin-inline: auto;
  }

  .stage-artboard {
    position: absolute;
    top: 0;
    left: 50%;
    width: 109.87rem;
    height: 168rem;
    transform: translateX(-50%) scale(var(--support-stage-scale, 1));
    transform-origin: top center;
  }

  /* Each card's decorative group is independent (see the CARDS array comment
     for the full derivation). .card-deco is positioned at the card's own
     container origin (--deco-x/-y, from CARDS[].deco) and sized to its own
     container (63.864rem wide x --deco-h tall, 63.281rem for 3 cards,
     60.156rem for Piloting since it's the last card). Every child below is
     positioned relative to THIS wrapper, not the shared artboard. */
  .card-deco {
    position: absolute;
    left: var(--deco-x);
    top: var(--deco-y);
    width: 63.864rem;
    height: var(--deco-h);
    pointer-events: none;
  }

  .deco-line {
    position: absolute;
    z-index: 0;
    background: var(--color-orange);
    opacity: 0.7;
  }

  .deco-v-a,
  .deco-v-b {
    width: 1px;
  }

  .deco-h-a,
  .deco-h-b,
  .deco-h-c {
    height: 1px;
  }

  /* Tall vertical, right side — identical across all 4 cards, always spans
     the wrapper's full height (100%, so it still works for Piloting's
     shorter 60.156rem container without a separate variable). */
  .deco-v-a {
    left: 56.21rem;
    top: 0;
    height: 100%;
  }

  /* Shorter vertical, left side — top/height are the one real per-card
     exception (--vb-top/--vb-h, from CARDS[].deco): Infrastructure's starts
     near the very top (0.324rem) and runs longer (57.842rem) than the other
     3 cards (9.583rem / 48.584rem). */
  .deco-v-b {
    left: 10.212rem;
    top: var(--vb-top);
    height: var(--vb-h);
  }

  /* The "closing" line — full container width, identical across all 4
     cards. This is the line each card's own big corner sparks sit on. */
  .deco-h-a {
    left: 0;
    top: 53.289rem;
    width: 63.864rem;
  }

  /* Short line above the eyebrow — x/width are the other real per-card
     exception (--hb-x/--hb-w, from CARDS[].deco), since each card's own
     content width differs slightly. */
  .deco-h-b {
    left: var(--hb-x);
    top: 4.65rem;
    width: var(--hb-w);
  }

  /* Line just below the subtitle — identical across all 4 cards. */
  .deco-h-c {
    left: 3.896rem;
    top: 17.345rem;
    width: 56.549rem;
  }

  .deco-spark {
    position: absolute;
    z-index: 1;
    pointer-events: none;
  }

  /* Large spark at deco-v-a x deco-h-a (right corner of the closing line).
     Center (56.237, 53.316), 3.799rem square — identical across all 4 cards. */
  .deco-spark-big-a {
    left: 54.3375rem;
    top: 51.4165rem;
    width: 3.799rem;
    height: 3.799rem;
  }

  /* Large spark at deco-v-b x deco-h-a (left corner of the closing line).
     Center (10.242, 53.316), 3.799rem square — identical across all 4 cards. */
  .deco-spark-big-b {
    left: 8.3425rem;
    top: 51.4165rem;
    width: 3.799rem;
    height: 3.799rem;
  }

  /* Small spark paired with deco-h-b (the short top line), at whichever end
     meets a vertical -- --small-c-x (from CARDS[].deco.smallCX): right side
     (55.257rem, center 56.237) at deco-v-a for 3 of 4 cards, but LEFT side
     (9.261rem, center 10.241) at deco-v-b for Infrastructure specifically,
     since its own h-b is mirrored to the left too. Confirmed per-card via
     Figma screenshot -- this was wrongly assumed uniform on the first pass. */
  .deco-spark-small-c {
    left: var(--small-c-x);
    top: 3.699rem;
    width: 1.96rem;
    height: 1.96rem;
  }

  /* Tiny, non-square spark at deco-v-b x deco-h-c (left end of the
     subtitle-underline line). Center (10.732, 17.375), 0.98 x 1.96rem —
     identical across all 4 cards. */
  .deco-spark-tiny-d {
    left: 10.242rem;
    top: 16.395rem;
    width: 0.98rem;
    height: 1.96rem;
  }

  .art {
    position: absolute;
    z-index: 1;
    height: auto;
    pointer-events: none;
  }

  .art-capital {
    left: 63.86rem; /* node 1:20698 */
    top: 14.69rem;
    width: 29.15rem;
  }

  .art-expertise {
    left: 27.32rem; /* node 1:20756 */
    top: 55.23rem;
    width: 15.66rem;
  }

  .art-infrastructure {
    left: 67.8rem; /* node 1:20788 */
    top: 93.84rem;
    width: 15.3rem;
  }

  .art-piloting {
    left: 20.07rem; /* node 1:20844 */
    top: 129.73rem;
    width: 27.52rem;
  }

  .support-card {
    position: absolute;
    z-index: 2;
    width: 36.25rem;
    background: var(--color-cream);
  }

  .support-card-capital {
    left: 15.18rem;
    top: 7.16rem;
  }

  .support-card-expertise {
    left: 60.56rem;
    top: 43.11rem;
  }

  .support-card-infrastructure {
    left: 15.18rem;
    top: 79.06rem;
  }

  .support-card-piloting {
    left: 60.56rem;
    top: 114.98rem;
  }

  .card-eyebrow {
    margin: 0 0 0.28rem;
    font-family: var(--font-display);
    /* calc()'d against --support-stage-scale (set by the script below on
       .stage, inherited here) rather than a plain 1.375rem: .stage-artboard
       is transform:scale()'d down at any viewport under ~1798px (its own
       width is capped at the 1757.92px Figma canvas), which was shrinking
       this text right along with the diagram geometry -- e.g. ~29px
       instead of the intended 32px h3 at a common 1600px laptop width,
       confirmed via pixel measurement. Dividing by the same scale factor
       counteracts it, keeping the text's rendered size constant regardless
       of viewport, while the lines/sparks/illustrations still scale
       normally to keep their Figma-derived proportions. The var()'s `, 1`
       fallback makes this a no-op below 1200px (where the script removes
       the property entirely) and at >=1798px (where scale is already 1). */
    font-size: calc(1.375rem / var(--support-stage-scale, 1)); /* 22px, increased from 18.25px per user directive 2026-07-07 */
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #949494;
  }

  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: calc(2rem / var(--support-stage-scale, 1)); /* 32px, reduced from 43.21px per user directive 2026-07-07 -- see .card-eyebrow comment above for the scale counter-compensation */
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-orange);
  }

  .subtitle {
    margin: -0.15rem 0 0;
    font-family: var(--font-display);
    font-size: calc(1.375rem / var(--support-stage-scale, 1)); /* 22px, reduced from 27.07px per user directive 2026-07-07 -- see .card-eyebrow comment above for the scale counter-compensation */
    line-height: 1.3;
    color: var(--color-ink-alt);
  }

  .intro {
    max-width: 35.1rem;
    margin: 4.85rem 0 0;
    font-family: var(--font-sans);
    font-size: calc(1.0625rem / var(--support-stage-scale, 1)); /* 17px, reduced from 19.68px per user directive 2026-07-07 -- see .card-eyebrow comment above for the scale counter-compensation */
    line-height: 1.33;
    color: #1e1e3e;
  }

  ul {
    display: grid;
    gap: 0.75rem;
    max-width: 32rem;
    margin: 1.7rem 0 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-sans);
    font-size: calc(1.0625rem / var(--support-stage-scale, 1)); /* 17px, reduced from 18.88px per user directive 2026-07-07 -- see .card-eyebrow comment above for the scale counter-compensation */
    line-height: 1.28;
    color: #1e1e3e;
  }

  li {
    position: relative;
    padding-inline-start: 2rem;
  }

  li::before {
    content: "";
    position: absolute;
    left: 0.45rem;
    top: 0.47rem;
    width: 0.55rem;
    height: 0.55rem;
    border-top: 2px solid var(--color-ink-alt);
    border-right: 2px solid var(--color-ink-alt);
    transform: rotate(45deg);
  }

  @media (max-width: 1199.98px) {
    .stage {
      width: min(100% - 2.5rem, 48rem);
      height: auto;
    }

    .stage-artboard {
      position: static;
      width: 100%;
      height: auto;
      display: grid;
      gap: 4rem;
      padding-block: 2rem 5rem;
      transform: none;
    }

    .card-deco {
      display: none;
    }

    .art,
    .support-card {
      position: static;
    }

    .support-card {
      width: min(100%, 36rem);
      background: transparent;
    }

    /* .art used to share the .support-card's width:min(100%,36rem) cap
       above, plus a blanket max-width:70% below -- discarding each
       illustration's own distinct native size (29.15rem/15.66rem/15.3rem/
       27.52rem, all different) in favor of one shared value. That's fine
       for Capital/Piloting (already close to or bigger than the shared
       cap) but massively inflates Expertise/Infrastructure, the two
       smallest illustrations -- confirmed live at 825px, where
       Infrastructure's compass-in-hand icon rendered at ~660px, nearly
       triple its intended 245px. Each illustration now gets its own
       max-width (its existing desktop-native size, reused as the ceiling)
       so it stays fluidly responsive but never exceeds its correct size. */
    .art {
      justify-self: center;
      width: 100%;
    }
    .art-capital {
      max-width: 29.15rem;
    }
    .art-expertise {
      max-width: 15.66rem;
    }
    .art-infrastructure {
      max-width: 15.3rem;
    }
    .art-piloting {
      max-width: 27.52rem;
    }

    .support-card {
      justify-self: center;
    }

    .intro {
      margin-top: 2rem;
    }

    .support-card-capital {
      order: 1;
    }
    .art-capital {
      order: 2;
    }
    .support-card-expertise {
      order: 3;
    }
    .art-expertise {
      order: 4;
    }
    .support-card-infrastructure {
      order: 5;
    }
    .art-infrastructure {
      order: 6;
    }
    .support-card-piloting {
      order: 7;
    }
    .art-piloting {
      order: 8;
    }
  }

  @media (max-width: 559.98px) {
    h3 {
      font-size: clamp(1.75rem, 8vw, 2rem); /* ceiling/floor both reduced to match the new 32px desktop size per user directive 2026-07-07 */
    }

    .subtitle {
      font-size: clamp(1.125rem, 5vw, 1.375rem); /* ceiling/floor both reduced to match the new 22px desktop size per user directive 2026-07-07 */
    }

    .intro,
    ul {
      font-size: 1rem;
    }
  }
</style>
