---
// Figma file u4NLOVKuXUTKULhSn0sAJQ, groups 1:9174 (eyebrow/H2/intro) and 1:9306
// (4 stat columns). Node ids + exact derivations are documented inline in the
// style block below. Two corrections vs. the task brief/starter guesses,
// confirmed against the Figma reference code and pixel-sampled screenshots:
//   1. The eyebrow (1:9175) is set in Faculty_Glyphic per the Figma reference
//      code's own font-family class, NOT Sora as the brief guessed (other
//      sections' eyebrows are Sora, but this one's node data is explicit).
//   2. The stat descriptions sample to solid RGB(30,30,60) = #1e1e3c =
//      --color-ink-alt, NOT --color-gray as the brief guessed — same
//      gray-vs-navy correction SponsorStrip.astro already made for its
//      caption text.
import SparkOrange from "../../assets/about/spark-orange.svg";
import RevealStar from "../../assets/shared/reveal-star.svg";

const STATS = [
  { value: "4OO+ acres", desc: "Dedicated R&D campuses across the energy majors" },
  { value: "12+", desc: "R&D centres and labs open to startups" },
  { value: "Pan India", desc: "Refining, E&P, gas, LNG and retail operations" },
  { value: "7", desc: "Balance sheets behind a single mandate", arrowTarget: "1" },
];
---

<section class="scale">
  <div class="container reveal">
    <p class="eyebrow">THE SCALE BEHIND YOU</p>
    <h2>
      <span class="reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">The industrial weight behind</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>{" "}
      <span class="reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">every venture.</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </h2>
    <p class="intro reveal-rise reveal-rise--after-2-lines">
      Seven energy majors contribute infrastructure, domain mentorship, pilot
      sites and anchor demand, assets no standalone incubator can replicate.
    </p>

    <div class="stats-wrap">
      <!-- Desktop-only (>=1024px) Figma-exact grid overlay (see .grid-lines
           below) — the mobile rail (<=559.98px) is a separate, simpler
           treatment defined further down, not derived from this. -->
      <div class="grid-lines" aria-hidden="true">
        <span class="gline gline-v gline-v1"></span>
        <span class="gline gline-v gline-v2"></span>
        <span class="gline gline-v gline-v3"></span>
        <span class="gline gline-v gline-v4"></span>
        <span class="gline gline-v gline-v5"></span>
        <span class="gline gline-h gline-h-top"></span>
        <span class="gline gline-h gline-h-bottom"></span>
        <SparkOrange class="gspark gspark-1" />
        <SparkOrange class="gspark gspark-2" />
        <SparkOrange class="gspark gspark-3" />
        <SparkOrange class="gspark gspark-4" />
        <SparkOrange class="gspark gspark-5" />
        <SparkOrange class="gspark gspark-6" />
        <SparkOrange class="gspark gspark-7" />
        <SparkOrange class="gspark gspark-8" />
      </div>

      <ul class="stats">
        {STATS.map((s, i) => (
          <li>
            {/* Mobile-only (<=559.98px) rail boundary marker — display:none
                outside that breakpoint (see .stat-spark-top below), so this
                doesn't clash with the desktop .grid-lines sparks above. */}
            {i > 0 && <SparkOrange class="stat-spark stat-spark-top" aria-hidden="true" />}
            <p class="stat-value">
              {s.value}
              {s.arrowTarget && <span class="stat-arrow" aria-hidden="true"> &rarr; {s.arrowTarget}</span>}
            </p>
            <p class="stat-desc">{s.desc}</p>
          </li>
        ))}
        <!-- Mobile-only (<=559.98px) left rail: a continuous vertical line
             running the full height of the stacked 1-col layout, paired
             with the top sparks above as boundary markers (dev-feedback:
             don't drop this treatment outright on mobile, give it a rail
             instead). display:none outside that breakpoint. -->
        <span class="stats-rail" aria-hidden="true"></span>
      </ul>
    </div>
  </div>
</section>

<style>
  .scale {
    background: var(--color-cream);
    /* Was 11.74rem, treating the full Scale-top(3409.04) − Sponsor-bottom
       (3221.27) gap as this section's own padding. That double-counted: a
       spark (node 1:9495) sits inside that same 187.77px gap, ~63px below
       the pills and ~75px above this section's own eyebrow — its size/margin
       are now accounted for on SponsorStrip's own .divider-spark, so this
       padding should only cover the remaining spark-to-eyebrow portion:
       75.0px = 4.6875rem. Bottom: Footer-top (4103) − Scale-bottom (4033.50,
       node 1:9173) ≈ 69.5px = 4.34rem — Scale is the last section before the
       footer, so it owns both edges of its surrounding gaps. */
    padding-block: 4.6875rem 4.34rem;
    text-align: center;
    /* Contains the grid-lines' genuine Figma bleed past .stats-wrap's own
       edges, and the mobile rail's own negative left offset. `clip`, not
       `hidden`: per spec, overflow-x:hidden with overflow-y:visible computes
       overflow-y to `auto`, turning the section into a scroll container —
       which is exactly the vertical scrollbar the user reported when the
       grid lines protruded past the section box. `clip` clips without ever
       creating a scroll container (SupportStack.astro precedent). */
    overflow-x: clip;
  }

  /* Eyebrow (text node 1:9175): Figma reference code returns
     font-['Faculty_Glyphic:Regular'] text-[27.07px] text-[#959595]
     tracking-[6.7675px] — an exact, unambiguous match (real text node, not
     vectorized). Color = --color-gray. 6.7675 / 27.07 = 0.25 exactly, so
     letter-spacing is a clean 0.25em. CORRECTS the starter's --font-sans /
     0.2em guesses: this eyebrow is set in the display face, unlike
     SponsorStrip's/Mission's Sora eyebrows — confirmed visually too, the
     isolated screenshot shows serifed letterforms (flared "Y", bracketed
     "T"/"S"), not Sora's geometric sans. */
  .eyebrow {
    font-family: var(--font-display);
    color: var(--color-gray);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-size: 1.375rem; /* 22px — reduced from 27.07px per user directive 2026-07-07 (desktop type felt oversized on sub-1920 laptops) */
    margin: 0 0 1.25rem;
  }

  /* H2 (real text nodes 1:9177/1:9178): reference code gives
     text-[#1e1e3c] text-[65px] font-['Faculty_Glyphic:Regular'] — identical
     treatment to Mission.astro's and SponsorStrip.astro's H2s. */
  h2 {
    font-family: var(--font-display);
    font-size: 3.25rem; /* 52px — reduced from the Figma 65px per user directive 2026-07-07 (desktop type felt oversized on sub-1920 laptops) */
    color: var(--color-ink-alt);
    margin: 0 0 1.75rem;
  }
  h2 .reveal-line {
    display: block;
  }

  /* Intro (group 1:9179) is a vectorized paragraph, not real text, so its
     size is reverse-engineered the same way as Mission's body / SponsorStrip's
     eyebrow: the "S" of "Seven" (vector 1:9180) measures 19.16px cap height;
     against Sora's capHeight/upm of 0.73 -> 19.16 / 0.73 ≈ 26.25px. Line-top
     delta between line 1 (y 3613.12) and line 2 (y 3646.06) is 32.94px ->
     32.94 / 26.25 ≈ 1.255, rounded to 1.26. Color pixel-sampled from the full
     heading screenshot: RGB(149,149,149) = #959595 = --color-gray, matching
     the brief's guess. */
  .intro {
    max-width: 44rem;
    /* Bottom margin was 3rem (48px), predating the grid-lines rebuild. The
       grid's tallest verticals rise 4.9813rem (79.7px, Figma-exact) above
       .stats-wrap, so at 3rem they crossed ~2rem into this text
       (user-reported overlap). Figma's own intro-bottom -> stats-top gap is
       ~99.56px (intro line-2 top y3646.06 + ~32.94 line height ≈ 3679;
       stats top 3778.56) = 6.22rem, which puts the line tops ~20px below
       the intro — matching the design. Reverted to 3rem at <=1023.98px,
       where the grid is hidden and the extra gap would be dead space. */
    margin: 0 auto 6.22rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem; /* 17px — reduced from the --text-body token's 20px per user directive 2026-07-07 (overridden locally) */
    line-height: 1.26;
    color: var(--color-gray);
    text-align: justify; /* sitewide paragraph-justify pass */
  }

  /* Stats row (group 1:9306). Labels (1:9309/1:9354/1:9388/1:9429, real text
     nodes) are text-[#f37d2c] text-[35.23px] font-['Faculty_Glyphic:Regular']
     per the Figma reference code — an exact match for --color-orange at
     2.2019rem (rounded 2.2rem here, a 0.03px difference). Stat 1's "4OO+"
     and "acres" are two separate text nodes stacked in the same orange
     group (1:9308), which is why they're both inside one .stat-value <p>
     with a <br /> between them, both inheriting the orange color. Stat 4
     ("7") has its own free-floating arrow vector (node 1:9464, positioned
     immediately right of the "7" text) — confirmed by both the design
     context and the get_screenshot render ("7 →"), rendered here as a
     literal &rarr; glyph.

     Descriptions (the "Dedicated R&D campuses..." vectorized paragraphs,
     e.g. group 1:9311) pixel-sample to a solid RGB(30,30,60) = #1e1e3c =
     --color-ink-alt — CORRECTS the brief's --color-gray guess (Figma wins;
     same gray-vs-navy correction SponsorStrip.astro made for its captions).
     Size derived the same way as the intro: "D" of "Dedicated" (vector
     1:9312) measures 14.74px cap height -> 14.74 / 0.73 ≈ 20.19px = 1.26rem. */
  /* Full re-derivation from Figma's raw node tree (get_metadata on 1:9305,
     fileKey u4NLOVKuXUTKULhSn0sAJQ), not the earlier "readable core"
     simplification (which dropped 2 of 5 verticals and clamped both
     horizontals' bleeding ends to avoid overflow). Calibration: text group
     1:9306 (x=242.15 y=3778.56 w=1383.96 h=144.67) maps 1:1 to .stats-wrap,
     confirmed because the previous code's .stats::before{left:35.07%} — kept
     from an earlier partial pass — matches this calibration's h-top left%
     exactly. .stats itself needs an explicit max-width matching Figma's
     1383.96px content width (86.5rem) since it previously just inherited
     .container's wider 1760px, which would have put every line/spark at the
     wrong absolute position despite correct percentages. */
  .stats-wrap {
    position: relative;
    max-width: 86.5rem;
    margin-inline: auto;
    /* Reserves the grid lines' below-stats overhang in layout height: the
       deepest verticals end 254.9px below .stats-wrap's top = 110.23px
       (6.89rem) past its Figma-calibrated bottom (group bottom 4033.5 −
       stats text bottom 3923.23). The lines are absolutely positioned, so
       without this the section's own 4.34rem bottom padding (derived from
       the Figma group bottom, i.e. already assuming the lines counted
       toward layout height) couldn't contain them — they protruded past
       the section and, combined with the old overflow-x:hidden scroll
       container, produced the vertical scrollbar the user reported.
       Zeroed at <=1023.98px where the grid is hidden. */
    margin-bottom: 6.89rem;
  }
  .stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    text-align: left;
  }
  .stats li {
    padding: 2.5rem 1.5rem 0;
  }
  /* Mobile-only rail (<=559.98px), see media block below for the visible
     rule — no-op at tablet/desktop. .has-divider/border-left from the
     earlier per-item-border system is gone (no <li> gets that class
     anymore), superseded entirely by .grid-lines below. */
  .stats-rail {
    display: none;
  }
  /* Rail boundary-marker spark (<=559.98px only — see media block below).
     Hidden by default so it never doubles up with .grid-lines' own sparks
     at tablet/desktop, where .grid-lines itself is also hidden anyway. */
  .stat-spark {
    display: none;
    position: absolute;
    left: -0.75rem;
    width: 1.4rem;
    height: 1.4rem;
  }
  .stat-spark-top {
    top: -0.75rem;
  }
  .grid-lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .gline {
    position: absolute;
    background: var(--color-orange);
  }
  .gline-v {
    width: 1px;
  }
  .gline-h {
    height: 1px;
  }
  /* 5 verticals: the 3 internal column dividers (v2/v3/v4) plus the 2 outer
     ones that bleed past .stats-wrap's own edges (v1 right, v5 left) —
     dropped by the earlier simplification, restored here. Each has its own
     top/height per Figma (not a uniform rise/drop shared across all 5). */
  .gline-v1 {
    left: 106.97%;
    top: -4.9813rem;
    height: 15.2875rem;
  }
  .gline-v2 {
    left: 79.44%;
    top: -4.9813rem;
    height: 18.4125rem;
  }
  .gline-v3 {
    left: 51.9%;
    top: -3.7313rem;
    height: 19.6625rem;
  }
  .gline-v4 {
    left: 24.37%;
    top: -3.1063rem;
    height: 19.0375rem;
  }
  .gline-v5 {
    left: -3.17%;
    top: 2.2062rem;
    height: 13.725rem;
  }
  /* 2 horizontals, true Figma bleed (not clamped to a positive inset like
     the earlier pass) — .scale gets overflow-x:hidden below to contain it
     safely at any viewport width instead. */
  .gline-h-top {
    left: 35.07%;
    right: -23.25%;
    top: -1.8188rem;
    background: linear-gradient(to right, var(--color-orange) 0%, var(--color-orange) 65%, transparent 100%);
  }
  .gline-h-bottom {
    left: -19.51%;
    right: 39.84%;
    top: 12.8313rem;
    background: linear-gradient(to right, transparent 0%, var(--color-orange) 35%, var(--color-orange) 100%);
  }
  /* 8 sparks, each at a real line x line crossing (confirmed geometrically —
     v1 doesn't reach h-bottom's y and v5 doesn't reach h-top's y, so those 2
     crossings genuinely don't exist and have no spark). Sizes vary per
     Figma, not a uniform token. */
  .gspark {
    position: absolute;
    transform: translate(-50%, -50%);
  }
  .gspark-1 {
    /* v2 x h-bottom, tiny */
    left: 79.47%;
    top: 12.8625rem;
    width: 0.5425rem;
    height: 0.5425rem;
  }
  .gspark-2 {
    /* v1 x h-top */
    left: 107.01%;
    top: -2.1875rem;
    width: 3.0962rem;
    height: 2.3044rem;
  }
  .gspark-3 {
    /* v2 x h-top */
    left: 79.47%;
    top: -2.1875rem;
    width: 3.0963rem;
    height: 2.3044rem;
  }
  .gspark-4 {
    /* v3 x h-bottom */
    left: 51.92%;
    top: 12.875rem;
    width: 2.2075rem;
    height: 2.2075rem;
  }
  .gspark-5 {
    /* v3 x h-top */
    left: 51.94%;
    top: -2.0812rem;
    width: 2.2662rem;
    height: 1.6869rem;
  }
  .gspark-6 {
    /* v4 x h-bottom */
    left: 24.4%;
    top: 12.8625rem;
    width: 3.0963rem;
    height: 3.0963rem;
  }
  .gspark-7 {
    /* v4 x h-top, small */
    left: 24.4%;
    top: -1.7937rem;
    width: 1.0225rem;
    height: 1.0225rem;
  }
  .gspark-8 {
    /* v5 x h-bottom */
    left: -3.14%;
    top: 12.8625rem;
    width: 3.0962rem;
    height: 3.0963rem;
  }
  .stat-value {
    font-family: var(--font-display);
    font-size: 1.75rem; /* 28px — reduced from 35.23px per user directive 2026-07-07, matches Audiences' analogous column-title cut on Home */
    color: var(--color-orange);
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }
  .stat-arrow {
    color: var(--color-orange);
  }
  .stat-desc {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm); /* 20.19px, derived — see comment above — normalized to home hero scale per user directive 2026-07-06 */
    color: var(--color-ink-alt); /* correction: sampled navy, not --color-gray */
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 1023.98px) {
    h2 {
      font-size: clamp(2.2rem, 6vw, 3.25rem);
    }
    .stats {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 2.5rem;
    }
    /* Desktop-only per user request — the grid's percentage positions are
       derived against the 4-column layout and don't translate to the
       2-col/1-col mobile layouts. */
    .grid-lines {
      display: none;
    }
    /* With the grid hidden, its desktop clearance spacing (intro's 6.22rem
       Figma gap for the rising line tops; stats-wrap's 6.89rem reserve for
       the line overhang below) would just be dead space — revert both. */
    .intro {
      margin-bottom: 3rem;
    }
    .stats-wrap {
      margin-bottom: 0;
    }
  }
  @media (max-width: 559.98px) {
    /* Dev feedback: "every" was orphaning below "The industrial weight
       behind" (itself wrapping to 2 internal rows at the narrowest phone
       widths, since this heading's own 2 hardcoded `.reveal-line` spans
       are unconditionally forced one-per-row below).

       DEVIATION from the reviewed plan, in two parts, both verified live
       before fixing:
       1. The plan called for switching only `.reveal-line` to `display:
          inline` and expected the nested `.reveal-line-box`/`.reveal-
          line-text` (both `display: inline-block` in the shared
          global.css) to reflow along with it. That doesn't work: an
          inline-block's shrink-to-fit width, once its content is wider
          than the available space, is assigned that full available width
          as its own box — so even though its wrapped text visibly leaves
          trailing space on its last internal row, the BOX itself still
          claims the whole row, leaving no actual room for a sibling inline
          element to sit in. `.reveal-line` alone becoming inline had no
          visible effect for this reason — all 3 nesting levels need to
          flatten to plain `inline` (scoped locally to this component, so
          Hero.astro/Pillars.astro's own instances of the same shared
          classes are untouched).
       2. The plan suggested scoping this to the shared "sanctioned
          adaptation below 1024px" breakpoint (matching where the star +
          clip-path reveal already give way to a plain fade sitewide).
          Tried that first and it overshot: in the ~640-1023px tablet
          range each line already fits cleanly on its own full row without
          wrapping (matching desktop's 2-line split, just at a smaller
          fluid font-size) — joining them there didn't fix an orphan, it
          CREATED one ("venture." landing alone on its own row). Scoped
          instead to this file's own narrower 559.98px breakpoint, which
          matches where "The industrial weight behind" actually starts
          wrapping on its own (verified live: still wrapped at 500px,
          clean single row by 560px).
       Safe re: the star: `.reveal-star` is already `display: none` below
       1024px sitewide, so there's no star-positioning concern from a
       wrapped plain-inline containing block either way. */
    h2 .reveal-line,
    h2 .reveal-line-box,
    h2 .reveal-line-text {
      display: inline;
    }
    /* Two more DEVIATIONS, both needed once the plain-inline reflow above
       actually started working, and both verified live at every width in
       320-559px:
       1. Without `nowrap` here, reflow can still produce a NEW single-word
          orphan of its own: at 390px, "every venture." (line 2's full
          text) split mid-phrase into "...behind every" / "venture." —
          trading the original "every" orphan for a "venture." orphan.
          Line 2's text is short enough to treat as one atomic unit:
          nowrap means it either joins line 1's last wrapped row in full
          (when there's room, e.g. 430-559px) or drops to its own full row
          un-split (matching the original, acceptable "every venture."
          together on one row — e.g. 320-390px, where there truly isn't
          room for it to join) — it can never itself be torn across two
          rows. Only line 2 needs this: line 1 is the long phrase that's
          SUPPOSED to keep wrapping internally to make room.
       2. Even with (1), line 1's OWN internal wrap could still land badly:
          at 390px specifically, line 1 wrapped as "The industrial weight" /
          "behind" with the atomic "every venture." bumped to its own row —
          leaving "behind" alone, a new single-word orphan one word over
          from the original bug. `text-wrap: balance` (applied to the h2,
          which is still `display: block` — only its children flattened to
          inline above) asks the browser to distribute line 1's wrapped
          text more evenly instead of greedily maximizing each row, which
          resolves this: "behind" rejoins "weight" ("The industrial" /
          "weight behind") at 390px, with (1)'s atomic "every venture."
          still bumped to its own row since there still isn't room — the
          same non-orphaned fallback layout as the un-joinable widths. */
    h2 .reveal-line:nth-of-type(2) .reveal-line-text {
      white-space: nowrap;
    }
    h2 {
      text-wrap: balance;
    }
    .stats {
      grid-template-columns: 1fr;
    }
    .stats li {
      /* Clears the rail + spark, which sit at left: -0.75rem. */
      padding-left: 1.5rem;
    }
    .stats-rail {
      display: block;
      position: absolute;
      top: 0;
      bottom: 0;
      left: -0.75rem;
      width: 1px;
      background: var(--color-orange);
    }
    /* Overrides .stat-spark's own display:none base (added when merging
       this rail feature against the .grid-lines rebuild, so the rail's
       markers don't double up with .grid-lines' sparks at wider widths).
       Only the top spark per boundary item is shown, as the 3 boundary
       markers, repositioned to align with the rail. No nth-child(odd)
       override needed here (unlike the earlier per-item-border system) —
       .grid-lines is a single desktop-only overlay, not per-item, so there
       was never a competing odd/even hide-rule at this breakpoint. */
    .stat-spark-top {
      display: block;
      left: -0.75rem;
    }
  }
</style>
