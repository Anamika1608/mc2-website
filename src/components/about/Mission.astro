---
// Figma file u4NLOVKuXUTKULhSn0sAJQ, group 1:8065: heading "Our Mission" (1:8066,
// x201.65 w360) left column, body paragraph group (1:8067, x600.79 w673.66) right
// column. See exact derivations in style block below.
import RevealStar from "../../assets/shared/reveal-star.svg";
---

<section class="mission">
  <div class="container grid reveal">
    <h2>
      <span class="reveal-line">
        <span class="reveal-line-box">
          <span class="reveal-line-text">Our Mission</span>
          <RevealStar class="reveal-star" aria-hidden="true" />
        </span>
      </span>
    </h2>
    <p class="body reveal-rise reveal-rise--after-1-line">
      Take energy ventures from idea to industrial deployment through
      unmatched access to infrastructure, capital, mentorship and market
      access.
    </p>
  </div>
</section>

<style>
  .mission {
    background: var(--color-cream);
    /* Figma gap Mission-top (1230.41) − Hero-bottom (984.16, node 1:9499's
       scroll-chevron) ≈ 246.25px = 15.39rem. Bottom is 0 — the Mission-to-Vision
       gap is owned by Vision's own padding-block-start (see Vision.astro). */
    padding-block: 15.39rem 0;
  }

  /* Column widths from node 1:8065 (fileKey u4NLOVKuXUTKULhSn0sAJQ): heading
     text bbox (1:8066) is x=201.65 w=360 -> ends at x=561.65; body group bbox
     (1:8067) is x=600.79 w=673.66. Gap = 600.79 - 561.65 = 39.14px = 2.45rem.
     Heading column = 360px = 22.5rem. Body column = 673.66px = 42.10rem
     (rounded 42.1rem) — confirms the plan's ~42rem estimate almost exactly. */
  .grid {
    display: grid;
    grid-template-columns: minmax(0, 22.5rem) minmax(0, 42.1rem);
    gap: 2.45rem;
    align-items: start; /* heading's visual cap-top and body's first-line
      ink-top land within ~10px of each other once the heading text box's
      own leading is discounted (box top 1230.41 + ~half-leading ≈ 1249.66
      vs body first-line ink top 1260.05); matches the screenshot's shared
      top edge. */
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 4.0625rem; /* 65px, node 1:8066 */
    color: var(--color-ink-alt); /* #1e1e3c */
  }

  .body {
    /* Body (1:8067) is an outlined/vectorized paragraph, not real text, so its
       font-size is reverse-engineered the same way as AboutHero's lede: the
       "T" in "Take" (vector 1:8068) measures 22.63px tall — identical to the
       hero lede's "M" ink height — against Sora's capHeight/upm of 0.73 ->
       22.63/0.73 ≈ 31.0px. This CORRECTS the plan's rough ~20px guess (Figma
       wins); it happens to match the hero lede's own derived 31px exactly,
       consistent with both using the same body-paragraph text style. Line
       height is likewise derived from line-top deltas (first line "Take" top
       1260.05, second line "deployment" top 1300.51 -> delta 40.46px) /
       31px ≈ 1.305, rounded to 1.31 (same as the hero lede's derived value). */
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-body-lg); /* 31px, derived — see comment above — normalized to home hero scale per user directive 2026-07-06 */
    line-height: 1.4; /* was 1.31 — normalized to home hero scale per user directive 2026-07-06 */
    color: var(--color-ink); /* body text token */
  }

  @media (max-width: 1023.98px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    h2 {
      font-size: clamp(2.4rem, 6vw, 4.0625rem);
    }
  }

  @media (max-width: 767.98px) {
    .grid {
      gap: 0.85rem;
    }
  }
</style>
