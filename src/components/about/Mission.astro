---
// Figma file u4NLOVKuXUTKULhSn0sAJQ, group 1:8065: heading "Our Mission" (1:8066,
// x201.65 w360) left column, body paragraph group (1:8067, x600.79 w673.66) right
// column. See exact derivations in style block below.
---

<section class="mission">
  <div class="container grid">
    <h2>Our Mission</h2>
    <p class="body">
      Take energy ventures from idea to industrial deployment through
      unmatched access to infrastructure, capital, mentorship and market
      access.
    </p>
  </div>
</section>

<style>
  .mission {
    background: var(--color-cream);
    /* Was 15.39rem (246.25px), derived as Figma's Mission-top − Hero-bottom
       (node 1:9499's scroll-chevron) gap. That assumed hero's own box ended
       right at the scroll arrow — true in the original design, but no
       longer true after AboutHero's min-height was floored to preserve its
       4 baked-in sparks (user directive) rather than shrink to fit the
       (now smaller) hero text: hero's box now extends ~382px past the
       arrow on its own. Stacking the full 246px on top of that reads as
       far too much space (user directive). Reduced to 3rem so the total
       arrow→heading gap is tighter, without re-introducing hero clipping.
       Bottom is 0 — the Mission-to-Vision gap is owned by Vision's own
       padding-block-start (see Vision.astro). */
    padding-block: 3rem 0;
  }

  /* Column widths from node 1:8065 (fileKey u4NLOVKuXUTKULhSn0sAJQ): heading
     text bbox (1:8066) is x=201.65 w=360 -> ends at x=561.65; body group bbox
     (1:8067) is x=600.79 w=673.66 -> 42.1rem. Body column widened to 67.54rem
     (user directive, dev feedback deck) to match Vision's body column exactly
     — a deliberate deviation from Figma's own narrower 42.1rem, so both
     sections read at the same line length. */
  .grid {
    display: grid;
    grid-template-columns: minmax(0, 22.5rem) minmax(0, 67.54rem);
    gap: 2.45rem;
    align-items: start; /* heading's visual cap-top and body's first-line
      ink-top land within ~10px of each other once the heading text box's
      own leading is discounted (box top 1230.41 + ~half-leading ≈ 1249.66
      vs body first-line ink top 1260.05); matches the screenshot's shared
      top edge. */
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 3.25rem; /* 52px — reduced from the Figma 65px per user directive 2026-07-07 (desktop type felt oversized on sub-1920 laptops) */
    color: var(--color-ink-alt); /* #1e1e3c */
  }

  .body {
    /* Body (1:8067) is an outlined/vectorized paragraph, not real text, so its
       font-size is reverse-engineered the same way as AboutHero's lede: the
       "T" in "Take" (vector 1:8068) measures 22.63px tall — identical to the
       hero lede's "M" ink height — against Sora's capHeight/upm of 0.73 ->
       22.63/0.73 ≈ 31.0px. This CORRECTS the plan's rough ~20px guess (Figma
       wins); it happens to match the hero lede's own derived 31px exactly,
       consistent with both using the same body-paragraph text style. Line
       height is likewise derived from line-top deltas (first line "Take" top
       1260.05, second line "deployment" top 1300.51 -> delta 40.46px) /
       31px ≈ 1.305, rounded to 1.31 (same as the hero lede's derived value). */
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.125rem; /* 18px — reduced from the --text-body-lg token's 23px per user directive 2026-07-07 (overridden locally, same approach as Home/Initiatives CtaBand; the shared token itself is untouched) */
    line-height: 1.4; /* was 1.31 — normalized to home hero scale per user directive 2026-07-06 */
    color: var(--color-ink); /* body text token */
    text-align: justify; /* user directive, dev feedback deck — matches Vision's body */
  }

  @media (max-width: 1023.98px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    h2 {
      font-size: clamp(2.4rem, 6vw, 3.25rem);
    }
  }

  @media (max-width: 767.98px) {
    .grid {
      gap: 0.85rem;
    }
  }
</style>
