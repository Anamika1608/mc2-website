---
// Figma file u4NLOVKuXUTKULhSn0sAJQ, group 1:8931: eyebrow (vectorized, node 1:9127),
// H2 "Seven sponsors. One platform." (real text node 1:9126, Faculty 65px, #1e1e3c),
// 7 logo+caption pairs (1:9000 = 7 caption text groups, 1:9102 = 7 logo icon groups),
// ghost pill "Meet the team" (1:8932) + filled pill "Explore initiatives" (1:8953) —
// same node IDs PillButton.astro was already derived from in an earlier task, so its
// pill sizing/colors are reused as-is here. See exact derivations in style block below.
import PillButton from "../PillButton.astro";
import SparkOrange from "../../assets/about/spark-orange.svg";

// Sources swapped 2026-07-07 (user directive) from the old src/assets/about/
// sponsor-*.png imports to new logo exports dropped directly in public/ --
// referenced as plain <img src="/...png"> since public/ files aren't
// processed by astro:assets. width/height were each logo's Figma design bbox
// (node 1:354's children), scaled to 80% per a follow-up user directive
// 2026-07-07 (bumped up from an earlier 65% pass that read as too small) --
// see Home's SponsorStrip.astro for the full math. Same values as Home's,
// kept in sync.
const SPONSORS = [
  { img: "/hindustan-petroleum.png", width: 99, height: 129, caption: "Hindustan Petroleum", alt: "Hindustan Petroleum Corporation" },
  { img: "/oil-naural-gas.png", width: 101, height: 101, caption: "Oil & Natural Gas", alt: "Oil and Natural Gas Corporation" },
  { img: "/indian-oil.png", width: 112, height: 119, caption: "Indian Oil Corp", alt: "Indian Oil Corporation" },
  { img: "/bharat-petroleum.png", width: 81, height: 101, caption: "Bharat Petroleum", alt: "Bharat Petroleum Corporation" },
  { img: "/gas-authority.png", width: 141, height: 106, caption: "Gas Authority", alt: "GAIL (India) Limited" },
  { img: "/oil-india.png", width: 83, height: 122, caption: "Oil India Ltd", alt: "Oil India Limited" },
  { img: "/petronet-lng.png", width: 78, height: 103, caption: "Petronet LNG", alt: "Petronet LNG Limited" },
];
---

<section class="sponsors">
  <div class="container">
    <p class="eyebrow">Backed by India&rsquo;s oil and gas majors with a turnover of $232 billion</p>

    <div class="logos-viewport">
      <ul class="logos">
        {[...SPONSORS, ...SPONSORS].map((s, i) => (
          <li aria-hidden={i >= SPONSORS.length ? "true" : undefined}>
            <span class="logo-frame">
              <img src={s.img} alt={s.alt} width={s.width} height={s.height} class="logo" />
            </span>
            <span class="caption">{s.caption}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="ctas">
      <PillButton label="Meet the team" href="/team" variant="ghost" />
      <PillButton label="Explore initiatives" href="/initiatives" variant="filled" />
    </div>

    <SparkOrange class="divider-spark" aria-hidden="true" />
  </div>
</section>

<style>
  .sponsors {
    background: var(--color-cream);
    /* Figma gap Sponsor-top (2755.41, node 1:8931) − Video-bottom (2656.87,
       node 1:8189's visible clipped still) ≈ 98.54px = 6.16rem. Bottom is 0 —
       the Sponsor-to-Scale gap is owned by Scale's own padding-block-start
       (see Scale.astro). */
    padding-block: 6.16rem 0;
    text-align: center;
  }

  /* Eyebrow (node 1:9127) is a vectorized paragraph, not a real text node, so its
     font-size is reverse-engineered the same way as AboutHero's lede / Mission's
     body: isolated get_screenshot on 1:9127 returns a tight 654x29px ink bbox for
     "Promoted by India's leading energy majors". The line's tallest glyph ("P")
     tops out at Sora's capHeight/upm of 0.73 and its lowest descenders ("g"/"y")
     bottom out at -208/1000 -> full extent 938/1000 of the em -> 29 / 0.938 ≈
     30.9px, which CORRECTS the plan's ~1.25rem/20px guess (Figma wins) and lands
     on the same ~31px body-paragraph size used by Hero's lede and Mission's body.
     Color sampled directly from the exported PNG's darkest opaque pixel: RGB
     (149,149,149) = #959595, an exact match for --color-gray. */
  .eyebrow {
    font-family: var(--font-sans);
    /* Color + size matched to Home's InnovationPartners heading ("Built on
       Partnerships Across India's Innovation Ecosystem") per user directive
       2026-07-09 — same tokens (not literals) so the two stay in sync. This
       supersedes the earlier gray/#959595 sampling and the 17px local
       override of the --text-body token. */
    color: var(--color-ink);
    font-size: var(--text-body); /* 20px */
    margin: 0 0 1.3125rem; /* 21px gap to h2, measured from the full-section screenshot */
  }

  /* H2 (node 1:9126) is a real text node: Tailwind reference code returned it
     literally as `text-[#1e1e3c] text-[65px]` — an exact, unambiguous match for
     --color-ink-alt at 4.0625rem, identical to Mission.astro's H2 treatment. */
  h2 {
    font-family: var(--font-display);
    font-size: 3.25rem; /* 52px — reduced from the Figma 65px per user directive 2026-07-07 (desktop type felt oversized on sub-1920 laptops) */
    color: var(--color-ink-alt);
    margin: 0 0 2.5rem; /* ~40px gap to the logo row, measured from the full-section screenshot */
  }

  /* Logo row (7 icon groups under 1:9102, 7 caption groups under 1:9000).
     width/height per logo are Figma-exact (node 1:194/1:354, matching Home's
     SponsorStrip.astro values) rather than the old flat 120px-height
     approximation. Was also display:grid + repeat(7,minmax(0,1fr)), which
     stretched the row across the full container width, inflating gaps well
     past Figma's own ~103px-average, centered-natural-width layout (confirmed
     via get_screenshot on node 1:194) -- same fix as Home's SponsorStrip. */
  .logos-viewport {
    overflow: hidden;
    width: 100%;
    margin: 0 0 3rem; /* gap to the CTAs — approximate, not pixel-derived (see report) */
  }

  /* Marquee: SPONSORS is rendered twice back-to-back and the track is
     animated left by exactly 50% of its own width (one full set) -- see
     Home's SponsorStrip.astro for the full seamless-loop rationale. */
  .logos {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: nowrap;
    gap: 1.5rem 3rem; /* column-gap bumped from 2rem to 3rem (48px) per user directive 2026-07-07 -- see Home's SponsorStrip.astro for the full math */
    width: max-content;
    animation: sponsor-scroll 32s linear infinite;
  }
  .logos li {
    display: grid;
    gap: 0.75rem;
    justify-items: center;
    flex-shrink: 0;
  }

  @keyframes sponsor-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logos {
      animation-play-state: paused;
    }
  }
  .logo-frame {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    /* Per direct feedback across all 3 carousels: was flat at every
       viewport, reading oversized on narrow phones. Same fluid clamp as
       Home's SponsorStrip.astro/InnovationPartners.astro -- 129px ceiling
       unchanged at desktop, scaling down to a 4.5rem/72px floor by ~375px. */
    height: clamp(4.5rem, 3.635rem + 3.69vw, 8.0625rem); /* 129px ceiling, 80% of the tallest logo (Hindustan Petroleum) -- bottom-aligns every logo inside a box this tall so the row reads level, same technique as Home's SponsorStrip.astro */
  }
  /* .logo is the <img> element itself here (unlike Home's SponsorStrip.astro,
     where .logo wraps a separate img) -- matching the same clamp on its own
     height (width: auto scales proportionally via the aspect ratio its
     width/height HTML attributes already establish) is what actually shrinks
     the rendered logo; the frame's clamp alone wouldn't, since the <img>'s
     explicit HTML attributes otherwise render it at its full intrinsic size. */
  .logo {
    display: block;
    height: clamp(4.5rem, 3.635rem + 3.69vw, 8.0625rem);
    width: auto;
  }

  /* Captions (7 groups under 1:9000) are ALSO vectorized paragraphs, not real
     text. Isolated screenshots of two captions with no descenders
     ("Hindustan Petroleum": 176x13px ink bbox; a second sample: 141x13/14px)
     give a consistent 13px cap-height-to-baseline extent. Against Sora's
     capHeight/upm of 0.73 (same constant as the eyebrow/Hero/Mission
     derivations): 13 / 0.73 ≈ 17.8px. Darkest-pixel color sample from both
     caption PNGs is RGB(30,30,60) — an EXACT match for --color-ink-alt, NOT
     --color-gray as the plan/brief assumed (Figma wins: captions are navy,
     matching the H2's ink, not muted gray). */
  .caption {
    font-family: var(--font-sans);
    font-size: var(--text-caption); /* 17.8px, derived — see comment above — normalized to home hero scale per user directive 2026-07-06 */
    color: var(--color-ink-alt); /* correction: sampled navy, not --color-gray */
  }

  .ctas {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Found via the parent frame's metadata (node 1:9495, x935.23 y3284.5
     w49.54 h49.54, centered on the 1920px canvas) — previously unreachable
     because get_screenshot on 1:8931 cropped flush to the pills, so this was
     guessed at 1.5rem/2rem. Real size is 49.54px = 3.1rem; real gap from the
     pills' bottom (3221.27) to the spark's top (3284.5) is 63.23px = 3.95rem. */
  .divider-spark {
    width: 3.1rem;
    height: 3.1rem;
    margin: 3.95rem auto 0;
  }

  @media (max-width: 1023.98px) {
    h2 {
      font-size: clamp(2.2rem, 6vw, 3.25rem);
    }
  }
  @media (max-width: 559.98px) {
    .ctas {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
