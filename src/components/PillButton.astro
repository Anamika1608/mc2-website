---
// Polymorphic: renders <a href> when href is given (every existing call site),
// or <button type> when it's not — e.g. a form submit control (ContactForm) that
// needs this exact pill styling but can't be a link.
interface Props {
  label: string;
  href?: string;
  type?: "button" | "submit";
  variant?: "filled" | "ghost";
}
const { label, href, type = "button", variant = "filled" } = Astro.props;
const Tag = href ? "a" : "button";
---

<Tag class:list={["pill", variant]} href={href} type={href ? undefined : type}>
  <span class="pill-label">{label}</span>
  <span class="pill-arrow" aria-hidden="true">
    <svg viewBox="0 0 16 16" fill="none">
      <path
        d="M2 8h11M9 3.5 13.5 8 9 12.5"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </span>
</Tag>

<style>
  /*
   * Merge reconciliation (home + about, u4NLOVKuXUTKULhSn0sAJQ): both pages point at
   * the same pill design — home's CTA-band instance "Get in touch" = 1:1479, about's
   * SponsorStrip pair = filled "Explore initiatives" 1:8953 / ghost "Meet the team"
   * 1:8932. Metadata for all three gives the same circle diameter (76px, flush to
   * pill height) and the same label-to-circle gap (25.3-28.9px, one shared value —
   * the ~3.5px spread is ordinary Illustrator-vector-import noise, not a deliberate
   * per-page difference; see the file's own "Illustrator import" caveat). Padding is
   * likewise one shared value (42-46px across the 3 nodes); home's 1:1479 number is
   * kept as it's this repo's most precisely-derived sample (exact node percentages).
   *
   * Font size/weight were RE-DERIVED during merge by isolating the lowercase "e" in
   * all three labels ("Get" / "Meet" / "Explore") and measuring x-height + stroke
   * width directly, letter-for-letter — sidestepping the ascender/descender
   * differences between the three label strings entirely. Result: x-height 17-18px
   * and stroke widths identical (±1px) across all three. Home's 2rem/400 (this
   * component's original filled-only build) was the correct read; about's 1.75rem/600
   * was a derivation error from the earlier about-page task and is corrected here.
   * (About's own label bbox height, 29.14px for "Explore initiatives", looked ~22%
   * taller than home's 23.84px for "Get in touch" — but "Explore" contains a
   * descender, 'p', that neither other label has; correcting for that with the same
   * capHeight/upm≈0.73 and full-extent≈0.938 constants this file's SponsorStrip
   * eyebrow comment already established lands back on ~32px, i.e. 2rem.)
   */
  /*
   * Responsive scaling: the parent CTA rows (SupportCta, CtaBand, etc.) are
   * flex containers that shrink this pill below its natural single-line width
   * on narrow viewports — without fluid sizing here, that just wraps the
   * label at full desktop size (32px font, 76px circle), which reads as
   * cramped and broken on phones (verified via Playwright viewport emulation,
   * not the CLI screenshot tool — that tool doesn't set a real CSS viewport
   * and produces false "cut off" renders at mobile widths). clamp() shrinks
   * every dimension together down to a 375px-ish reference instead of
   * changing at a single breakpoint, matching --container-gutter's existing
   * pattern. Floors keep min font-size at 1rem (legibility) and the arrow
   * circle at 2.75rem/44px (>=44px WCAG 2.5.5 touch-target minimum).
   */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.9rem, 0.55rem + 1.4vw, 1.6rem); /* 25.6px desktop, node 1:1479 */
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.55rem + 2vw, 2rem); /* 32px desktop — verified equal across 1:1479, 1:8953, 1:8932, see block comment above */
    font-weight: 400; /* regular — stroke widths measured pixel-identical across all 3 nodes, not 600 */
    line-height: 1.25; /* breathing room if a long label wraps to 2 lines on the smallest phones */
    text-decoration: none;
    border-radius: 999px;
    padding: 0.4rem 0 0.4rem clamp(1.25rem, 0.65rem + 2.7vw, 2.875rem); /* 46px left inset desktop, node 1:1479; about's nodes measured 42-45px, same shared value within noise */
    border: none;
    margin: 0;
    cursor: pointer;
  }
  .pill-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: clamp(2.75rem, 1.85rem + 3.6vw, 4.75rem); /* 76px desktop — arrow-circle diameter exactly equals pill height in 1:1479, 1:8953 and 1:8932; floor is 44px, the WCAG 2.5.5 touch-target minimum */
    height: clamp(2.75rem, 1.85rem + 3.6vw, 4.75rem);
    border-radius: 999px;
    transition: transform 150ms ease;
  }
  .pill-arrow svg {
    width: 42%; /* 32/76, the icon's original fixed-px ratio to the circle — scales with the clamp() above instead of a hardcoded 32px */
    height: 42%;
  }
  .pill:hover .pill-arrow {
    transform: translateX(3px);
  }

  /* Filled — navy pill, white label, orange arrow circle (1:1479, 1:8953) */
  .pill.filled {
    background: var(--color-ink-alt); /* #1e1e3c, plugin-API-exact sample from 1:8953; ~identical to --color-ink #1e1e3a (home's original token) — imperceptible, standardized on the exact sample */
    color: var(--color-white);
  }
  .pill.filled .pill-arrow {
    background: var(--color-orange);
    /* Both 1:1479 (home) and 1:8953 (about) show a NAVY arrow glyph on the orange
       disc on direct pixel inspection, not white — home's original build (this
       component, filled-only) used white; corrected during merge. */
    color: var(--color-ink-alt);
  }

  /* Ghost — transparent pill, navy hairline border, navy arrow outline (1:8932).
     Not used by any home page call site today. */
  .pill.ghost {
    background: transparent; /* Figma fill is --color-cream, but transparent matches the cream page bg and is more portable */
    color: var(--color-ink-alt);
    box-shadow: inset 0 0 0 2px var(--color-ink-alt); /* measured strokeWeight: 2 (not 1px); inset box-shadow keeps the 76px circle/pill sizing exact */
  }
  .pill.ghost .pill-arrow {
    background: transparent;
    color: var(--color-ink-alt);
    box-shadow: inset 0 0 0 2px var(--color-ink-alt);
  }
</style>
